{{ define "main" }}
<section class="lc-page-section">
  <header class="lc-page-header">
    <h1 class="lc-page-title">Bulk re-verify</h1>
    <p class="lc-page-lede">Up to {{ len .Selected }} certs queued for re-verification. The dashboard rate-limits the witness to a safe call rate; progress updates inline.</p>
  </header>
  <form method="post" action="/certs/bulk-reverify" class="lc-card lc-card--form">
    <input type="hidden" name="csrf" value="{{ .CSRFToken }}">
    {{ range .Selected }}
      <input type="hidden" name="cert_id" value="{{ . }}">
    {{ end }}
    <p class="lc-text-secondary">Click the button below to start the bulk job. The dashboard caps each job at 100 certs.</p>
    <ul class="lc-list font-tabular">
      {{ range .Selected }}<li><code class="lc-mono">{{ . }}</code></li>{{ end }}
    </ul>
    <div class="lc-card-actions">
      <button type="submit" class="lc-login-button">Re-verify {{ len .Selected }} cert{{ if ne (len .Selected) 1 }}s{{ end }}</button>
      <a class="lc-link" href="/certs">Cancel</a>
    </div>
  </form>
</section>
{{ end }}
