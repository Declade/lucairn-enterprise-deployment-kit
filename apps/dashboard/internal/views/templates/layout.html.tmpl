{{ define "layout" }}<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <title>{{ .Title }} — Lucairn Dashboard</title>
  <link rel="stylesheet" href="/static/css/dashboard.css">
  <link rel="stylesheet" href="/static/css/lucairn-tokens.css">
  <link rel="stylesheet" href="/static/fonts/fonts.css">
  <link rel="icon" type="image/svg+xml" href="/static/icons/sprite.svg#icon-mark">
  {{- /*
    Alpine.js powers the per-cert signature-pill click-to-reveal flow on
    the inspector + validator pages and the selection counter on the
    cert browser. Loaded from the layout so every page that uses Alpine
    directives ships with the runtime; the previous Slice 3 layout only
    loaded Alpine on the bulk-progress page, which silently broke the
    inspector's x-data / x-show / x-on:click bindings (bug-hunter F-1).
    `defer` keeps DOM parse non-blocking; Alpine self-initializes on
    DOMContentLoaded.
  */ -}}
  <script defer src="/static/js/alpine.min.js"></script>
</head>
<body class="font-sans bg-bg-base text-text-primary">
  {{ if .User.Email }}
    {{ template "topbar" . }}
    <div class="lc-shell">
      {{ template "sidebar" . }}
      <main class="lc-main">
        {{ template "main" . }}
      </main>
    </div>
  {{ else }}
    <main class="lc-fullscreen">
      {{ template "main" . }}
    </main>
  {{ end }}
</body>
</html>
{{ end }}
