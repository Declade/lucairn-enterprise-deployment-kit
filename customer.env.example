# Lucairn customer environment for Docker Compose installs.
# Copy to customer.env, replace every REPLACE_* value, then run:
#   bin/lucairn doctor --env customer.env --compose docker-compose.customer.yml

LUCAIRN_IMAGE_REGISTRY=ghcr.io/declade
# LUCAIRN_IMAGE_TAG pins the service-image version. Independent of the kit
# version in VERSION (the kit and the services version independently).
#
# v1.0 ships single-replica gateway on 0.5.3 across both Compose and Helm.
# The Helm path persists keys via a PVC mounted at /etc/dsa/keystore (chart
# v1.4.0+). Multi-replica gateway HA + Postgres-backed keystore are roadmapped
# for v2.0 — see INSTALL.md § "v1.0 deployment topology" and § "v2.0 roadmap
# (postgres-gateway keystore)" for the file-keystore details and the opt-in
# recipe for the v2.0 HA path.
LUCAIRN_IMAGE_TAG=0.5.3

# LUCAIRN_PII_ML_IMAGE_TAG pins the pii-ml sidecar image SEPARATELY from the
# umbrella LUCAIRN_IMAGE_TAG above. The pii-ml sidecar (Piiranha + GLiNER
# Phase 7 ML PII scanners) ships on an INDEPENDENT release cadence from the
# core dsa-* services (mirrors the lucairn-dashboard pattern). Default 0.5.1
# matches the multi-arch image at
# ghcr.io/declade/dsa-pii-ml:0.5.1@sha256:5cc46f58db9f0c84f6a8ed9428fe91a2a481ae0c6a3dfa3f02e4a607da80d1cc
# recorded in image-manifest.yaml. `bin/lucairn doctor` validates THIS env
# var (not LUCAIRN_IMAGE_TAG) so a customer override here is caught pre-up.
# Override ONLY when pinning a different pii-ml release.
LUCAIRN_PII_ML_IMAGE_TAG=0.5.1
LUCAIRN_MODEL_DIR=../models

DSA_ENV=production
GRPC_TLS_ENABLED=true
POSTGRES_SSLMODE=disable

# DSA-provided onboarding values.
#
# DSA_LICENSE_KEY: required for production deployments. Leave EMPTY for local
# sandbox / development — the gateway then enters dev mode (no license
# enforcement, "WARNING: no license key configured" logged on boot). For a
# real customer ship, replace the empty default with a Lucairn-provisioned
# signed license bundle (contact Lucairn for issuance).
#
# DO NOT fill in a placeholder string like "REPLACE_WITH_LICENSE_KEY" — any
# non-empty value is validated as a signed token and the gateway will reject
# placeholders with `invalid license key: malformed license key`, which
# defeats the dev-mode bypass.
DSA_LICENSE_KEY=
DSA_LICENSE_SIGNING_KEY=
#
# Deployment entitlement license (Ed25519, offline-verifiable). This is a
# SEPARATE license from DSA_LICENSE_* above: it gates Enterprise-only
# FEATURES (e.g. the custom-trained L3 PII shield) and carries an expiry
# with a grace-then-degrade lifecycle. Lucairn issues you a signed token
# (LUCAIRN_LICENSE_KEY) + a verification public key (LUCAIRN_LICENSE_PUBLIC_KEY).
#   - Leave both EMPTY for sandbox/dev: Enterprise features are available in
#     DSA_ENV=development/test (warn-not-enforce); in production an empty
#     license means unregistered mode — Enterprise features locked, core PII
#     pipeline still runs (it never bricks the compliance function).
#   - After valid_until: a 14-day grace window keeps everything working with
#     loud warnings; after grace, Enterprise features lock (degrade).
# NOTE: these two vars drive Enterprise FEATURE-GATING on any image. They do
# NOT by themselves activate the hardened anti-tamper coupling (fail-closed
# boot on a missing/forged entitlement; POST /api/v1/register disabled;
# DSA_ENV=development bypass closed; customer_id coupling -> 403
# entitlement_mismatch). That coupling is a single switch active ONLY on a
# pin-baked release gateway image Lucairn builds (the Ed25519 public key baked
# into the binary via -ldflags -X). Stock/committed/GHCR images are INERT for
# anti-tamper; setting these vars on a stock image has no anti-tamper effect.
# Contact Lucairn for a pin-baked image if you need anti-tamper enforcement.
# LUCAIRN_LICENSE_GRACE_DAYS overrides the default 14-day grace window.
LUCAIRN_LICENSE_KEY=
LUCAIRN_LICENSE_PUBLIC_KEY=
LUCAIRN_LICENSE_GRACE_DAYS=14
SANDBOX_B_REMOTE_ENDPOINT=https://inference.lucairn.example
SANDBOX_B_API_KEY=REPLACE_WITH_SANDBOX_B_API_KEY
LCR_SANDBOX_B_PUBLIC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_SANDBOX_B_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LOCAL_SANDBOX_B_API_KEY=local-sandbox-b-key

# Internal isolation-probe target. sandbox-b's boot_safety verifies it can
# reach sandbox-a via this gRPC address as part of the witness claim chain.
# The default value matches the canonical self-hosted compose layout; only
# override for split deployments where sandbox-a runs at a different address.
SANDBOX_A_PROBE_TARGET=sandbox-a:50053

# Public gateway URL and local bind ports.
GATEWAY_BASE_URL=REPLACE_WITH_GATEWAY_BASE_URL
GATEWAY_PORT=8080
GATEWAY_HEALTH_PORT=8085
GATEWAY_TRUSTED_PROXY_CIDRS=

# Customer-generated secrets. Replace every REPLACE_ME_* value with a fresh
# secret BEFORE the first `bin/lucairn doctor` run. `doctor` rejects any
# value starting with REPLACE_ME_ as a placeholder. Hex values must be 64
# hex characters (`openssl rand -hex 32`). GATEWAY_KEYSTORE_KEY must decode
# to exactly 32 bytes (`openssl rand -base64 32`).
DSA_SERVICE_TOKEN=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
DSA_BRIDGE_ENCRYPTION_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
SANDBOX_A_ENCRYPTION_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
BRIDGE_MASTER_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
DSA_ADMIN_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
GATEWAY_KEYSTORE_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa=
# HMAC key for sanitizer canary tokens (required when DSA_ENV=production;
# sanitizer refuses to start without it — services/sanitizer/canary.py:317).
# Generate with: openssl rand -hex 32
CANARY_HMAC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Lucairn signing keys (Stage 3 canonical names). Generate each with:
# openssl rand -hex 32. Legacy VEIL_*_SIGNING_KEY names are still accepted at
# runtime by the gateway / sanitizer / witness images (envcompat fallback);
# this template ships the canonical LCR_ names for new installs.
LCR_AUDIT_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_BRIDGE_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_SANITIZER_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_WITNESS_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_GATEWAY_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_MANIFEST_SIGNING_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Public keys paired with the signing keys above. MUST be derived from the
# matching LCR_*_SIGNING_KEY using scripts/derive-veil-pubkey.sh — do NOT
# generate these with `openssl rand -hex 32`. See INSTALL.md step 4a.
LCR_WITNESS_PUBLIC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_BRIDGE_PUBLIC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_SANITIZER_PUBLIC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_AUDIT_PUBLIC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LCR_GATEWAY_PUBLIC_KEY=REPLACE_ME_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Manifest-pubkey verifying keys the gateway publishes at
# /.well-known/veil-keys.json so external SDK verifiers can validate
# the gateway/witness manifest-signed claim shape.
#
# IMPORTANT — these pair with DIFFERENT signing keys:
#   - LCR_GATEWAY_MANIFEST_PUBLIC_KEY is the verifying key for the gateway's
#     manifest signature, which the gateway signs with LCR_MANIFEST_SIGNING_KEY
#     (NOT LCR_GATEWAY_SIGNING_KEY — that is the gateway CLAIM key, a separate
#     seed). Derive it from LCR_MANIFEST_SIGNING_KEY.
#   - LCR_WITNESS_MANIFEST_PUBLIC_KEY pairs with LCR_WITNESS_SIGNING_KEY (the
#     witness signs its manifest with the same seed it uses for claims).
# Generate via:
#   scripts/derive-veil-pubkey.sh "$LCR_MANIFEST_SIGNING_KEY"
#   scripts/derive-veil-pubkey.sh "$LCR_WITNESS_SIGNING_KEY"
# Leaving empty degrades the W2B Runtime Invariant Harness #3 self-check
# silently — verifier still passes for normal cert chains.
LCR_GATEWAY_MANIFEST_PUBLIC_KEY=
LCR_WITNESS_MANIFEST_PUBLIC_KEY=

LCR_ENABLED=true
LCR_WITNESS_KEY_ID=witness_v1
LCR_ISSUER="Lucairn Veil Witness"
LCR_MANIFEST_SIGNING_KEY_ID=gateway_manifest_v1
LCR_WITNESS_SIGNED_MANIFEST_PATH=/certs/witness-signed-manifest.json
WELLKNOWN_CACHE_TTL=300

# Optional mTLS material for remote Sandbox B and witness certificate RPCs.
SANDBOX_B_CLIENT_CERT=
SANDBOX_B_CLIENT_KEY=
SANDBOX_B_CA_CERT=
SANDBOX_B_CERT_DIR=
LCR_WITNESS_MTLS_HOST_DIR=
WITNESS_MTLS_CA_BUNDLE_PATH=
WITNESS_MTLS_SERVER_CERT_PATH=
WITNESS_MTLS_SERVER_KEY_PATH=
WITNESS_MTLS_GATEWAY_CLIENT_CERT_PATH=
WITNESS_MTLS_GATEWAY_CLIENT_KEY_PATH=
WITNESS_MTLS_SERVER_NAME=witness

# Database passwords. Replace before production use.
POSTGRES_AUDIT_PASSWORD=REPLACE_WITH_POSTGRES_AUDIT_PASSWORD
POSTGRES_BRIDGE_PASSWORD=REPLACE_WITH_POSTGRES_BRIDGE_PASSWORD
POSTGRES_SANDBOX_A_PASSWORD=REPLACE_WITH_POSTGRES_SANDBOX_A_PASSWORD
POSTGRES_VEIL_PASSWORD=REPLACE_WITH_POSTGRES_VEIL_PASSWORD
AUDIT_APP_PASSWORD=REPLACE_WITH_AUDIT_APP_PASSWORD
VEIL_APP_PASSWORD=REPLACE_WITH_VEIL_APP_PASSWORD

# Automated offsite compliance-DB backups — Compose path.
# Used by `lucairn backup` / `lucairn restore` (see OPS.md § Backups). Same
# pipeline as the Helm backup CronJobs: pg_dump -Fc -> age-encrypt -> upload to
# S3, then prune per LUCAIRN_BACKUP_RETENTION_DAYS.
#
# S3 credentials are NOT set here (they would land in the support bundle) —
# use the standard AWS resolution: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in
# the shell env, ~/.aws/credentials, or an instance role.
#
# Hold the age IDENTITY (private key) OUTSIDE this host; it is required to
# restore. LUCAIRN_BACKUP_AGE_IDENTITY_FILE points at it ONLY when you run
# `lucairn restore` / `lucairn backup --verify` from a secured operator host.
LUCAIRN_BACKUP_S3_BUCKET=
LUCAIRN_BACKUP_S3_ENDPOINT=
LUCAIRN_BACKUP_S3_REGION=eu-central-1
LUCAIRN_BACKUP_S3_PREFIX=
LUCAIRN_BACKUP_AGE_RECIPIENT=
LUCAIRN_BACKUP_AGE_IDENTITY_FILE=
LUCAIRN_BACKUP_RETENTION_DAYS=30
# Helm installs: set to true to assert that backup is managed by the chart
# (backup.enabled=true in values.yaml, validated fail-closed at helm-upgrade
# time by _validators.tpl) so `lucairn doctor --strict` passes without a bucket.
# Compose installs use LUCAIRN_BACKUP_S3_BUCKET instead — do NOT set this on
# a Compose install; the bucket signal is the correct gate for that path.
#LUCAIRN_BACKUP_HELM_MANAGED=true

# Runtime tuning.
SANDBOX_A_EPHEMERAL=true
QI_ENGINE_ENABLED=true
SANITIZER_CONFIG_FILE=./config/default-sanitizer.yaml
# Optional safe-terms file mounted alongside config.yaml. Defaults to the
# starter list at ./config/medical-terms.txt (DE psychiatric vocabulary).
# Customers outside DE clinical can replace with their own per-domain list.
# This is the ANY-WORD list: a span is suppressed if ANY of its words matches.
SANITIZER_SAFE_TERMS_FILE=./config/medical-terms.txt
# Strict WHOLE-SPAN-EXACT safe-terms file (v0.5.1). A Presidio/spaCy detection
# is suppressed ONLY when the ENTIRE detected span equals a listed term — so
# "Claude" alone is suppressed, but "Claude Müller" is NOT (the surname still
# redacts). Stops product vocabulary (Claude/Opus/Sonnet/Anthropic/Lucairn/
# signable/Remedy/…) from being mis-tagged as PERSON without losing recall on
# real names. Defaults to the bundled ./config/safe-terms-strict.txt; replace
# with your own per-domain strict list if needed. Mounted at
# /config/safe-terms-strict.txt and wired via default-sanitizer.yaml's
# `strict_safe_terms_file`. See config/safe-terms-strict.txt.
SANITIZER_STRICT_SAFE_TERMS_FILE=./config/safe-terms-strict.txt
# A6 strict LOCATION stop-list (v0.5.2). Drops spaCy-NER LOCATION false
# positives on common English words (West/Loop/…) that the en SpacyRecognizer
# mis-tags as LOCATION in messy ITSM/ServiceNow prose. Whole-token-exact only:
# a multi-word place ("West Berlin"), a longer token ("Westminster"), a PERSON-
# tagged "West", and any L1 identity surname all stay redacted — recall-safe.
# Defaults to the bundled ./config/safe-terms-strict-location.txt; replace with
# your own per-domain stop-list if needed. Mounted at
# /config/safe-terms-strict-location.txt and wired via default-sanitizer.yaml's
# `spacy_location_stop_terms_file`. See config/safe-terms-strict-location.txt.
SANITIZER_LOCATION_STOP_TERMS_FILE=./config/safe-terms-strict-location.txt
# L3 PII-shield (Ollama / Qwen) availability policy. "true" = fail-closed:
# the gateway returns 503 when the L3 shield is down rather than letting a
# request through unscanned. "false" = continue-mode: the request proceeds
# and the cert is honestly downgraded to PARTIAL (llm_pii_scan omitted from
# layers_active).
#
# The COMPOSE DEFAULT is deployment-aware (this env var, when LEFT UNSET,
# inherits a per-path fallback baked into the compose files):
#   * Split deployment (docker-compose.customer.yml ALONE) -> defaults to
#     "false". This path starts NO L3 service — the L3 deep PII shield is the
#     GPU Ollama/Qwen service (`ollama-identity`), Enterprise-only and absent
#     here. Requiring L3 with no shield wired makes the sanitizer /readyz fail
#     liveness and the gateway fail-close 503 on EVERY request, so the split
#     install runs L1+L2 only and does NOT require L3.
#   * Self-hosted (docker-compose.customer.yml PLUS
#     docker-compose.self-hosted.yml) -> previously defaulted to "true"
#     (FAIL-CLOSED). Per the 2026-06 decision to ship L3 OFF uniformly until
#     the model is explicitly staged, the line below pins "false" for ALL
#     install paths so that a manual `cp customer.env.example customer.env`
#     gets the same continue-mode default as `bin/lucairn-init`.
# SETTING this var here OVERRIDES the compose-path defaults.
#   * "true"  = fail-closed (only safe once a reachable L3 shield is wired —
#               the GPU Ollama service + config/default-sanitizer.yaml `llm_scan`).
#   * "false" = continue-mode (cert honestly downgraded to PARTIAL, llm_pii_scan
#               omitted from layers_active).
# `bin/lucairn doctor` warns if this resolves to "true" but no L3 service is
# wired.
# L3 deep PII shield not required for now — L1+L2 active, Veil cert
# COMPLETENESS_PARTIAL; re-enable by pre-staging the model + setting =true.
# Matches lucairn-init's default.
LUCAIRN_L3_REQUIRED=false
# Sanitize-result cache: "true" lets identical requests skip re-scrubbing via
# cache-replay (cert stays FULL, no fail-open bump). Default "false".
# (docker-compose.customer.yml:516.)
SANITIZE_CACHE_ENABLED=false

# Public gateway URL served to MCP OAuth discovery endpoints and to the
# Lucairn dashboard's certificate download links. Required when you deploy
# the gateway at a custom hostname (e.g. https://gateway.example.com) —
# if unset the gateway falls back to GATEWAY_BASE_URL, which is the outbound
# proxy URL and may differ from the MCP-OAuth-discovery-facing URL.
# Consumed by: docker-compose.customer.yml gateway env block.
LUCAIRN_RESOURCE_BASE_URL=

# Sanitizer response-cache tuning (redis-sanitizer-cache, DB 0).
# Applies when SANITIZE_CACHE_ENABLED=true. Leave commented for defaults.
# BACKEND: "redis" (default) — the compose stack wires redis-sanitizer-cache.
#SANITIZER_CACHE_BACKEND=redis
# TTL in seconds for cached sanitization results (default 3600 = 1 hour).
# Lower to reduce stale-cache risk on frequently-updated PII corpora.
#SANITIZER_CACHE_TTL_SECONDS=3600

# Streaming-request state tracking backend (redis-sanitizer-cache, DB 0).
# Used to correlate streamed chunks back to the request that opened them.
# BACKEND: "redis" (default). Only override for non-compose Redis endpoints.
#SANITIZER_STREAM_STATE_BACKEND=redis
#SANITIZER_STREAM_STATE_REDIS_URL=redis://redis-sanitizer-cache:6379/0
# TTL for in-flight streaming state entries (default 300 = 5 minutes).
# Raise if your LLM responses routinely take > 5 minutes to complete.
#SANITIZER_STREAM_STATE_TTL_SECONDS=300

# STREAMING_ENABLED, LCR_AI_SIGNING_KEY, WELLKNOWN_*, and the legacy
# evidence-integration vars are read only by upstream dual-sandbox
# images that the kit's docker-compose path does not surface today.
# Setting them here is a no-op until the compose wirings land. Leaving
# them out of the example so doctor's env-vs-compose coherence check
# stays clean.

# ─────────────────────────────────────────────────────────────────────────
# Phase 8 — Per-deployment trust-zone tuning (self-hosted Enterprise only)
# ─────────────────────────────────────────────────────────────────────────
# Override the sanitizer's per-content-type scan strictness for THIS deployment.
# Affects ALL API keys on this installation. Operator owns the risk.
#
# Format: compact JSON map of segment_type → trust_zone.
#   Valid zones:         trusted_platform (skip) | full_scan | value_only | shallow
#   Valid segment types: system_prompt | platform_metadata | user_content |
#                        assistant_content | tool_use_input | tool_result_content |
#                        code_block | thinking_block | unknown
#
# Default built-in zones (unset = these apply):
#   system_prompt, platform_metadata  → trusted_platform (skipped)
#   user_content, assistant_content,
#     thinking_block                  → full_scan
#   tool_use_input, tool_result_content → value_only
#   code_block                        → shallow
#
# Prerequisite: gateway image >= 0.5.1 (the current release).
#   `lucairn doctor` blocks setting this on an older image.
#   See INSTALL.md § "Phase 8 — Per-deployment trust-zone tuning".
#
# An invalid zone value (typo, etc.) causes the gateway to refuse to start
# with a clear error naming the bad key+value. Run `lucairn doctor` before
# `docker compose up` to catch policy errors at pre-flight time.
#
# The effective zone for each segment is recorded in the signed cert's TMS
# manifest (tms_manifest_body), so any tuning is auditable after the fact.
#
# Examples:
#   Require full scanning of system prompts (stricter than default):
#     GATEWAY_TMS_TRUST_ZONES={"system_prompt":"full_scan"}
#
#   Require full scanning of both system prompts and code blocks:
#     GATEWAY_TMS_TRUST_ZONES={"system_prompt":"full_scan","code_block":"full_scan"}
#
#   Relax tool-result scanning (WEAKER than default — operator takes the risk):
#     GATEWAY_TMS_TRUST_ZONES={"tool_result_content":"shallow"}
#
# Unset (commented out) = gateway uses all built-in defaults. Recommended for
# most deployments. Only configure when a specific regulatory or operational
# requirement justifies deviating from the Lucairn-tested defaults.
#GATEWAY_TMS_TRUST_ZONES=

# ─────────────────────────────────────────────────────────────────────────
# Phase 7 ML PII scanners — pii-ml gRPC sidecar
# ─────────────────────────────────────────────────────────────────────────
# Piiranha + GLiNER ML scanners extracted from the sanitizer monolith into a
# dedicated single-process Python gRPC sidecar. All env vars below are OPTIONAL
# with safe production defaults baked into docker-compose.customer.yml;
# uncomment + override ONLY to tune. See INSTALL.md § "Phase 7 ML PII scanners" for
# full reference and TROUBLESHOOTING.md § "pii-ml Sidecar Slow to Become
# Ready After Enabling Phase 7" for cold-cache boot debugging.
#
# Image pin lives at LUCAIRN_PII_ML_IMAGE_TAG further up (next to
# LUCAIRN_IMAGE_TAG) so customers see the per-service pin at first scan
# of the env file.
#
# --- HuggingFace model revisions (load-bearing supply-chain pins) -------
# DO NOT override unless you mirror HF weights into a private bucket AND
# verify the same 40-char SHA. The image at LUCAIRN_PII_ML_IMAGE_TAG was
# built against THESE exact revisions; a mismatch silently re-downloads
# weights at a different revision (or fails the image-side guard) on
# cold-cache boot.
#LUCAIRN_PII_ML_PIIRANHA_REVISION=255acde67a2f34cf452eb42e365b24d2957352fc
#LUCAIRN_PII_ML_GLINER_REVISION=443d26d654e0324125a96bebd8e796c14ff2efe6
#LUCAIRN_PII_ML_GLINER_FALLBACK_REVISION=40ec419335d09393f298636f471328b722c6da9e
#
# --- Per-scanner enable toggles (paired with sanitizer-side flags) ------
# These tune the pii-ml SIDECAR's per-scanner switches and only take effect
# once Phase 7 is re-enabled. Phase 7 ML is DISABLED by default as of kit
# v1.7.1 (the sidecar is profile-gated `phase7` on Compose and
# pii-ml.enabled: false on Helm), so by default neither scanner runs at all.
# After re-enabling Phase 7, set the matching sanitizer-side flag in
# ./config/default-sanitizer.yaml (piiranha.enabled / gliner.enabled) too —
# setting only one half is a documented misconfiguration the umbrella
# validator flags pre-up.
#LUCAIRN_PII_ML_PIIRANHA_ENABLED=true
#LUCAIRN_PII_ML_GLINER_ENABLED=true
#
# --- Load policy (production fail-CLOSED defaults) ----------------------
# EAGER_LOAD=true blocks boot until both models load; /readyz reflects
# ready state accurately + first scan hits a warm inference path (production
# fail-CLOSED discipline).
#LUCAIRN_PII_ML_EAGER_LOAD=true
# EXIT_ON_LOAD_FAILURE=true hard-exits (sys.exit 2/3) if a model fails to
# load so a corrupted HF cache cannot produce a silently-degraded sidecar.
#LUCAIRN_PII_ML_EXIT_ON_LOAD_FAILURE=true
# ALLOW_LAZY_NOT_READY: dev / single-shot debugging only. Lets gRPC scans
# return scan_status=inference_error PER CALL rather than blocking or
# fail-OPEN. NEVER set true in production — defeats the fail-CLOSED
# /readyz gate.
#LUCAIRN_PII_ML_ALLOW_LAZY_NOT_READY=false
#
# --- Runtime knobs (log + gRPC pool) ------------------------------------
# Default INFO matches the image's server.py default. Drop to WARNING on
# a noisy install; lift to DEBUG when debugging a cold-cache load issue.
#LUCAIRN_PII_ML_LOG_LEVEL=INFO
# gRPC worker pool size. 8 covers concurrent scan bursts at single-tenant
# pilot load. Raise only if sanitizer queue depth metrics show contention.
#LUCAIRN_PII_ML_GRPC_WORKERS=8
#
# --- Network: sanitizer-side dial target --------------------------------
# Sanitizer's pii_ml_client.py reads LUCAIRN_PII_ML_ADDR at boot and dials
# it on every Phase 7 scan. Default matches the Compose internal-DNS layout.
# Override only for split deployments where pii-ml runs at a different host.
#LUCAIRN_PII_ML_ADDR=pii-ml:50056

# Certification profile. Used only when starting compose with:
#   docker compose --profile certification ...
BUILD_AUTH_TOKEN=REPLACE_WITH_BUILD_AUTH_TOKEN
CUSTOMER_KEY_ID=REPLACE_WITH_CUSTOMER_KEY_ID
PORTAL_API_KEY=REPLACE_WITH_PORTAL_API_KEY
PROBER_URL=

# Self-hosted model runtime.
# Leave MODEL_RUNTIME_PROFILE empty for split-deployment (remote Sandbox B)
# AND for self-hosted-with-BYOK installs (sandbox-b uses its built-in
# AnthropicAdapter / OpenAI client and does not need a local model runtime).
# Set to llama-cpp, vllm, tgi, ollama, onnxruntime, triton, or custom-runtime
# only when you want a local model runtime container alongside Sandbox B.
MODEL_RUNTIME_PROFILE=
MODEL_NAME=customer-model
MODEL_FILE=customer-model-q4.gguf
MODEL_PATH=.
MODEL_CONTEXT_WINDOW=8192
MODEL_RUNTIME_URL=http://model-runtime:8000/v1
MODEL_RUNTIME_API_KEY=local-model-runtime
MODEL_RUNTIME_IMAGE=
MODEL_RUNTIME_COMMAND=
LLAMA_CPP_IMAGE=ghcr.io/ggerganov/llama.cpp:server
VLLM_IMAGE=vllm/vllm-openai:latest
TGI_IMAGE=ghcr.io/huggingface/text-generation-inference:latest
# OLLAMA_IMAGE is the self-hosted L3 PII-plane runtime (sandbox-a ollama-identity,
# docker-compose.self-hosted.yml). It MUST stay pinned to a digest recorded in
# image-manifest.yaml (pii_plane.ollama-identity) for `lucairn doctor --strict`
# to pass — an unpinned/mutable :latest is rejected fail-closed (a floating tag
# cannot be digest-verified). To bump it: pull the new ollama, record its index
# digest in image-manifest.yaml, then update both the tag and @sha256 here.
OLLAMA_IMAGE=ollama/ollama:0.6.2@sha256:74a0929e1e082a09e4fdeef8594b8f4537f661366a04080e600c90ea9f712721
ONNXRUNTIME_OPENAI_IMAGE=ghcr.io/declade/openai-compatible-onnxruntime:latest
TRITON_OPENAI_IMAGE=ghcr.io/declade/openai-compatible-triton:latest

# ─────────────────────────────────────────────────────────────────────────
# Managed-LLM mode for self-hosted Sandbox B (BYOK Anthropic / OpenAI / etc.)
# ─────────────────────────────────────────────────────────────────────────
# Uncomment + populate the block below ONLY if you load
# docker-compose.self-hosted-byok.yml on top of the customer + self-hosted
# overlays. This switches Sandbox B from "no outbound reach" to "outbound
# reach to operator-declared FQDNs". See INSTALL.md § "Self-hosted with
# managed LLM (BYOK)" for the compliance-team checklist (FQDN enforcement
# at host firewall, Cilium NetworkPolicy, or transparent forward proxy —
# the kit provides topology, the operator enforces the FQDN policy).
#
# LUCAIRN_LLM_EGRESS_ALLOWLIST is a comma-separated list of FQDNs (no
# scheme, no path) Sandbox B is permitted to reach. The overlay refuses
# to start when this is empty.
#LUCAIRN_LLM_EGRESS_ALLOWLIST=api.anthropic.com,api.openai.com
#
# Provider keys — set whichever you use. Unset providers are simply not
# wired (their adapters never register inside Sandbox B).
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#MISTRAL_API_KEY=
#GEMINI_API_KEY=
#
# Optional: point the OpenAI adapter at an Azure OpenAI / AWS Bedrock
# proxy / internal LLM gateway. Default keeps the SDK dialing api.openai.com.
#OPENAI_BASE_URL=https://api.openai.com/v1

# ─────────────────────────────────────────────────────────────────────────
# Lucairn Enterprise Dashboard (opt-in, --profile dashboard)
# ─────────────────────────────────────────────────────────────────────────
# Uncomment + populate the block below ONLY if you intend to start the
# dashboard alongside the core stack via:
#   docker compose -f docker-compose.customer.yml --env-file customer.env \
#     --profile dashboard up -d lucairn-dashboard
# This release ships the v1.0-dashboard feature-complete surface: auth
# + shell foundation, optional OIDC SSO, cert browser + inspector +
# audit-grade validator, server health + Grafana embedding, API key
# management, audit log browser, and compliance PDF export (AI Act
# Art. 10 / 12 / 14 / 15 evidence summary). See INSTALL.md § "Enable
# the Lucairn dashboard".

# Set to true to make `bin/lucairn doctor` run the dashboard pre-flight
# checks. Doctor also auto-detects when COMPOSE_PROFILES includes
# `dashboard` in this env file, so leaving this commented is safe — set it
# only when you want explicit opt-in independent of the compose profile.
#LUCAIRN_DASHBOARD_ENABLED=false

# Default 0.0.0.0:8443 inside the container; published as 127.0.0.1:8443 on
# the host (operator fronts it with their own TLS-terminating proxy).
#LUCAIRN_DASHBOARD_LISTEN_ADDR=0.0.0.0:8443

# Pin a specific dashboard image tag (defaults to the kit's bundled 0.8.2).
# Bumped independently from LUCAIRN_IMAGE_TAG — the dashboard ships on its
# own release cadence and is NOT controlled by the global image-tag knob.
#LUCAIRN_DASHBOARD_IMAGE_TAG=0.8.2

# Dashboard demo mode + per-user toggle (introduced in dashboard 0.8.1).
#
# LUCAIRN_DASHBOARD_DEMO_MODE=true swaps the real cert / audit /
# saved-filters / admin-client stores for in-memory fixtures (50 certs,
# ~300 audit events, 3 customers + keys). Every surface renders fully
# populated WITHOUT wiring postgres-bridge + postgres-audit + the
# gateway admin HTTP API. CSV export of certs + witness Verify degrade
# to friendly errors. NOT FOR PRODUCTION — leave UNSET on any install
# that talks to a real Lucairn stack.
#LUCAIRN_DASHBOARD_DEMO_MODE=true
#
# LUCAIRN_DASHBOARD_DEMO_TOGGLE_ENABLED=true exposes the per-user
# demo-data switch in the dashboard home page header. Cookie-scoped
# (lucairn_dash_demo_view, 30-day TTL, HttpOnly+Secure+Lax) — each
# signed-in user gets their own preference. Auto-enabled whenever
# LUCAIRN_DASHBOARD_DEMO_MODE=true is also set.
#LUCAIRN_DASHBOARD_DEMO_TOGGLE_ENABLED=true

# Kubernetes namespace where the dashboard is deployed (Helm path only —
# the doctor reads this when DOCTOR_INCLUDE_DASHBOARD=1 and kubectl is
# available). Defaults to `lucairn`.
#LUCAIRN_DASHBOARD_NAMESPACE=lucairn

# Bootstrap admin email. Defaults to admin@lucairn.local — override per
# customer install. Rotate via the procedure documented in OPS.md.
#LUCAIRN_DASHBOARD_BOOTSTRAP_EMAIL=admin@lucairn.local

# Bootstrap admin password. REQUIRED when the dashboard profile is active —
# the compose service fails-fast at start-up if this is empty, and the
# doctor pre-flight also enforces a ≥12-character length. Generate with
# `openssl rand -base64 24` (or any ≥12-character secret) and rotate after
# first login per OPS.md.
#LUCAIRN_DASHBOARD_BOOTSTRAP_PASSWORD=

# OPTIONAL. Reserved for a future flip to signed-cookie sessions — the
# current build uses opaque in-memory IDs and does not consume the value.
# Set it now so rotation tooling does not need to touch the env file when
# the signed-cookie path lands. Generate with `openssl rand -hex 24`.
#LUCAIRN_DASHBOARD_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# OIDC SSO (opt-in)
# ─────────────────────────────────────────────────────────────────────────
# When LUCAIRN_DASHBOARD_OIDC_ENABLED=true, the dashboard renders a
# "Sign in with SSO" button on /login alongside the local-admin form.
# Local-admin sign-in keeps working — there is no way to disable it in
# this release.
#
# Required (when enabled):
#   - LUCAIRN_DASHBOARD_OIDC_ISSUER_URL       issuer base URL (no trailing /)
#   - LUCAIRN_DASHBOARD_OIDC_CLIENT_ID        client_id registered at the IdP
#   - LUCAIRN_DASHBOARD_OIDC_CLIENT_SECRET    client_secret (rotate via IdP)
#   - LUCAIRN_DASHBOARD_OIDC_ADMIN_GROUP      group → RoleAdmin (full access)
#   - LUCAIRN_DASHBOARD_OIDC_VIEWER_GROUP     group → RoleViewer (read-only)
#   - one of:
#       LUCAIRN_DASHBOARD_OIDC_CALLBACK_URL   pin the registered callback URL
#       LUCAIRN_DASHBOARD_OIDC_PUBLIC_URL     dashboard public base; callback
#                                              derived as <public>/auth/oidc/callback
#
# Optional:
#   - LUCAIRN_DASHBOARD_OIDC_GROUPS_CLAIM    defaults to "groups"
#
# Group mapping rules (LOCKED):
#   - User in admin_group → RoleAdmin (full access).
#   - User in viewer_group → RoleViewer (read-only).
#   - User in BOTH → RoleAdmin wins.
#   - User in NEITHER → rejected with HTTP 401. Customers must explicitly
#     authorize identities at the IdP; the dashboard does NOT auto-grant
#     viewer to arbitrary directory users.

#LUCAIRN_DASHBOARD_OIDC_ENABLED=false
#LUCAIRN_DASHBOARD_OIDC_ISSUER_URL=https://idp.example.com/realms/lucairn
#LUCAIRN_DASHBOARD_OIDC_CLIENT_ID=lucairn-dashboard
#LUCAIRN_DASHBOARD_OIDC_CLIENT_SECRET=
#LUCAIRN_DASHBOARD_OIDC_ADMIN_GROUP=lucairn-admins
#LUCAIRN_DASHBOARD_OIDC_VIEWER_GROUP=lucairn-viewers
#LUCAIRN_DASHBOARD_OIDC_GROUPS_CLAIM=groups
#LUCAIRN_DASHBOARD_OIDC_PUBLIC_URL=https://dashboard.example.com
#LUCAIRN_DASHBOARD_OIDC_CALLBACK_URL=

# ─────────────────────────────────────────────────────────────────────────
# Cert browser + inspector + audit-grade validator (enabled by default)
# ─────────────────────────────────────────────────────────────────────────
# Dashboard 0.8.2 (2026-05-27) ships with the cert browser ENABLED by
# default. The compose stack pre-provisions postgres-veil (the cert log
# DB) with the veil_app role, and docker-compose.customer.yml wires
# LUCAIRN_DASHBOARD_AUDIT_DB_URL to that role automatically. The
# customer can navigate to /certs immediately after login.
#
# The veil_app role has SELECT on veil_certificates (the dashboard's
# only read path), plus INSERT + UPDATE(attestation_raw) which the
# dashboard binary never exercises. For stricter least-privilege,
# operators can pre-create a dedicated read-only role and override
# LUCAIRN_DASHBOARD_AUDIT_DB_URL below:
#
#   CREATE ROLE lucairn_dashboard_ro WITH LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE veil TO lucairn_dashboard_ro;
#   GRANT USAGE ON SCHEMA public TO lucairn_dashboard_ro;
#   GRANT SELECT ON veil_certificates TO lucairn_dashboard_ro;
#
# Override env vars:
#
#   - LUCAIRN_DASHBOARD_AUDIT_DB_URL       libpq URL. Defaults to the
#                                          veil_app role on postgres-veil.
#                                          Examples:
#                                            postgres://lucairn_dashboard_ro:...@postgres-veil:5432/veil?sslmode=require
#                                            postgresql://...
#   - LUCAIRN_DASHBOARD_WITNESS_ENDPOINT   host:port of the witness cert
#                                          gRPC service. Defaults to
#                                          veil-witness:50058 (compose
#                                          internal DNS; chart cert RPC
#                                          port).
#
# Reserved for a future mTLS slice (currently no-op):
#   - LUCAIRN_DASHBOARD_WITNESS_TLS_ENABLED   default "false"

#LUCAIRN_DASHBOARD_AUDIT_DB_URL=postgres://lucairn_dashboard_ro:CHANGE_ME@postgres-veil:5432/veil?sslmode=require
#LUCAIRN_DASHBOARD_WITNESS_ENDPOINT=veil-witness:50058
#LUCAIRN_DASHBOARD_WITNESS_TLS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────
# Server health + Grafana embedding (opt-in)
# ─────────────────────────────────────────────────────────────────────────
# Health probing is ALWAYS-ON by default — the 12 standard kit services
# get polled every 10 seconds and their per-service status renders on
# /health. Set HEALTH_SERVICES to the literal "disabled" to turn the
# poller off entirely. To probe a custom service list, set
# HEALTH_SERVICES to a comma-separated "name=url" spec (URL prefix
# http:// / https:// / tcp:// — see apps/dashboard/internal/health/
# services.go for the bundled defaults).
#
#LUCAIRN_DASHBOARD_HEALTH_SERVICES=
#LUCAIRN_DASHBOARD_HEALTH_POLL_INTERVAL_SECONDS=10
#
# Grafana embedding is OPT-IN. When LUCAIRN_DASHBOARD_GRAFANA_URL is set,
# LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET MUST also be set (>=32 chars).
# The SAME secret is consumed by the in-cluster / in-compose Grafana
# via [auth.jwt].key_file; see INSTALL.md § "Enable server health +
# Grafana embedding" for the Grafana-side setup.
#
# Panel UIDs are individually optional — leaving a UID empty surfaces
# a "panel not configured" placeholder in the side drawer without
# breaking the rest of /health.
#
#LUCAIRN_DASHBOARD_GRAFANA_URL=https://grafana.lucairn.local
#LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET=CHANGE_ME_TO_A_48_CHAR_RANDOM_HEX_STRING
#LUCAIRN_DASHBOARD_GRAFANA_PANEL_GATEWAY_THROUGHPUT_UID=
#LUCAIRN_DASHBOARD_GRAFANA_PANEL_SANITIZER_HIT_RATES_UID=
#LUCAIRN_DASHBOARD_GRAFANA_PANEL_WITNESS_VERIFY_RATE_UID=
#LUCAIRN_DASHBOARD_GRAFANA_PANEL_AUDIT_LOG_VOLUME_UID=

# ─────────────────────────────────────────────────────────────────────────
# API key management (opt-in)
# ─────────────────────────────────────────────────────────────────────────
# Set BOTH to enable the dashboard's /keys surface (mint / rotate /
# revoke / bulk-revoke lcr_live_* keys against the gateway admin
# HTTP API).
#
# URL must be reachable from the dashboard container; in the bundled
# compose stack the gateway listens on http://gateway:8080 (admin
# routes mount on the same listener as the data plane). The TOKEN
# value must match the gateway's DSA_ADMIN_KEY env var byte-for-byte.
# Treat as a secret — store in a vault, NOT in plain customer.env if
# possible.
#
# Plaintext keys minted via the dashboard appear ONCE on the post-mint
# modal; the gateway's keystore does not retain the plaintext in
# recoverable form, and the modal drops the value from the visible UI
# on close. Copy + paste into your downstream credential store before
# closing.
#
# /keys is ADMIN ONLY. Viewers reach the route via direct typing and
# see a 404 (the dashboard returns 404 rather than 403 to avoid
# disclosing the surface to non-admin sessions).
#
#LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL=http://gateway:8080
#LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN=CHANGE_ME_to_real_gateway_admin_token

# OPTIONAL — Helm-only doctor knobs. Override the K8s Secret name + key
# that `bin/lucairn doctor` checks when DOCTOR_INCLUDE_DASHBOARD=1.
# Defaults match the values the dashboard sub-chart ships
# (`charts/lucairn/charts/dashboard/values.yaml`); operators only set
# these when they renamed the Secret on the Helm side.
#
#LUCAIRN_DASHBOARD_GATEWAY_ADMIN_SECRET_NAME=lucairn-dashboard-gateway-admin
#LUCAIRN_DASHBOARD_GATEWAY_ADMIN_SECRET_KEY=admin-token

# ─────────────────────────────────────────────────────────────────────────
# Audit log browser (opt-in)
# ─────────────────────────────────────────────────────────────────────────
# Set to enable the dashboard's /audit surface (filter / paginate / save
# filters / CSV export across audit events emitted by the kit's audit
# service).
#
# IMPORTANT: this URL points at postgres-audit (the AUDIT EVENT LOG),
# NOT postgres-veil (the CERT LOG that LUCAIRN_DASHBOARD_AUDIT_DB_URL
# configures). The two are independent databases and must use separate
# connection strings. The naming asymmetry is unfortunate legacy; the
# code path treats them as wholly distinct connections.
#
# The role you connect as MUST have BOTH:
#   - SELECT on audit_events (browsing + render-time PII guard)
#   - INSERT on audit_events (the dashboard emits paired audit events
#     for admin reveal-raw + admin csv_export_with_reveal so auditors
#     can see who unmasked what; without INSERT the surface
#     fail-closes those flows with 500 and DOES NOT return raw PII).
# Default audit_app role from the kit's audit migrations matches; see
# `migrations/audit/000003_least_privilege_role.up.sql.tmpl`.
#
# Saved filters require an additional table the operator pre-creates by
# applying `apps/dashboard/migrations/000001_create_saved_filters.up.sql`
# against the same DB. Without the table, /audit still works — the
# saved-filter dropdown shows a "apply the dashboard migration" banner.
#
# By default the saved-filters table is read/written by the same
# audit_app role, expanding its grants to INSERT/SELECT/UPDATE/DELETE
# on the new `dashboard_saved_filters` table only. Operators who want
# tighter scoping can create a separate role (dashboard_app) with grants
# on dashboard_saved_filters only and set
# LUCAIRN_DASHBOARD_AUDIT_LOG_SAVED_FILTERS_DB_URL to its connection
# string. See OPS.md § "Rotating the audit log DB credentials".
#
# Format: postgres://USER:PASS@HOST:PORT/DB?sslmode=...
#
#LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL=postgres://audit_app:CHANGE_ME@postgres-audit:5432/audit?sslmode=disable
#LUCAIRN_DASHBOARD_AUDIT_LOG_SAVED_FILTERS_DB_URL=

# OPTIONAL — Helm path only. Override the K8s Secret name / key the
# doctor checks when DOCTOR_INCLUDE_DASHBOARD=1. Defaults match the
# values the dashboard sub-chart ships (`charts/lucairn/charts/dashboard/
# values.yaml`); operators only set these when they renamed the Secret
# on the Helm side. Mirrors the gateway-admin pattern further up.
#
#LUCAIRN_DASHBOARD_AUDIT_LOG_SECRET_NAME=lucairn-dashboard-audit-log
#LUCAIRN_DASHBOARD_AUDIT_LOG_SECRET_KEY=url

# ─────────────────────────────────────────────────────────────────────────
# Compliance PDF export
# ─────────────────────────────────────────────────────────────────────────
# The /compliance surface is ADMIN-ONLY and ALWAYS-ON when the dashboard
# is enabled. There is NO opt-in env var — the surface registers whether
# or not the cert DB (LUCAIRN_DASHBOARD_AUDIT_DB_URL) and the audit-log
# DB (LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL) are wired. When neither is
# wired, the aggregator returns zero-value counts and the generated PDF
# still renders cleanly with "(no rows recorded in this window)"
# placeholder tables.
#
# Both knobs below are OPTIONAL.
#
# MAX_WINDOW_DAYS bounds the date-range span any single export may scan.
# Default 365 days. Values >3650 (10 years) fail-closed at boot (likely
# operator typo). Operators wanting longer spans slice the export into
# multiple PDFs.
#
# DEFAULT_CUSTOMER_NAME pre-populates the customer-name input on the
# /compliance form. The string MUST NOT contain any banned mechanism-
# allowlist literals (the project's locked corpus of regulator program
# names + similar terms) — the dashboard's render-time guard fails-
# closed at PDF generation if a literal slips through, and
# `bin/lucairn doctor` greps for the same set pre-up.
#
#LUCAIRN_DASHBOARD_COMPLIANCE_MAX_WINDOW_DAYS=365
#LUCAIRN_DASHBOARD_COMPLIANCE_DEFAULT_CUSTOMER_NAME=Acme Corp GmbH
