# Lucairn Helm customer values.
# Copy to customer-values.yaml, replace every REPLACE_* value, then run:
#   helm upgrade --install lucairn charts/lucairn \
#     --namespace lucairn --create-namespace \
#     -f customer-values.yaml \
#     --set-file global.imagePullDockerConfigJson="$DOCKER_CONFIG/config.json"
#
# WARNING: DO NOT write the dockerconfigjson value into this file — it must
# come from the --set-file flag at install time. Embedding the registry PAT
# into customer-values.yaml would leak it into version control. See
# INSTALL.md § "Kubernetes Install" for the isolated $DOCKER_CONFIG recipe.

global:
  dsaEnv: production
  imageRegistry: ghcr.io/declade
  imageTag: "0.4.0"
  imagePullSecrets:
    - name: lucairn-registry
  # imagePullDockerConfigJson is ALWAYS passed via `--set-file ...` at
  # install time (see header). Leave it blank here.
  imagePullDockerConfigJson: ""

  # === Cluster type ===
  # Default values target a vanilla Kubernetes cluster (Kind, vanilla
  # EKS/GKE/AKS) with no Cilium and no labeled+tainted node pools.
  # If your cluster runs Cilium with WireGuard encryption + CNP
  # enforcement AND you have provisioned dsa.io/zone=identity /
  # dsa.io/zone=ai node pools, flip BOTH flags below to true:
  #   nodeIsolation: true
  #   dnsRestriction: true
  # Otherwise leave them false — flipping them on without the
  # supporting CNI policy + labeled nodes breaks pod scheduling
  # (nodeIsolation) and cross-namespace service discovery
  # (dnsRestriction). (Vast-verify finding #1.)
  nodeIsolation: false
  dnsRestriction: false

  # === Postgres SSL ===
  # Bundled postgres-* StatefulSets do NOT configure TLS. Default
  # sslmode=disable matches the Compose path. Override to "require"
  # only if you swap in an external Postgres with TLS configured.
  # (Vast-verify finding #2.)
  postgresqlSslmode: disable

  # === gRPC TLS between services ===
  # Bundled subcharts do NOT provision TLS certs for inter-service
  # gRPC. Each subchart's per-chart `grpcTlsEnabled` defaults to
  # "false"; the gateway, audit, id-bridge, sandbox-a, sandbox-b
  # values blocks below MUST stay at "false" until cert-manager (or
  # equivalent) is wired at the customer site. Audit + id-bridge
  # refuse to start on dsaEnv=production + grpcTlsEnabled="true"
  # without certs mounted. The per-subchart flag below is the
  # load-bearing one (Helm subcharts don't read global.grpcTlsEnabled).
  # (Vast-verify finding #3.)

  wireguardEncryption: false
  llmEgressEnabled: true
  ingestEgressEnabled: false
  ollamaEnabled: true
  demoEnabled: false

# v1.0 ships single-replica gateway with the file-keystore persisted on a
# PVC mounted at the parent of gateway.keystorePath
# (gateway.keystore.persistence.enabled=true by default;
# gateway.keystorePath="/etc/dsa/keystore-dir/keystore.json" by default,
# PVC mount at /etc/dsa/keystore-dir, gateway creates keystore.json inside
# it on first run — matches the Compose volume-on-parent-dir model). The
# PVC carries helm.sh/resource-policy: keep so `helm uninstall` preserves
# API keys for clean re-install. Pilot customers handling <500 req/sec are
# comfortably served by a single pod.
#
# Multi-replica gateway HA is the v2.0 opt-in path via the postgres-gateway
# subchart further down. Do NOT enable it in v1.0 — the chart fails-fast
# if you flip only one of the two paired flags. See INSTALL.md
# § "Lucairn Enterprise v1.0 deployment topology" + "v2.0 roadmap".
gateway:
  ingress:
    enabled: true
    className: nginx
    host: lucairn.customer.example
    tlsSecret: lucairn-gateway-tls
  gatewayBaseUrl: https://lucairn.customer.example
  # gRPC TLS between services. Default "false" matches the Compose
  # path; bundled subcharts do NOT provision certs. Flip to "true"
  # only after wiring cert-manager (or equivalent) at the customer
  # site. (Vast-verify finding #3.)
  grpcTlsEnabled: "false"
  streaming:
    enabled: true
    timeoutSeconds: 300
  secrets:
    values:
      licenseKey: "REPLACE_WITH_LICENSE_KEY"
      licenseSigningKey: "REPLACE_WITH_LICENSE_SIGNING_KEY"
      adminKey: "REPLACE_WITH_64_HEX_ADMIN_KEY"
      sandboxBApiKey: "REPLACE_WITH_SANDBOX_B_API_KEY"
      veilManifestSigningKey: "REPLACE_WITH_64_HEX_MANIFEST_SIGNING_KEY"
      veilWitnessPublicKey: "REPLACE_WITH_64_HEX_WITNESS_PUBLIC_KEY"
      veilBridgePublicKey: "REPLACE_WITH_64_HEX_BRIDGE_PUBLIC_KEY"
      veilSanitizerPublicKey: "REPLACE_WITH_64_HEX_SANITIZER_PUBLIC_KEY"
      veilSandboxBPublicKey: "REPLACE_WITH_64_HEX_SANDBOX_B_PUBLIC_KEY"
      veilAuditPublicKey: "REPLACE_WITH_64_HEX_AUDIT_PUBLIC_KEY"
      veilAISigningKey: ""
      # === Inter-service auth token ===
      # ALL FOUR `dsaServiceToken` placeholders below (gateway, audit,
      # id-bridge, sandbox-a) MUST be the SAME string — they are the
      # shared bearer token services use to authenticate to each
      # other. Generate ONCE with `openssl rand -hex 32` and paste
      # the same value into every dsaServiceToken occurrence in this
      # file. Different values silently break inter-service calls
      # at runtime. A future v1.0.1 refactor will lift this to a
      # single global.dsaServiceToken. (Vast-verify finding #5.)
      dsaServiceToken: "REPLACE_WITH_64_HEX_SERVICE_TOKEN"
      gatewayKeystoreKey: "REPLACE_WITH_BASE64_32_BYTES"

# postgres-gateway is the v2.0 path for multi-replica gateway HA. v1.0
# ships single-replica with the file-keystore on PVC (block above). Leave
# both flags below at false until v2.0. Enabling either without the other
# or with gateway.replicaCount > 1 produces undefined behavior — the
# umbrella validator fails-fast on the mixed case. See INSTALL.md
# § "v2.0 roadmap".
#
# When v2.0 ships, the opt-in recipe will be:
#   postgres-gateway:
#     enabled: true
#     postgresql:
#       storageSize: 5Gi
#     secrets:
#       values:
#         postgresPassword: "REPLACE_WITH_POSTGRES_GATEWAY_PASSWORD"
#   gateway:
#     replicaCount: 2     # or higher
#     keystorePath: ""    # clear so GATEWAY_KEYSTORE_PATH is NOT emitted
#     keystore:
#       persistence:
#         enabled: false  # v2.0 uses Postgres-backed keystore, not PVC
#     postgresKeystore:
#       enabled: true
#     hpa:
#       enabled: true     # safe under Postgres-backed keystore
postgres-gateway:
  enabled: false
# NOTE: gateway.postgresKeystore.enabled: false is the chart default (see
# charts/lucairn/charts/gateway/values.yaml). Do NOT add a second top-level
# `gateway:` block here — YAML would silently drop the earlier `gateway:`
# entry (with the ingress + secrets values) in favor of the later one.
# The umbrella validator enforces that both flags toggle together.

audit:
  postgresql:
    storageSize: 50Gi
  secrets:
    values:
      postgresPassword: "REPLACE_WITH_AUDIT_POSTGRES_PASSWORD"
      # audit_app role password — baked into 000003 migration by the render
      # init container. Must not contain ' or \ (rendered into SQL string).
      auditAppPassword: "REPLACE_WITH_AUDIT_APP_PASSWORD"
      veilSigningKey: "REPLACE_WITH_64_HEX_AUDIT_SIGNING_KEY"
      # MUST match gateway.secrets.values.dsaServiceToken above (Vast finding #5).
      dsaServiceToken: "REPLACE_WITH_64_HEX_SERVICE_TOKEN"

id-bridge:
  postgresql:
    storageSize: 50Gi
  secrets:
    values:
      postgresPassword: "REPLACE_WITH_BRIDGE_POSTGRES_PASSWORD"
      masterKey: "REPLACE_WITH_64_HEX_BRIDGE_MASTER_KEY"
      veilSigningKey: "REPLACE_WITH_64_HEX_BRIDGE_SIGNING_KEY"
      bridgeEncryptionKey: "REPLACE_WITH_64_HEX_BRIDGE_ENCRYPTION_KEY"
      # MUST match gateway.secrets.values.dsaServiceToken above (Vast finding #5).
      dsaServiceToken: "REPLACE_WITH_64_HEX_SERVICE_TOKEN"

sandbox-a:
  postgresql:
    storageSize: 50Gi
  sanitizer:
    llmScanEnabled: false
  secrets:
    values:
      postgresPassword: "REPLACE_WITH_SANDBOX_A_POSTGRES_PASSWORD"
      encryptionKey: "REPLACE_WITH_64_HEX_SANDBOX_A_ENCRYPTION_KEY"
      adminKey: "REPLACE_WITH_64_HEX_ADMIN_KEY"
      veilSigningKey: "REPLACE_WITH_64_HEX_SANITIZER_OR_SANDBOX_A_SIGNING_KEY"
      # MUST match gateway.secrets.values.dsaServiceToken above (Vast finding #5).
      dsaServiceToken: "REPLACE_WITH_64_HEX_SERVICE_TOKEN"
      # Sanitizer sidecar canary-token signing key (≥32 chars). Without it,
      # canary-token leak detection silently disables. Compose-path parity:
      # CANARY_HMAC_KEY :? enforced in docker-compose.customer.yml.
      canaryHmacKey: "REPLACE_WITH_CANARY_HMAC_KEY"

sandbox-b:
  llm:
    provider: anthropic
  redis:
    password: "REPLACE_WITH_REDIS_PASSWORD"
  secrets:
    values:
      anthropicApiKey: ""
      openaiApiKey: ""
      mistralApiKey: ""
      geminiApiKey: ""
      veilSigningKey: "REPLACE_WITH_64_HEX_SANDBOX_B_SIGNING_KEY"
      sandboxBApiKeys: "REPLACE_WITH_SANDBOX_B_API_KEYS"
      adminKey: "REPLACE_WITH_64_HEX_ADMIN_KEY"
      dsaManagedAiKey: ""

veil-witness:
  postgresql:
    storageSize: 50Gi
  # The veil-witness pod consumes the 4 ed25519 public keys below as
  # VEIL_BRIDGE_PUBLIC_KEY / VEIL_SANITIZER_PUBLIC_KEY /
  # VEIL_SANDBOX_B_PUBLIC_KEY / VEIL_AUDIT_PUBLIC_KEY environment
  # variables (see charts/lucairn/charts/veil-witness/templates/configmap.yaml).
  # Missing values crash the pod on boot. These are the SAME ed25519
  # public keys as gateway.secrets.values.{veilBridgePublicKey,
  # veilSanitizerPublicKey, veilSandboxBPublicKey, veilAuditPublicKey}
  # above — copy each REPLACE_WITH_* placeholder verbatim into both
  # places. (Vast-verify finding #4.)
  config:
    # MUST match gateway.secrets.values.veilBridgePublicKey above.
    bridgePublicKey: "REPLACE_WITH_64_HEX_BRIDGE_PUBLIC_KEY"
    # MUST match gateway.secrets.values.veilSanitizerPublicKey above.
    sanitizerPublicKey: "REPLACE_WITH_64_HEX_SANITIZER_PUBLIC_KEY"
    # MUST match gateway.secrets.values.veilSandboxBPublicKey above.
    sandboxBPublicKey: "REPLACE_WITH_64_HEX_SANDBOX_B_PUBLIC_KEY"
    # MUST match gateway.secrets.values.veilAuditPublicKey above.
    auditPublicKey: "REPLACE_WITH_64_HEX_AUDIT_PUBLIC_KEY"
    insecureDevMode: "false"
  secrets:
    values:
      postgresPassword: "REPLACE_WITH_VEIL_POSTGRES_PASSWORD"
      # veil_app role password — baked into 000002 migration by the render
      # init container. Must not contain ' or \ (rendered into SQL string).
      veilAppPassword: "REPLACE_WITH_VEIL_APP_PASSWORD"
      signingKey: "REPLACE_WITH_64_HEX_WITNESS_SIGNING_KEY"
      keyId: "witness_v1"

observability:
  enabled: true

demo:
  enabled: false

ingest:
  enabled: false

certification:
  enabled: false

dsa-certification:
  signing:
    local:
      keyId: "REPLACE_WITH_CUSTOMER_KEY_ID_WHEN_CERTIFICATION_ENABLED"
      keyFile: /keys/customer-key.pem


# Lucairn Enterprise Dashboard. OFF by default. When dashboard.enabled
# flips to true, the binary boots with cert pages rendering "not
# configured" unless auditDB.connectionStringRef.name is also set. See
# INSTALL.md § "Enable the Lucairn dashboard" + "Audit DB + Witness
# wiring (cert browser + inspector)".
dashboard:
  enabled: false
  # Slice 3 cert surface (opt-in). Leave connectionStringRef.name empty
  # to ship the dashboard without the cert browser; the cert pages
  # render a friendly "not configured" explainer in that mode.
  # auditDB:
  #   connectionStringRef:
  #     name: lucairn-dashboard-audit-db
  #     key: connection-string
  # witness:
  #   endpoint: "witness.lucairn.svc.cluster.local:50051"

  # Slice 4 — server health overview + Grafana embedding plumbing.
  # /health probing is ALWAYS-ON at the binary level (cards render
  # status pills for the 12 standard kit services every 10s). To
  # add embedded Grafana panels, set grafana.endpoint + the panel
  # UIDs, then flip observability.grafana.auth.jwt.enabled to true
  # so the in-cluster Grafana accepts the dashboard's HS256 JWT.
  # See INSTALL.md § "Enable server health + Grafana embedding".
  #
  # grafana:
  #   endpoint: "https://grafana.lucairn.local"
  #   panels:
  #     gatewayThroughputUID: ""
  #     sanitizerHitRatesUID: ""
  #     witnessVerifyRateUID: ""
  #     auditLogVolumeUID: ""

  # Dashboard 0.8.0 — demo mode + per-user demo-data toggle on the
  # operator-overview home page. Both default OFF. Leaves the dashboard
  # behaving identically to 0.7.x when this block is commented out
  # entirely (the Helm template guards on `(default dict .Values.demoMode)`
  # so missing keys are nil-safe).
  #
  # demoMode.enabled=true swaps real stores for in-memory fixtures at
  # boot time — every surface renders populated. NOT FOR PRODUCTION;
  # see INSTALL.md § "Enable demo mode + the per-user demo-data toggle".
  #
  # demoMode.toggleEnabled=true exposes the per-user `Live ◯○ Demo`
  # switch in the dashboard home-page header. Cookie-scoped
  # (lucairn_dash_demo_view, 30-day TTL, HttpOnly+Secure+Lax). Auto-
  # enabled whenever demoMode.enabled=true.
  # demoMode:
  #   enabled: false
  #   toggleEnabled: false

# Observability sub-chart — Slice 4 fold-in. Set jwt.enabled=true to
# wire Grafana into the dashboard's embed handoff. The Secret name
# below must match the dashboard's auto-generated Secret (default
# "lucairn-dashboard-grafana-jwt") OR the operator-pre-created Secret.
# observability:
#   grafana:
#     auth:
#       jwt:
#         enabled: false
#         secretRef:
#           name: lucairn-dashboard-grafana-jwt
#           key: shared-secret
