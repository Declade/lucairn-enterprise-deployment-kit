#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || printf 'unknown')"

usage() {
  cat <<'USAGE'
Usage:
  lucairn doctor --env customer.env --compose docker-compose.customer.yml [--offline] [--check-images] [--skip-image-check]
  lucairn support-bundle --env customer.env --compose docker-compose.customer.yml [--output bundles] [--offline]
  lucairn bundle create --customer-slug acme --models-dir ./models --model-manifest model-manifest.yaml --env customer.env --image-tar images.tar [--customer-data-dir ./customer-data]
  lucairn bundle prepare --customer-slug acme --staging-dir /secure/staging/acme [--output dist/customer-bundles]
  lucairn bundle verify --bundle dist/customer-bundles/lucairn-customer-bundle-acme-YYYYMMDDTHHMMSSZ.tar.gz

Commands:
  doctor          Validate customer deployment prerequisites.
  support-bundle  Generate a redacted support archive for customer review.
  bundle          Create, prepare, or verify per-customer delivery bundles.
USAGE
}

fail() {
  echo "error: $*" >&2
  exit 1
}

warn() {
  echo "warn: $*" >&2
}

info() {
  echo "$*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

dir_has_payload_files() {
  local dir="$1"
  [ -d "$dir" ] || return 1
  find "$dir" -mindepth 1 -type f ! -iname 'README' ! -iname 'README.*' | grep -q .
}

compose_cmd() {
  if docker compose version >/dev/null 2>&1; then
    echo "docker compose"
  elif have docker-compose; then
    echo "docker-compose"
  else
    echo ""
  fi
}

env_value() {
  local file="$1" key="$2" line
  line="$(grep -E "^${key}=" "$file" 2>/dev/null | tail -1 || true)"
  if [ -z "$line" ]; then
    printf ''
  else
    printf '%s' "${line#*=}" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
  fi
}

is_secret_key() {
  local key="$1"
  case "$key" in
    *KEY*|*TOKEN*|*SECRET*|*PASSWORD*|*PRIVATE*|*SIGNING*|*CERT*|*CREDENTIAL*|*API_KEY*|*LICENSE*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

redact_stream() {
  awk -F= '
    function trim(s) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      return s
    }
    function secret_key(k) {
      return k ~ /(KEY|TOKEN|SECRET|PASSWORD|PRIVATE|SIGNING|CERT|CREDENTIAL|API_KEY|LICENSE)/
    }
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { print; next }
    index($0, "=") > 0 {
      k = trim($1)
      if (secret_key(k)) {
        print k "=<redacted>"
      } else {
        print
      }
      next
    }
    {
      line = $0
      if (line ~ /(KEY|TOKEN|SECRET|PASSWORD|PRIVATE|SIGNING|CERT|CREDENTIAL|API_KEY|LICENSE):/) {
        sub(/:.*/, ": <redacted>", line)
      }
      gsub(/(sk-[A-Za-z0-9._-]+)/, "<redacted>", line)
      gsub(/(lcr_[A-Za-z0-9._-]+)/, "<redacted>", line)
      print line
    }
  '
}

require_file() {
  local file="$1" label="$2"
  [ -f "$file" ] || fail "$label not found: $file"
}

require_env_values() {
  local env_file="$1" missing=0 key val
  local required=(
    DSA_ENV
    DSA_LICENSE_KEY
    DSA_LICENSE_SIGNING_KEY
    DSA_SERVICE_TOKEN
    DSA_BRIDGE_ENCRYPTION_KEY
    SANDBOX_A_ENCRYPTION_KEY
    BRIDGE_MASTER_KEY
    DSA_ADMIN_KEY
    GATEWAY_KEYSTORE_KEY
    GATEWAY_BASE_URL
    VEIL_AUDIT_SIGNING_KEY
    VEIL_BRIDGE_SIGNING_KEY
    VEIL_SANITIZER_SIGNING_KEY
    VEIL_WITNESS_SIGNING_KEY
    VEIL_GATEWAY_SIGNING_KEY
    VEIL_MANIFEST_SIGNING_KEY
    VEIL_WITNESS_PUBLIC_KEY
    VEIL_BRIDGE_PUBLIC_KEY
    VEIL_SANITIZER_PUBLIC_KEY
    VEIL_AUDIT_PUBLIC_KEY
    VEIL_SANDBOX_B_PUBLIC_KEY
  )

  for key in "${required[@]}"; do
    val="$(env_value "$env_file" "$key")"
    if [ -z "$val" ]; then
      echo "required secrets: missing $key"
      missing=1
    fi
  done

  [ "$missing" -eq 0 ]
}

validate_hex64() {
  local env_file="$1" key="$2" val
  val="$(env_value "$env_file" "$key")"
  [ -z "$val" ] && return 0
  if ! printf '%s' "$val" | grep -Eq '^[0-9a-fA-F]{64}$'; then
    echo "secret format: $key must be 64 hex chars"
    return 1
  fi
}

validate_keystore_key() {
  local env_file="$1" val
  val="$(env_value "$env_file" GATEWAY_KEYSTORE_KEY)"
  [ -z "$val" ] && return 0
  if ! printf '%s' "$val" | openssl enc -A -d -base64 >/tmp/lucairn-keystore-key.$$ 2>/dev/null; then
    rm -f /tmp/lucairn-keystore-key.$$
    echo "secret format: GATEWAY_KEYSTORE_KEY must be base64"
    return 1
  fi
  local bytes
  bytes="$(wc -c < /tmp/lucairn-keystore-key.$$ | tr -d ' ')"
  rm -f /tmp/lucairn-keystore-key.$$
  if [ "$bytes" != "32" ]; then
    echo "secret format: GATEWAY_KEYSTORE_KEY must decode to 32 bytes"
    return 1
  fi
}

url_host() {
  python3 - "$1" <<'PY' 2>/dev/null || true
import sys
from urllib.parse import urlparse
u = urlparse(sys.argv[1])
print(u.hostname or "")
PY
}

url_port() {
  python3 - "$1" <<'PY' 2>/dev/null || true
import sys
from urllib.parse import urlparse
u = urlparse(sys.argv[1])
if u.port:
    print(u.port)
elif u.scheme == "https":
    print(443)
elif u.scheme == "http":
    print(80)
else:
    print("")
PY
}

check_dns() {
  local host="$1"
  [ -z "$host" ] && return 0
  python3 - "$host" <<'PY' >/dev/null
import socket, sys
socket.getaddrinfo(sys.argv[1], None)
PY
}

check_local_port_available() {
  local port="$1"
  [ -z "$port" ] && return 0
  if have lsof && lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
    return 1
  fi
  return 0
}

check_certs() {
  local env_file="$1" checked=0 failed=0 key path
  local cert_keys=(SANDBOX_B_CLIENT_CERT SANDBOX_B_CA_CERT GRPC_TLS_CERT_FILE WITNESS_MTLS_CA_BUNDLE_PATH WITNESS_MTLS_GATEWAY_CLIENT_CERT_PATH)
  for key in "${cert_keys[@]}"; do
    path="$(env_value "$env_file" "$key")"
    [ -z "$path" ] && continue
    checked=1
    if [ ! -f "$path" ]; then
      echo "certs: missing $key at $path"
      failed=1
      continue
    fi
    if ! openssl x509 -checkend 2592000 -noout -in "$path" >/dev/null 2>&1; then
      echo "certs: $key expires within 30 days or is invalid"
      failed=1
    fi
  done
  if [ "$failed" -eq 0 ]; then
    if [ "$checked" -eq 1 ]; then
      echo "certs: ok"
    else
      echo "certs: no external cert paths configured"
    fi
  fi
  [ "$failed" -eq 0 ]
}

check_container_images() {
  local env_file="$1" failed=0 registry tag image
  registry="$(env_value "$env_file" LUCAIRN_IMAGE_REGISTRY)"
  tag="$(env_value "$env_file" LUCAIRN_IMAGE_TAG)"
  registry="${registry:-ghcr.io/declade}"
  tag="${tag:-1.0.0}"

  if ! have docker; then
    echo "container images: skipped (docker unavailable)"
    return 0
  fi

  for image in dsa-audit dsa-id-bridge dsa-sandbox-a dsa-sanitizer dsa-veil-witness dsa-gateway; do
    local ref="${registry}/${image}:${tag}"
    if ! docker manifest inspect "$ref" >/dev/null 2>&1; then
      echo "container images: failed ($ref not pullable; check registry credentials or image tag)"
      failed=1
    fi
  done

  if [ "$failed" -eq 0 ]; then
    echo "container images: ok"
  fi
  [ "$failed" -eq 0 ]
}

sha256_file() {
  local file="$1"
  if have sha256sum; then
    sha256sum "$file" | awk '{print $1}'
  else
    shasum -a 256 "$file" | awk '{print $1}'
  fi
}

manifest_value() {
  local manifest="$1" key="$2"
  awk -v key="$key" '
    /^[[:space:]]*model:[[:space:]]*$/ { in_model=1; next }
    in_model && /^[^[:space:]]/ { in_model=0 }
    in_model {
      pattern = "^[[:space:]]*" key ":[[:space:]]*"
      if ($0 ~ pattern) {
        sub(pattern, "")
        gsub(/^["'\''"]|["'\''"]$/, "")
        print
        exit
      }
    }
  ' "$manifest"
}

manifest_files_entries() {
  # Emits "path<TAB>sha256" lines, one per declared file.
  # Supports BOTH shapes:
  #   1) Legacy:  files: [ "foo.gguf", "bar.gguf" ]  (block form: "- foo.gguf")
  #      -> "foo.gguf\t"        (empty second column)
  #   2) New:     files:
  #                 - path: foo.gguf
  #                   sha256: <64-hex>
  #      -> "foo.gguf\tabc..."
  #
  # B4 hardening: the new-shape parser is keyed off the field NAME, not on
  # positional ordering. Authors may interleave sibling keys (size:, source:,
  # license:, notes:) between path: and sha256: — the parser ignores those
  # rather than dropping sha256 silently.
  local manifest="$1"
  awk -v OFS='\t' '
    function trim(s) { gsub(/^[[:space:]]+|[[:space:]]+$/, "", s); gsub(/^["'\''"]|["'\''"]$/, "", s); return s }
    function flush_cur() {
      if (cur_path != "") { print cur_path, cur_sha }
      cur_path=""; cur_sha=""
    }
    /^[[:space:]]*model:[[:space:]]*$/ { in_model=1; next }
    in_model && /^[^[:space:]]/ { in_model=0 }
    in_model && /^[[:space:]]*files:[[:space:]]*$/ {
      in_files=1
      # Capture the indentation depth of the "files:" key so we can detect a
      # sibling key (same or shallower indent that is NOT a list item) as the
      # end of the files block.
      match($0, /^[[:space:]]*/)
      files_indent = RLENGTH
      next
    }
    in_files {
      # End of files list: a sibling key at <= files_indent that is not a list
      # marker and not a deeper continuation. We compute the indent of $0 and
      # compare; deeper-indented continuation lines (size:, source:, etc.) stay
      # inside the current entry and are ignored by the allowlist below.
      match($0, /^[[:space:]]*/)
      cur_indent = RLENGTH
      if (cur_indent <= files_indent && $0 ~ /^[[:space:]]*[A-Za-z0-9_-]+:[[:space:]]*/ && $0 !~ /^[[:space:]]*-[[:space:]]/) {
        flush_cur()
        exit
      }
      # New shape: list item starting with "- path: <value>"
      if ($0 ~ /^[[:space:]]*-[[:space:]]+path:[[:space:]]*/) {
        flush_cur()
        line=$0
        sub(/^[[:space:]]*-[[:space:]]+path:[[:space:]]*/, "", line)
        cur_path=trim(line); cur_sha=""
        next
      }
      # New shape: any deeper-indented continuation line for the current entry.
      # We key off the field name ("sha256:"), so size:, source:, license:,
      # notes: are tolerated in any order between path: and sha256: without
      # dropping the sha256.
      if (cur_path != "" && $0 ~ /^[[:space:]]+sha256:[[:space:]]*/) {
        line=$0
        sub(/^[[:space:]]+sha256:[[:space:]]*/, "", line)
        cur_sha=trim(line)
        next
      }
      # Other allowlisted sibling keys inside an entry — explicitly ignored so
      # interleaving them between path: and sha256: cannot drop the sha256.
      if (cur_path != "" && $0 ~ /^[[:space:]]+(size|source|license|notes):[[:space:]]*/) {
        next
      }
      # Legacy shape: bare scalar item "- foo.gguf" (NOT a key:value pair)
      if ($0 ~ /^[[:space:]]*-[[:space:]]+[^[:space:]]/ && $0 !~ /^[[:space:]]*-[[:space:]]+[A-Za-z0-9_-]+:[[:space:]]/) {
        flush_cur()
        line=$0
        sub(/^[[:space:]]*-[[:space:]]+/, "", line)
        cur_path=trim(line); cur_sha=""
        next
      }
    }
    END { flush_cur() }
  ' "$manifest"
}

manifest_checksum_policy() {
  local manifest="$1" val
  val="$(manifest_value "$manifest" checksum_policy)"
  if [ -z "$val" ]; then
    printf 'sha256-required'
  else
    printf '%s' "$val"
  fi
}

validate_model_manifest() {
  # Args:
  #   $1 manifest path
  #   $2 models dir
  #   $3 (optional) "require-sha256" — when set, force checksum_policy to
  #      "sha256-required" regardless of what the manifest declares. Used by
  #      `bundle verify --require-sha256` (B2) to defend against a manifest
  #      that has been tampered to declare a weaker policy.
  local manifest="$1" models_dir="$2" force_mode="${3:-}"
  local name format runtime policy file sha actual missing=0
  require_file "$manifest" "model manifest"
  [ -d "$models_dir" ] || fail "models dir not found: $models_dir"

  name="$(manifest_value "$manifest" name)"
  format="$(manifest_value "$manifest" format)"
  runtime="$(manifest_value "$manifest" runtime)"
  policy="$(manifest_checksum_policy "$manifest")"

  [ -n "$name" ] || { echo "model manifest: missing model.name"; return 1; }
  [ -n "$format" ] || { echo "model manifest: missing model.format"; return 1; }
  [ -n "$runtime" ] || { echo "model manifest: missing model.runtime"; return 1; }

  case "$format" in
    gguf|safetensors|pytorch|onnx|tensorrt-llm|ollama|openai-compatible|custom) ;;
    *) echo "model manifest: unsupported format '$format'"; return 1 ;;
  esac

  case "$runtime" in
    llama-cpp|vllm|tgi|ollama|onnxruntime|triton|external-openai-compatible|custom) ;;
    *) echo "model manifest: unsupported runtime '$runtime'"; return 1 ;;
  esac

  case "$policy" in
    sha256-required|sha256-optional|none|external-runtime-no-model-file) ;;
    *) echo "model manifest: unsupported checksum_policy '$policy' (allowed: sha256-required, sha256-optional, none, external-runtime-no-model-file)"; return 1 ;;
  esac

  # B1: `external-runtime-no-model-file` is meaningful ONLY when the runtime
  # also delegates to an external endpoint. Without this guard, a tampered
  # manifest could pair `runtime: llama-cpp` with this policy and skip the
  # re-hash entirely (the loop terminal `;;` does nothing).
  if [ "$policy" = "external-runtime-no-model-file" ]; then
    case "$runtime" in
      external-openai-compatible) ;;
      *)
        echo "model manifest: checksum_policy=external-runtime-no-model-file requires runtime=external-openai-compatible (got '$runtime')"
        return 1
        ;;
    esac
  fi

  # B2: receiver-side override. If the caller demands strong verification, we
  # ignore a weaker declared policy. This DOES NOT relax existing rules — a
  # manifest declaring sha256-required already enforces sha256-required.
  if [ "$force_mode" = "require-sha256" ]; then
    policy="sha256-required"
  fi

  if [ "$runtime" = "external-openai-compatible" ] || [ "$format" = "openai-compatible" ]; then
    return 0
  fi

  if ! manifest_files_entries "$manifest" | grep -q .; then
    echo "model manifest: model.files is required for local runtimes"
    return 1
  fi

  while IFS=$'\t' read -r file sha; do
    [ -z "$file" ] && continue
    if [ ! -f "$models_dir/$file" ]; then
      echo "model manifest: missing model file $file"
      missing=1
      continue
    fi
    case "$policy" in
      sha256-required)
        if [ -z "$sha" ]; then
          echo "model manifest: checksum_policy=sha256-required but no sha256 declared for $file"
          missing=1
          continue
        fi
        if ! printf '%s' "$sha" | grep -Eq '^[0-9a-fA-F]{64}$'; then
          echo "model manifest: invalid sha256 for $file (must be 64 hex chars)"
          missing=1
          continue
        fi
        actual="$(sha256_file "$models_dir/$file")"
        if [ "$actual" != "$sha" ]; then
          echo "model manifest: sha256 mismatch for $file"
          echo "  declared: $sha"
          echo "  actual:   $actual"
          missing=1
        fi
        ;;
      sha256-optional)
        if [ -n "$sha" ]; then
          if ! printf '%s' "$sha" | grep -Eq '^[0-9a-fA-F]{64}$'; then
            echo "model manifest: invalid sha256 for $file (must be 64 hex chars)"
            missing=1
            continue
          fi
          actual="$(sha256_file "$models_dir/$file")"
          if [ "$actual" != "$sha" ]; then
            echo "model manifest: sha256 mismatch for $file"
            echo "  declared: $sha"
            echo "  actual:   $actual"
            missing=1
          fi
        fi
        ;;
      none|external-runtime-no-model-file)
        ;;
    esac
  done < <(manifest_files_entries "$manifest")

  [ "$missing" -eq 0 ]
}

write_bundle_install_note() {
  local file="$1" slug="$2"
  cat > "$file" <<EOF
# Lucairn Customer Install: $slug

This bundle is prepared for one customer environment. Do not reuse it across customers.

## Offline Install

\`\`\`bash
docker load -i images/lucairn-images.tar
bin/lucairn bundle verify --bundle .
bin/lucairn doctor --env install/customer.env --compose install/docker-compose.customer.yml --skip-image-check
docker compose \\
  -f install/docker-compose.customer.yml \\
  -f install/docker-compose.self-hosted.yml \\
  --env-file install/customer.env \\
  --profile "\${MODEL_RUNTIME_PROFILE:-custom-runtime}" \\
  up -d
\`\`\`

## Model Runtime

The selected runtime is declared in \`models/model-manifest.yaml\`. Supported profiles are:

- \`llama-cpp\` for GGUF.
- \`vllm\` for Hugging Face safetensors / PyTorch model directories.
- \`tgi\` for Hugging Face Text Generation Inference.
- \`ollama\` for Ollama model stores or Modelfile-based packaging.
- \`onnxruntime\` for ONNX-serving containers.
- \`triton\` for TensorRT-LLM / Triton deployments.
- \`custom-runtime\` for any runtime image that exposes an OpenAI-compatible HTTP API inside the compose network.

## Support

If install fails, run:

\`\`\`bash
bin/lucairn support-bundle --env install/customer.env --compose install/docker-compose.customer.yml
\`\`\`

Review the generated archive before sending it to Lucairn support.
EOF
}

write_checksums() {
  local dir="$1"
  mkdir -p "$dir/checksums"
  : > "$dir/checksums/SHA256SUMS"
  (
    cd "$dir"
    find . -type f ! -path './checksums/SHA256SUMS' | sort | while IFS= read -r file; do
      printf '%s  %s\n' "$(sha256_file "$file")" "${file#./}"
    done > checksums/SHA256SUMS
  )
}

verify_checksums() {
  local dir="$1" sums expected path actual failed=0
  sums="$dir/checksums/SHA256SUMS"
  require_file "$sums" "checksum file"
  while read -r expected path; do
    [ -z "${expected:-}" ] && continue
    if [ ! -f "$dir/$path" ]; then
      echo "checksum verification failed: missing $path"
      failed=1
      continue
    fi
    actual="$(sha256_file "$dir/$path")"
    if [ "$actual" != "$expected" ]; then
      echo "checksum verification failed: $path"
      failed=1
    fi
  done < "$sums"
  [ "$failed" -eq 0 ]
}

bundle_create() {
  local slug="" models_dir="" manifest="" env_file="" output_dir="$ROOT/dist/customer-bundles"
  local image_tar="" images_dir="" data_dir="" base_compose="$ROOT/docker-compose.customer.yml" self_compose="$ROOT/docker-compose.self-hosted.yml"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --customer-slug) slug="$2"; shift 2 ;;
      --models-dir) models_dir="$2"; shift 2 ;;
      --model-manifest) manifest="$2"; shift 2 ;;
      --env) env_file="$2"; shift 2 ;;
      --output) output_dir="$2"; shift 2 ;;
      --image-tar) image_tar="$2"; shift 2 ;;
      --images-dir) images_dir="$2"; shift 2 ;;
      --customer-data-dir|--demo-data-dir|--data-dir) data_dir="$2"; shift 2 ;;
      --base-compose) base_compose="$2"; shift 2 ;;
      --self-hosted-compose|--compose) self_compose="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown bundle create argument: $1" ;;
    esac
  done

  [ -n "$slug" ] || fail "--customer-slug is required"
  printf '%s' "$slug" | grep -Eq '^[a-z0-9][a-z0-9-]{1,62}$' || fail "--customer-slug must be lowercase letters, numbers, and hyphens"
  [ -n "$models_dir" ] || fail "--models-dir is required"
  [ -n "$manifest" ] || fail "--model-manifest is required"
  [ -n "$env_file" ] || fail "--env is required"
  validate_model_manifest "$manifest" "$models_dir"
  require_file "$env_file" "env file"
  require_file "$base_compose" "base compose"
  require_file "$self_compose" "self-hosted compose"
  [ -z "$image_tar" ] || require_file "$image_tar" "image tar"
  [ -z "$images_dir" ] || [ -d "$images_dir" ] || fail "images dir not found: $images_dir"
  [ -z "$data_dir" ] || [ -d "$data_dir" ] || fail "customer data dir not found: $data_dir"

  local ts bundle_name staging archive
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  bundle_name="lucairn-customer-bundle-${slug}-${ts}"
  mkdir -p "$output_dir"
  staging="$output_dir/$bundle_name"
  archive="$output_dir/$bundle_name.tar.gz"
  rm -rf "$staging" "$archive"
  mkdir -p "$staging"/{bin,install,models,images,customer-data,checksums,docs,config,migrations,starter-templates}

  cp "$ROOT/bin/lucairn" "$staging/bin/lucairn"
  cp "$base_compose" "$staging/install/docker-compose.customer.yml"
  cp "$self_compose" "$staging/install/docker-compose.self-hosted.yml"
  cp "$env_file" "$staging/install/customer.env"
  cp "$manifest" "$staging/models/model-manifest.yaml"
  cp -R "$models_dir"/. "$staging/models/"
  cp "$manifest" "$staging/models/model-manifest.yaml"
  cp -R "$ROOT/config"/. "$staging/config/"
  cp -R "$ROOT/migrations"/. "$staging/migrations/"
  cp -R "$ROOT/starter-templates"/. "$staging/starter-templates/"
  cp "$ROOT/OPS.md" "$ROOT/TROUBLESHOOTING.md" "$ROOT/README.md" "$staging/docs/"
  [ -f "$ROOT/docs/CUSTOMER_BUNDLE.md" ] && cp "$ROOT/docs/CUSTOMER_BUNDLE.md" "$staging/docs/"
  write_bundle_install_note "$staging/INSTALL-CUSTOMER.md" "$slug"

  if [ -n "$image_tar" ]; then
    cp "$image_tar" "$staging/images/lucairn-images.tar"
  elif [ -n "$images_dir" ]; then
    cp -R "$images_dir"/. "$staging/images/"
  else
    echo "No image archive included. Customer install must use registry access." > "$staging/images/README.txt"
  fi

  if [ -n "$data_dir" ]; then
    cp -R "$data_dir"/. "$staging/customer-data/"
  else
    echo "No customer demo data included." > "$staging/customer-data/README.txt"
  fi

  {
    echo "customer_slug=$slug"
    echo "created_utc=$ts"
    echo "kit_version=$VERSION"
    echo "model_name=$(manifest_value "$manifest" name)"
    echo "model_format=$(manifest_value "$manifest" format)"
    echo "model_runtime=$(manifest_value "$manifest" runtime)"
    if [ -n "$data_dir" ]; then
      echo "customer_data=present"
    else
      echo "customer_data=absent"
    fi
  } > "$staging/bundle-manifest.txt"

  write_checksums "$staging"
  tar -czf "$archive" -C "$output_dir" "$bundle_name"
  echo "bundle: $archive"
}

bundle_root_from_path() {
  local bundle="$1" tmp="$2"
  if [ -d "$bundle" ]; then
    printf '%s' "$bundle"
    return 0
  fi
  require_file "$bundle" "bundle"
  mkdir -p "$tmp"
  tar -xzf "$bundle" -C "$tmp"
  find "$tmp" -maxdepth 1 -type d -name 'lucairn-customer-bundle-*' -print -quit
}

bundle_verify() {
  local bundle="" expect_slug="" max_age_days="" require_sha256=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bundle) bundle="$2"; shift 2 ;;
      --customer-slug) expect_slug="$2"; shift 2 ;;
      --max-age-days) max_age_days="$2"; shift 2 ;;
      --require-sha256) require_sha256=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown bundle verify argument: $1" ;;
    esac
  done
  [ -n "$bundle" ] || fail "--bundle is required"
  if [ -n "$max_age_days" ]; then
    printf '%s' "$max_age_days" | grep -Eq '^[0-9]+$' \
      || fail "--max-age-days must be a non-negative integer"
  fi
  if [ -n "$expect_slug" ]; then
    # B7: apply the same slug regex bundle_create uses when minting bundles, so
    # an attacker cannot smuggle a bogus expected-slug string past this gate.
    printf '%s' "$expect_slug" | grep -Eq '^[a-z0-9][a-z0-9-]{1,62}$' \
      || fail "--customer-slug must be lowercase letters, numbers, and hyphens"
  fi

  local tmp root
  tmp="$(mktemp -d)"
  root="$(bundle_root_from_path "$bundle" "$tmp")"
  if [ -z "$root" ]; then
    rm -rf "$tmp"
    fail "bundle root not found"
  fi

  require_file "$root/install/docker-compose.customer.yml" "bundle base compose"
  require_file "$root/install/docker-compose.self-hosted.yml" "bundle self-hosted compose"
  require_file "$root/install/customer.env" "bundle customer env"
  require_file "$root/models/model-manifest.yaml" "bundle model manifest"
  require_file "$root/bin/lucairn" "bundle CLI"
  if [ "$require_sha256" -eq 1 ]; then
    validate_model_manifest "$root/models/model-manifest.yaml" "$root/models" "require-sha256"
  else
    validate_model_manifest "$root/models/model-manifest.yaml" "$root/models"
  fi
  verify_checksums "$root"

  if [ -n "$expect_slug" ] || [ -n "$max_age_days" ]; then
    require_file "$root/bundle-manifest.txt" "bundle manifest"
  fi

  # B3: replay-guard hardening. The manifest must declare exactly one
  # customer_slug= and one created_utc= line. Without this, an attacker could
  # append a duplicated line targeting a different victim and re-hash
  # SHA256SUMS — `tail -1` then silently selects the doctored line and the
  # cross-customer replay check passes.
  if [ -n "$expect_slug" ]; then
    local slug_count
    slug_count="$(grep -cE '^customer_slug=' "$root/bundle-manifest.txt" || true)"
    if [ "$slug_count" != "1" ]; then
      rm -rf "$tmp"
      fail "bundle-manifest.txt has $slug_count customer_slug= lines (expected exactly 1)"
    fi
    local actual_slug
    actual_slug="$(grep -E '^customer_slug=' "$root/bundle-manifest.txt" | cut -d= -f2-)"
    if [ "$actual_slug" != "$expect_slug" ]; then
      rm -rf "$tmp"
      fail "bundle customer_slug mismatch: expected '$expect_slug', got '$actual_slug'"
    fi
  fi

  if [ -n "$max_age_days" ]; then
    local ts_count created_utc created_epoch now_epoch age_seconds max_age_seconds
    ts_count="$(grep -cE '^created_utc=' "$root/bundle-manifest.txt" || true)"
    if [ "$ts_count" != "1" ]; then
      rm -rf "$tmp"
      fail "bundle-manifest.txt has $ts_count created_utc= lines (expected exactly 1)"
    fi
    created_utc="$(grep -E '^created_utc=' "$root/bundle-manifest.txt" | cut -d= -f2-)"
    [ -n "$created_utc" ] || { rm -rf "$tmp"; fail "bundle-manifest.txt missing created_utc"; }
    # B5: strip whitespace + pre-check the format with a regex so ambiguous or
    # space-padded values fail with a clear error rather than tripping
    # strptime's "is not a recognised timestamp" later.
    created_epoch="$(python3 - "$created_utc" <<'PY' 2>/dev/null || true
import sys, datetime, re
ts = sys.argv[1].strip()
if not re.fullmatch(r"\d{8}T\d{6}Z", ts):
    sys.exit(0)
try:
    dt = datetime.datetime.strptime(ts, "%Y%m%dT%H%M%SZ").replace(tzinfo=datetime.timezone.utc)
    print(int(dt.timestamp()))
except Exception:
    pass
PY
)"
    [ -n "$created_epoch" ] || { rm -rf "$tmp"; fail "bundle created_utc '$created_utc' is not a recognised timestamp"; }
    now_epoch="$(date -u +%s)"
    age_seconds=$(( now_epoch - created_epoch ))
    # B8: a future-dated bundle is either clock skew or tamper. Either way it
    # is not a state the gate should silently allow under `--max-age-days`.
    if [ "$age_seconds" -lt 0 ]; then
      rm -rf "$tmp"
      fail "bundle created_utc '$created_utc' is in the future ($(( -age_seconds )) seconds): clock skew or tamper"
    fi
    max_age_seconds=$(( max_age_days * 86400 ))
    if [ "$age_seconds" -gt "$max_age_seconds" ]; then
      rm -rf "$tmp"
      fail "bundle is $((age_seconds / 86400)) days old (max allowed: $max_age_days)"
    fi
  fi

  rm -rf "$tmp"
  echo "bundle verify: ok"
}

write_bundle_prepare_report() {
  local report="$1" slug="$2" staging_dir="$3" archive="$4" manifest="$5" env_file="$6"
  local image_delivery="$7" base_compose="$8" self_compose="$9"
  local customer_data="${10}"
  local ts
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  {
    echo "agent_contract=lucairn-customer-package-v1"
    echo "customer_slug=$slug"
    echo "prepared_utc=$ts"
    echo "kit_version=$VERSION"
    echo "bundle_path=$archive"
    echo "bundle_sha256=$(sha256_file "$archive")"
    echo "bundle_verify=ok"
    echo "customer_env=present"
    echo "model_name=$(manifest_value "$manifest" name)"
    echo "model_format=$(manifest_value "$manifest" format)"
    echo "model_runtime=$(manifest_value "$manifest" runtime)"
    echo "image_delivery=$image_delivery"
    echo "customer_data=$customer_data"
    echo "base_compose=$base_compose"
    echo "self_hosted_compose=$self_compose"
    echo "staging_dir=$staging_dir"
    echo "human_review_required=true"
    echo "customer_files_committed_to_git=false"
  } > "$report"
}

bundle_prepare() {
  local slug="" staging_dir="" output_dir="$ROOT/dist/customer-bundles" report_file=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --customer-slug) slug="$2"; shift 2 ;;
      --staging-dir) staging_dir="$2"; shift 2 ;;
      --output) output_dir="$2"; shift 2 ;;
      --report) report_file="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown bundle prepare argument: $1" ;;
    esac
  done

  [ -n "$slug" ] || fail "--customer-slug is required"
  [ -n "$staging_dir" ] || fail "--staging-dir is required"
  [ -d "$staging_dir" ] || fail "staging dir not found: $staging_dir"

  local env_file models_dir manifest image_tar images_dir data_dir image_delivery customer_data base_compose self_compose
  env_file="$staging_dir/customer.env"
  models_dir="$staging_dir/models"
  manifest="$models_dir/model-manifest.yaml"
  image_tar=""
  images_dir=""
  data_dir=""
  image_delivery="registry"
  customer_data="absent"
  base_compose="$ROOT/docker-compose.customer.yml"
  self_compose="$ROOT/docker-compose.self-hosted.yml"

  [ -f "$staging_dir/install/docker-compose.customer.yml" ] && base_compose="$staging_dir/install/docker-compose.customer.yml"
  [ -f "$staging_dir/install/docker-compose.self-hosted.yml" ] && self_compose="$staging_dir/install/docker-compose.self-hosted.yml"

  if [ -f "$staging_dir/images/lucairn-images.tar" ]; then
    image_tar="$staging_dir/images/lucairn-images.tar"
    image_delivery="archive"
  elif dir_has_payload_files "$staging_dir/images"; then
    images_dir="$staging_dir/images"
    image_delivery="directory"
  fi

  # B6: "non-empty" means "contains at least one real candidate file" —
  # exclude the product sentinel `README.txt` (bundle_create writes this when
  # no data dir was supplied) and any hidden dotfile (.gitkeep, .DS_Store, …).
  # Otherwise extracting a previous bundle next to a separately-staged
  # demo-data/ produces a false-positive "ambiguous" failure.
  local data_candidates=() data_real_files=() candidate file
  for candidate in customer-data demo-data data; do
    if [ ! -d "$staging_dir/$candidate" ]; then
      continue
    fi
    # Collect non-sentinel non-dotfile entries. Dotfiles match files whose
    # basename starts with a dot at any depth (find's -name acts on basename).
    local found_files
    found_files="$(find "$staging_dir/$candidate" -mindepth 1 -type f \
        ! -name 'README.txt' ! -name '.*' \
        -print 2>/dev/null || true)"
    if [ -n "$found_files" ]; then
      data_candidates+=("$staging_dir/$candidate")
      data_real_files+=("$found_files")
    fi
  done
  if [ "${#data_candidates[@]}" -gt 1 ]; then
    echo "bundle prepare: ambiguous data staging — multiple non-empty data dirs found:" >&2
    local i=0
    for candidate in "${data_candidates[@]}"; do
      echo "  - $candidate" >&2
      # List ONLY real candidate files (sentinel + dotfiles already filtered).
      while IFS= read -r file; do
        [ -z "$file" ] && continue
        echo "      $file" >&2
      done <<< "${data_real_files[$i]}"
      i=$(( i + 1 ))
    done
    fail "remove the unwanted directories so only one of customer-data/, demo-data/, or data/ contains real files"
  fi
  if [ "${#data_candidates[@]}" -eq 1 ]; then
    data_dir="${data_candidates[0]}"
    customer_data="present"
    echo "selected staging dir: $data_dir"
  fi

  require_file "$env_file" "staged customer env"
  require_file "$manifest" "staged model manifest"
  validate_model_manifest "$manifest" "$models_dir"

  mkdir -p "$output_dir"
  report_file="${report_file:-$output_dir/lucairn-customer-bundle-${slug}-report.txt}"

  local create_args create_output archive verify_output
  create_args=(
    --customer-slug "$slug"
    --models-dir "$models_dir"
    --model-manifest "$manifest"
    --env "$env_file"
    --output "$output_dir"
    --base-compose "$base_compose"
    --self-hosted-compose "$self_compose"
  )
  if [ -n "$data_dir" ]; then
    create_args+=(--customer-data-dir "$data_dir")
  fi
  if [ -n "$image_tar" ]; then
    create_args+=(--image-tar "$image_tar")
  elif [ -n "$images_dir" ]; then
    create_args+=(--images-dir "$images_dir")
  fi

  create_output="$(bundle_create "${create_args[@]}")"
  echo "$create_output"
  archive="$(printf '%s\n' "$create_output" | awk '/^bundle: / {print $2; exit}')"
  [ -n "$archive" ] || fail "bundle prepare could not resolve archive path"

  # B2: prepare's internal verify defaults to the strongest mode so the
  # operator gate matches the receiver gate (CUSTOMER_HANDOFF_GATES.md).
  if ! verify_output="$(bundle_verify --bundle "$archive" --require-sha256 2>&1)"; then
    echo "$verify_output" >&2
    fail "bundle prepare verification failed"
  fi
  echo "$verify_output"

  write_bundle_prepare_report "$report_file" "$slug" "$staging_dir" "$archive" "$manifest" "$env_file" "$image_delivery" "$base_compose" "$self_compose" "$customer_data"
  echo "agent report: $report_file"
}

bundle_command() {
  local subcmd="${1:-}"
  case "$subcmd" in
    create) shift; bundle_create "$@" ;;
    prepare) shift; bundle_prepare "$@" ;;
    verify) shift; bundle_verify "$@" ;;
    -h|--help|"") usage ;;
    *) fail "unknown bundle subcommand: $subcmd" ;;
  esac
}

doctor() {
  local env_file="" compose_file="" offline=0 postgres_url="" kube_namespace="dsa-system" check_images=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --env) env_file="$2"; shift 2 ;;
      --compose) compose_file="$2"; shift 2 ;;
      --offline) offline=1; check_images=0; shift ;;
      --check-images) check_images=1; shift ;;
      --skip-image-check) check_images=0; shift ;;
      --postgres-url) postgres_url="$2"; shift 2 ;;
      --kube-namespace) kube_namespace="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown doctor argument: $1" ;;
    esac
  done

  env_file="${env_file:-$ROOT/customer.env}"
  compose_file="${compose_file:-$ROOT/docker-compose.customer.yml}"

  require_file "$env_file" "env file"
  require_file "$compose_file" "compose file"

  echo "lucairn doctor $VERSION"
  echo "env file: ok ($env_file)"
  echo "compose file: ok ($compose_file)"

  if require_env_values "$env_file"; then
    echo "required secrets: ok"
  else
    return 1
  fi

  local format_failed=0 key
  for key in \
    DSA_SERVICE_TOKEN DSA_BRIDGE_ENCRYPTION_KEY SANDBOX_A_ENCRYPTION_KEY \
    BRIDGE_MASTER_KEY DSA_ADMIN_KEY VEIL_AUDIT_SIGNING_KEY \
    VEIL_BRIDGE_SIGNING_KEY VEIL_SANITIZER_SIGNING_KEY VEIL_WITNESS_SIGNING_KEY \
    VEIL_GATEWAY_SIGNING_KEY VEIL_MANIFEST_SIGNING_KEY VEIL_WITNESS_PUBLIC_KEY \
    VEIL_BRIDGE_PUBLIC_KEY VEIL_SANITIZER_PUBLIC_KEY VEIL_AUDIT_PUBLIC_KEY \
    VEIL_SANDBOX_B_PUBLIC_KEY
  do
    validate_hex64 "$env_file" "$key" || format_failed=1
  done
  validate_keystore_key "$env_file" || format_failed=1
  [ "$format_failed" -eq 0 ] || return 1
  echo "secret formats: ok"

  check_certs "$env_file"

  if [ "$check_images" -eq 1 ]; then
    check_container_images "$env_file" || return 1
  fi

  if [ "$offline" -eq 1 ]; then
    echo "network checks: skipped (--offline)"
    echo "docker compose: skipped (--offline)"
    echo "postgres: skipped (--offline)"
    echo "network policies: skipped (--offline)"
    echo "doctor: ok"
    return 0
  fi

  local gateway_url host port
  gateway_url="$(env_value "$env_file" GATEWAY_BASE_URL)"
  host="$(url_host "$gateway_url")"
  port="$(url_port "$gateway_url")"
  if check_dns "$host"; then
    echo "dns: ok ($host)"
  else
    echo "dns: failed ($host)"
    return 1
  fi

  local gateway_port
  gateway_port="$(env_value "$env_file" GATEWAY_PORT)"
  gateway_port="${gateway_port:-8080}"
  if check_local_port_available "$gateway_port"; then
    echo "ports: ok (host port $gateway_port available)"
  else
    echo "ports: failed (host port $gateway_port already has a listener)"
    return 1
  fi

  local compose
  compose="$(compose_cmd)"
  if [ -n "$compose" ]; then
    if $compose -f "$compose_file" --env-file "$env_file" config --quiet; then
      echo "docker compose: ok"
    else
      echo "docker compose: config failed"
      return 1
    fi
  else
    warn "docker compose not available; skipping compose config validation"
  fi

  postgres_url="${postgres_url:-$(env_value "$env_file" POSTGRES_URL)}"
  if [ -n "$postgres_url" ] && have pg_isready; then
    if pg_isready -d "$postgres_url" >/dev/null 2>&1; then
      echo "postgres: ok"
    else
      echo "postgres: failed"
      return 1
    fi
  else
    echo "postgres: skipped (no --postgres-url or pg_isready unavailable)"
  fi

  if have kubectl; then
    if kubectl get networkpolicy -n "$kube_namespace" >/dev/null 2>&1; then
      echo "network policies: ok ($kube_namespace)"
    else
      echo "network policies: not found or cluster unavailable ($kube_namespace)"
    fi
  else
    echo "network policies: skipped (kubectl unavailable)"
  fi

  echo "doctor: ok"
}

write_cert_report() {
  local env_file="$1" out="$2" key path
  : > "$out"
  for key in SANDBOX_B_CLIENT_CERT SANDBOX_B_CA_CERT GRPC_TLS_CERT_FILE WITNESS_MTLS_CA_BUNDLE_PATH WITNESS_MTLS_GATEWAY_CLIENT_CERT_PATH; do
    path="$(env_value "$env_file" "$key")"
    [ -z "$path" ] && continue
    if [ -f "$path" ]; then
      {
        echo "$key=$path"
        openssl x509 -noout -subject -issuer -dates -in "$path" 2>/dev/null || true
        echo
      } >> "$out"
    else
      echo "$key=$path (missing)" >> "$out"
    fi
  done
  if [ ! -s "$out" ]; then
    echo "No external certificate paths were configured in the env file." > "$out"
  fi
}

support_bundle() {
  local env_file="" compose_file="" output_dir="" offline=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --env) env_file="$2"; shift 2 ;;
      --compose) compose_file="$2"; shift 2 ;;
      --output) output_dir="$2"; shift 2 ;;
      --offline) offline=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown support-bundle argument: $1" ;;
    esac
  done

  env_file="${env_file:-$ROOT/customer.env}"
  compose_file="${compose_file:-$ROOT/docker-compose.customer.yml}"
  output_dir="${output_dir:-$ROOT/support-bundles}"

  require_file "$env_file" "env file"
  require_file "$compose_file" "compose file"
  mkdir -p "$output_dir"

  local ts bundle_dir archive compose
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  bundle_dir="$output_dir/lucairn-support-bundle-$ts"
  archive="$bundle_dir.tar.gz"
  mkdir -p "$bundle_dir"/{redacted,docker,logs,certs,postgres}

  {
    echo "Lucairn support bundle"
    echo "Generated: $ts"
    echo "Kit version: $VERSION"
    echo "Host: $(hostname 2>/dev/null || echo unknown)"
    echo "Kernel: $(uname -a 2>/dev/null || echo unknown)"
    echo
    echo "Customer review required before sending this bundle to Lucairn support."
  } > "$bundle_dir/README.txt"

  {
    echo "version=$VERSION"
    echo "generated_utc=$ts"
  } > "$bundle_dir/version.txt"

  redact_stream < "$env_file" > "$bundle_dir/redacted/customer.env"
  redact_stream < "$compose_file" > "$bundle_dir/redacted/docker-compose.customer.yml"
  write_cert_report "$env_file" "$bundle_dir/certs/cert-validity.txt"

  if [ "$offline" -eq 1 ]; then
    echo "offline mode: docker status not collected" > "$bundle_dir/docker/status.txt"
    echo "offline mode: logs not collected" > "$bundle_dir/logs/compose.log"
    echo "offline mode: postgres schema version not collected" > "$bundle_dir/postgres/schema-version.txt"
  else
    compose="$(compose_cmd)"
    if [ -n "$compose" ]; then
      ($compose -f "$compose_file" --env-file "$env_file" ps 2>&1 || true) | redact_stream > "$bundle_dir/docker/compose-ps.txt"
      (docker ps --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}' 2>&1 || true) | redact_stream > "$bundle_dir/docker/status.txt"
      ($compose -f "$compose_file" --env-file "$env_file" logs --tail 300 --no-color 2>&1 || true) | redact_stream > "$bundle_dir/logs/compose.log"
      ($compose -f "$compose_file" --env-file "$env_file" config 2>&1 || true) | redact_stream > "$bundle_dir/redacted/compose-resolved.yml"
    else
      echo "docker compose unavailable" > "$bundle_dir/docker/status.txt"
      echo "docker compose unavailable" > "$bundle_dir/logs/compose.log"
    fi
    echo "Collect schema version manually if Postgres is external: SELECT version FROM schema_migrations ORDER BY version;" > "$bundle_dir/postgres/schema-version.txt"
  fi

  tar -czf "$archive" -C "$output_dir" "$(basename "$bundle_dir")"
  rm -rf "$bundle_dir"
  echo "support bundle: $archive"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    doctor) shift; doctor "$@" ;;
    support-bundle) shift; support_bundle "$@" ;;
    bundle) shift; bundle_command "$@" ;;
    -h|--help|"") usage ;;
    *) fail "unknown command: $cmd" ;;
  esac
}

main "$@"
