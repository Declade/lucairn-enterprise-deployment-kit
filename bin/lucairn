#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || printf 'unknown')"

usage() {
  cat <<'USAGE'
Usage:
  lucairn doctor --env customer.env --compose docker-compose.customer.yml [--offline] [--check-images] [--skip-image-check] [--strict-runtime]
  lucairn support-bundle --env customer.env --compose docker-compose.customer.yml [--output bundles] [--offline]
  lucairn bundle create --customer-slug acme --models-dir ./models --model-manifest model-manifest.yaml --env customer.env --image-tar images.tar [--customer-data-dir ./customer-data]
  lucairn bundle prepare --customer-slug acme --staging-dir /secure/staging/acme [--output dist/customer-bundles]
  lucairn bundle verify --bundle dist/customer-bundles/lucairn-customer-bundle-acme-YYYYMMDDTHHMMSSZ.tar.gz
  lucairn backup --env customer.env [--compose docker-compose.customer.yml] [--verify]
  lucairn restore --env customer.env --stamp YYYYMMDDTHHMMSSZ [--compose docker-compose.customer.yml] [--db audit|bridge|veil]

  lucairn license issue --license-id ID --customer-id ID --customer-name NAME --valid-until YYYY-MM-DD [--features csv] --signing-key-hex HEX
  lucairn license verify --license TOKEN --public-key-hex HEX
  lucairn license gen-key

  lucairn verify-images [--registry REG] [--tag TAG] [--dashboard-tag TAG] [--key PATH] [--no-dashboard]

Commands:
  doctor          Validate customer deployment prerequisites.
  support-bundle  Generate a redacted support archive for customer review.
  bundle          Create, prepare, or verify per-customer delivery bundles.
  backup          pg_dump -> age-encrypt -> upload the 3 compliance DBs to S3,
                  then prune per LUCAIRN_BACKUP_RETENTION_DAYS. --verify does a
                  restore-into-throwaway smoke. Compose-path peer of the Helm
                  backup CronJobs (see charts/lucairn + OPS.md § Backups).
  restore         Download -> decrypt -> pg_restore a chosen --stamp's dumps
                  into the LIVE compose compliance DBs (restore into clean DBs).
  license         Issue / verify / generate keys for deployment entitlement licenses (operator-only).
  verify-images   Verify the published Lucairn images' cosign signatures against
                  the bundled public key + the Sigstore Rekor transparency log.
                  Requires `cosign` on PATH.
USAGE
}

fail() {
  echo "error: $*" >&2
  exit 1
}

warn() {
  echo "warn: $*" >&2
}

info() {
  echo "$*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

dir_has_payload_files() {
  local dir="$1"
  [ -d "$dir" ] || return 1
  find "$dir" -mindepth 1 -type f ! -iname 'README' ! -iname 'README.*' | grep -q .
}

compose_cmd() {
  if docker compose version >/dev/null 2>&1; then
    echo "docker compose"
  elif have docker-compose; then
    echo "docker-compose"
  else
    echo ""
  fi
}

env_value() {
  local file="$1" key="$2" line
  line="$(grep -E "^${key}=" "$file" 2>/dev/null | tail -1 || true)"
  if [ -z "$line" ]; then
    printf ''
  else
    printf '%s' "${line#*=}" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
  fi
}

# dashboard_opted_in returns 0 if the operator has opted in to the dashboard
# via any of the three supported channels, 1 otherwise. Used by check_dashboard
# AND check_container_images so both functions detect the COMPOSE_PROFILES
# heuristic (FX-2 + FX-5 parity — without this, `--profile dashboard` alone
# bypassed the image pre-flight check while still triggering the bootstrap
# check; result was silent ImagePullBackOff for the dashboard image).
#
# Channels:
#   1. LUCAIRN_DASHBOARD_ENABLED=true in the compose env file (dedicated flag).
#   2. DOCTOR_INCLUDE_DASHBOARD=1 in the live shell env (Helm/kubectl path).
#   3. COMPOSE_PROFILES contains "dashboard" (env file OR live shell) AND the
#      compose file declares a dashboard profile (so we don't trip on stray
#      values where the file doesn't actually wire it).
#
# Args: $1=env_file, $2=compose_file (optional; defaults to
#       ${ROOT:-$(pwd)}/docker-compose.customer.yml).
dashboard_opted_in() {
  local env_file="$1"
  local compose_file="${2:-${ROOT:-$(pwd)}/docker-compose.customer.yml}"

  local enabled
  enabled="$(env_value "$env_file" LUCAIRN_DASHBOARD_ENABLED)"
  if [ "$enabled" = "true" ]; then
    return 0
  fi

  if [ "${DOCTOR_INCLUDE_DASHBOARD:-0}" = "1" ]; then
    return 0
  fi

  if [ -n "$compose_file" ] && [ -f "$compose_file" ] && grep -q 'profiles:.*dashboard' "$compose_file" 2>/dev/null; then
    local compose_profiles_env compose_profiles_live
    compose_profiles_env="$(env_value "$env_file" COMPOSE_PROFILES)"
    compose_profiles_live="${COMPOSE_PROFILES:-}"
    case ",${compose_profiles_env},${compose_profiles_live}," in
      *,dashboard,*) return 0 ;;
    esac
  fi

  return 1
}

is_secret_key() {
  local key="$1"
  case "$key" in
    *KEY*|*TOKEN*|*SECRET*|*PASSWORD*|*PRIVATE*|*SIGNING*|*CERT*|*CREDENTIAL*|*API_KEY*|*LICENSE*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

redact_stream() {
  awk -F= '
    function trim(s) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      return s
    }
    function secret_key(k) {
      return k ~ /(KEY|TOKEN|SECRET|PASSWORD|PRIVATE|SIGNING|CERT|CREDENTIAL|API_KEY|LICENSE)/
    }
    # scrub_inline masks high-confidence secret tokens that can appear ANYWHERE
    # on a line (compose logs, config dumps, prose), not just on KEY=value /
    # KEY: value lines. Runs on every non-comment line BEFORE the structural
    # KEY=value early-return so an sk-/lcr- key on a non-secret-named "=" line
    # (e.g. "note=please use sk-ant-...") is still scrubbed (OBS-06).
    function scrub_inline(line) {
      # Provider API keys (sk-ant-, sk-, etc.) and Lucairn keys (lcr_live_, ...).
      gsub(/sk-[A-Za-z0-9._-]+/, "<redacted>", line)
      gsub(/lcr_[A-Za-z0-9._-]+/, "<redacted>", line)
      # Bearer tokens: "Bearer <token>" (Authorization headers, log lines).
      gsub(/[Bb]earer[[:space:]]+[A-Za-z0-9._~+\/=-]+/, "Bearer <redacted>", line)
      # JWTs: three base64url segments separated by dots, starting with the
      # standard "eyJ" header prefix (handles tokens NOT preceded by "Bearer").
      gsub(/eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+/, "<redacted>", line)
      # Email addresses. (TLD written as [A-Za-z][A-Za-z]+ rather than {2,}
      # so it does not depend on awk interval-quantifier support — the support
      # bundle is generated on arbitrary customer hosts with varied awks.)
      gsub(/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z][A-Za-z]+/, "<redacted>", line)
      # E.164 phone numbers: leading "+" then 8 or more digits (written
      # without an interval quantifier for the same portability reason).
      gsub(/\+[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]*/, "<redacted>", line)
      return line
    }
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { print; next }
    {
      line = scrub_inline($0)
    }
    index(line, "=") > 0 {
      split(line, _kv, "=")
      k = trim(_kv[1])
      if (secret_key(k)) {
        print k "=<redacted>"
      } else {
        print line
      }
      next
    }
    {
      if (line ~ /(KEY|TOKEN|SECRET|PASSWORD|PRIVATE|SIGNING|CERT|CREDENTIAL|API_KEY|LICENSE):/) {
        sub(/:.*/, ": <redacted>", line)
      }
      print line
    }
  '
}

require_file() {
  local file="$1" label="$2"
  [ -f "$file" ] || fail "$label not found: $file"
}

require_env_values() {
  local env_file="$1" missing=0 key val
  # Always-required secrets. DSA_LICENSE_KEY / DSA_LICENSE_SIGNING_KEY are
  # NOT in this list: the gateway treats an empty DSA_LICENSE_KEY as
  # dev-mode (services/gateway/cmd/server/main.go:226-241 "no license key
  # configured — running in unregistered/dev mode"), so doctor must allow
  # the same. We check the license pair separately below: if either is set,
  # BOTH must be set; if both empty, dev mode is acknowledged with a warn.
  local required=(
    DSA_ENV
    DSA_SERVICE_TOKEN
    DSA_BRIDGE_ENCRYPTION_KEY
    SANDBOX_A_ENCRYPTION_KEY
    BRIDGE_MASTER_KEY
    DSA_ADMIN_KEY
    GATEWAY_KEYSTORE_KEY
    GATEWAY_BASE_URL
    VEIL_AUDIT_SIGNING_KEY
    VEIL_BRIDGE_SIGNING_KEY
    VEIL_SANITIZER_SIGNING_KEY
    VEIL_WITNESS_SIGNING_KEY
    VEIL_GATEWAY_SIGNING_KEY
    VEIL_MANIFEST_SIGNING_KEY
    VEIL_WITNESS_PUBLIC_KEY
    VEIL_BRIDGE_PUBLIC_KEY
    VEIL_SANITIZER_PUBLIC_KEY
    VEIL_AUDIT_PUBLIC_KEY
    VEIL_GATEWAY_PUBLIC_KEY
    VEIL_SANDBOX_B_PUBLIC_KEY
    CANARY_HMAC_KEY
  )

  for key in "${required[@]}"; do
    val="$(env_value "$env_file" "$key")"
    if [ -z "$val" ]; then
      echo "required secrets: missing $key"
      missing=1
    fi
  done

  # License pair: empty=dev mode (with explicit warning so the operator
  # never thinks they're production-licensed when they aren't); set=
  # production mode and BOTH must be present + non-placeholder.
  local lic_key lic_sig
  lic_key="$(env_value "$env_file" DSA_LICENSE_KEY)"
  lic_sig="$(env_value "$env_file" DSA_LICENSE_SIGNING_KEY)"
  if [ -z "$lic_key" ] && [ -z "$lic_sig" ]; then
    echo "license: empty DSA_LICENSE_KEY / DSA_LICENSE_SIGNING_KEY -> dev mode (gateway logs 'no license key configured'; tier caps still apply)"
  elif [ -z "$lic_key" ] || [ -z "$lic_sig" ]; then
    echo "license: DSA_LICENSE_KEY and DSA_LICENSE_SIGNING_KEY must be both set or both empty (one is empty, the other is not)"
    missing=1
  fi

  [ "$missing" -eq 0 ]
}

validate_no_placeholder() {
  # Reject values still left at a placeholder form. Catches three
  # placeholder conventions:
  #   - REPLACE_ME_*  — hex/base64 slots padded to the correct length
  #                     (so the operator sees the slot's expected width,
  #                      but the prefix flags it as not-yet-customised).
  #   - REPLACE_WITH_*— named-value slots (license keys, postgres
  #                     passwords, GATEWAY_BASE_URL). The kit ships these
  #                     unfilled and the doctor refuses to proceed until
  #                     they're replaced. Catches copy-and-forget
  #                     regressions.
  #   - Single-character-repeat hex strings (e.g. cccc…64 chars,
  #                     7777…, aaaa…). Sim 3 dead-reference sweep found
  #                     customer.env.example shipped 4 such sentinel
  #                     pubkeys and doctor passed them silently — the
  #                     resulting install ships non-functional crypto.
  local env_file="$1" key="$2" val
  val="$(env_value "$env_file" "$key")"
  [ -z "$val" ] && return 0
  case "$val" in
    REPLACE_ME_*|REPLACE_WITH_*)
      echo "secret format: $key still set to a placeholder value (starts with REPLACE_); replace it before doctor"
      return 1
      ;;
  esac
  # Sentinel-hex check: 64 hex chars consisting of a single repeating
  # character (case-insensitive). Real openssl-generated keys have ~ uniform
  # distribution; a string of 64 identical chars is always a placeholder.
  if printf '%s' "$val" | grep -Eq '^([0-9a-fA-F])\1{63}$'; then
    echo "secret format: $key looks like a repeating-character sentinel ($(printf '%s' "$val" | cut -c1-8)…); replace with a real openssl-generated value"
    return 1
  fi
}

validate_hex64() {
  local env_file="$1" key="$2" val
  val="$(env_value "$env_file" "$key")"
  [ -z "$val" ] && return 0
  if ! printf '%s' "$val" | grep -Eq '^[0-9a-fA-F]{64}$'; then
    echo "secret format: $key must be 64 hex chars"
    return 1
  fi
}

validate_keystore_key() {
  local env_file="$1" val
  val="$(env_value "$env_file" GATEWAY_KEYSTORE_KEY)"
  [ -z "$val" ] && return 0
  # SEC-05 (hardening 2026-05-28): measure the decoded length entirely
  # in-memory. The previous implementation wrote the decoded 32-byte key to
  # a predictable `/tmp/lucairn-keystore-key.$$` path (PID-guessable, default
  # umask, and left briefly on disk on the openssl-success path before the
  # `rm`) — a secret-on-disk exposure with no need. We never write the
  # decoded key to disk now:
  #   1. a decode probe (output to /dev/null) catches malformed base64; and
  #   2. a `decode | wc -c` pipe measures the byte count.
  # The decoded bytes flow only through the pipe into `wc -c` (which discards
  # them after counting), so the plaintext key never lands in a file or even
  # in a shell variable (`bytes` holds only the integer count).
  if ! printf '%s' "$val" | openssl enc -A -d -base64 >/dev/null 2>&1; then
    echo "secret format: GATEWAY_KEYSTORE_KEY must be base64"
    return 1
  fi
  local bytes
  bytes="$(printf '%s' "$val" | openssl enc -A -d -base64 2>/dev/null | wc -c | tr -d ' ')"
  if [ "$bytes" != "32" ]; then
    echo "secret format: GATEWAY_KEYSTORE_KEY must decode to 32 bytes"
    return 1
  fi
}

url_host() {
  python3 - "$1" <<'PY' 2>/dev/null || true
import sys
from urllib.parse import urlparse
u = urlparse(sys.argv[1])
print(u.hostname or "")
PY
}

url_port() {
  python3 - "$1" <<'PY' 2>/dev/null || true
import sys
from urllib.parse import urlparse
u = urlparse(sys.argv[1])
if u.port:
    print(u.port)
elif u.scheme == "https":
    print(443)
elif u.scheme == "http":
    print(80)
else:
    print("")
PY
}

check_dns() {
  # Resolve host without leaking the Python traceback on gaierror.
  # Caller checks the return code; stderr is suppressed so doctor's
  # output stays clean even when the host doesn't resolve. Sim 3
  # rehearser hit this when GATEWAY_BASE_URL was the placeholder
  # `lucairn.customer.example` — doctor printed a 7-line traceback
  # ending in `socket.gaierror: [Errno 8]` instead of a one-line
  # `dns: failed`.
  local host="$1"
  [ -z "$host" ] && return 0
  python3 - "$host" <<'PY' >/dev/null 2>&1
import socket, sys
socket.getaddrinfo(sys.argv[1], None)
PY
}

check_local_port_available() {
  # Returns 0 if the port is free for compose to bind to.
  # Returns 0 if the port is occupied by one of the kit's own compose-managed
  # containers (so re-running doctor after `docker compose up -d` doesn't
  # false-positive). Returns 1 only on a true foreign-process conflict.
  local port="$1"
  [ -z "$port" ] && return 0
  have lsof || return 0   # no lsof available → defer to compose's own bind error
  lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1 || return 0   # free
  # Port has a listener. Check whether it's our own compose stack.
  if have docker && docker compose ps --status running --format '{{.Name}}' 2>/dev/null \
       | grep -q '^[^[:space:]]\+-gateway-1$'; then
    return 0
  fi
  return 1
}

check_dev_mode_consistency() {
  local env_file="$1"
  local dsa_env grpc_tls grpc_cert lic_key
  dsa_env="$(env_value "$env_file" DSA_ENV)"
  grpc_tls="$(env_value "$env_file" GRPC_TLS_ENABLED)"
  grpc_cert="$(env_value "$env_file" GRPC_TLS_CERT_FILE)"
  lic_key="$(env_value "$env_file" DSA_LICENSE_KEY)"

  # Heuristic: if the operator is in dev mode (empty license -> gateway
  # bypass logged at boot) but still on production-default env values
  # (DSA_ENV=production + GRPC_TLS_ENABLED=true) without TLS cert paths
  # set, sandbox-b will refuse to start. Warn before compose-up.
  if [ -z "$lic_key" ] \
     && { [ "$dsa_env" = "production" ] || [ -z "$dsa_env" ]; } \
     && { [ "$grpc_tls" = "true" ] || [ -z "$grpc_tls" ]; } \
     && [ -z "$grpc_cert" ]; then
    echo "warn: dev-mode license (empty DSA_LICENSE_KEY) with DSA_ENV=production + GRPC_TLS_ENABLED=true but no GRPC_TLS_CERT_FILE"
    echo "warn:   sandbox-b will refuse to start: 'GRPC_TLS_ENABLED=true (with cert/key) is required when DSA_ENV=production'"
    echo "warn:   for a local sandbox install set DSA_ENV=development + GRPC_TLS_ENABLED=false; for production install GRPC_TLS_CERT_FILE etc."
    echo "warn:   see TROUBLESHOOTING.md § 'Sandbox B Refuses Insecure Port / Gateway Sandbox B Health-Check TLS Handshake Failure'"
  fi
  return 0
}

check_certs() {
  local env_file="$1" checked=0 failed=0 key path
  local cert_keys=(SANDBOX_B_CLIENT_CERT SANDBOX_B_CA_CERT GRPC_TLS_CERT_FILE WITNESS_MTLS_CA_BUNDLE_PATH WITNESS_MTLS_GATEWAY_CLIENT_CERT_PATH)
  for key in "${cert_keys[@]}"; do
    path="$(env_value "$env_file" "$key")"
    [ -z "$path" ] && continue
    checked=1
    if [ ! -f "$path" ]; then
      echo "certs: missing $key at $path"
      failed=1
      continue
    fi
    if ! openssl x509 -checkend 2592000 -noout -in "$path" >/dev/null 2>&1; then
      echo "certs: $key expires within 30 days or is invalid"
      failed=1
    fi
  done
  if [ "$failed" -eq 0 ]; then
    if [ "$checked" -eq 1 ]; then
      echo "certs: ok"
    else
      echo "certs: no external cert paths configured"
    fi
  fi
  [ "$failed" -eq 0 ]
}

# check_byok_overlay — when LUCAIRN_LLM_EGRESS_ALLOWLIST is set in
# customer.env, surface that the BYOK overlay is in effect so the operator
# (and any compliance reviewer running `doctor`) can audit the declared
# FQDN list at deploy time. This is intentionally informational: the
# Docker bridge driver does not enforce FQDN policy, so the actual
# enforcement layer (host firewall, Cilium NetworkPolicy, transparent
# forward proxy) lives outside the kit. The doctor's role is to confirm
# (a) the allowlist is non-empty, (b) at least one provider key is set,
# and (c) the BYOK compose overlay sits beside the env file.
check_byok_overlay() {
  local env_file="$1"
  local allowlist anthropic openai mistral gemini
  allowlist="$(env_value "$env_file" LUCAIRN_LLM_EGRESS_ALLOWLIST)"
  if [ -z "$allowlist" ]; then
    echo "byok overlay: not in use (LUCAIRN_LLM_EGRESS_ALLOWLIST empty)"
    return 0
  fi

  anthropic="$(env_value "$env_file" ANTHROPIC_API_KEY)"
  openai="$(env_value "$env_file" OPENAI_API_KEY)"
  mistral="$(env_value "$env_file" MISTRAL_API_KEY)"
  gemini="$(env_value "$env_file" GEMINI_API_KEY)"
  local providers=()
  [ -n "$anthropic" ] && providers+=("anthropic")
  [ -n "$openai" ] && providers+=("openai")
  [ -n "$mistral" ] && providers+=("mistral")
  [ -n "$gemini" ] && providers+=("gemini")

  if [ "${#providers[@]}" -eq 0 ]; then
    echo "byok overlay: failed (LUCAIRN_LLM_EGRESS_ALLOWLIST set but no provider key configured — set at least one of ANTHROPIC_API_KEY, OPENAI_API_KEY, MISTRAL_API_KEY, GEMINI_API_KEY)"
    return 1
  fi

  local byok_compose="$ROOT/docker-compose.self-hosted-byok.yml"
  if [ ! -f "$byok_compose" ]; then
    echo "byok overlay: failed (LUCAIRN_LLM_EGRESS_ALLOWLIST is set but docker-compose.self-hosted-byok.yml is missing from $ROOT)"
    return 1
  fi

  echo "byok overlay: ok (allowlist=$allowlist; providers=${providers[*]})"
  echo "  NOTE: FQDN enforcement is the operator's responsibility. The kit"
  echo "  declares the topology + intent; enforcement belongs in your host"
  echo "  firewall, Cilium NetworkPolicy, or transparent forward proxy."
  echo "  See INSTALL.md § \"Self-hosted with managed LLM (BYOK)\"."
  return 0
}

# Verify the identity-plane bridges declared in docker-compose.customer.yml
# are `internal: true`. Sandbox A holds the raw-PII-to-pseudonym mapping;
# locking these networks down is defence-in-depth so a compromised
# identity-plane service cannot exfiltrate the mapping over the public
# internet. If the operator has removed `internal: true`, this is the
# strongest single signal that the "no raw identity data leaves your
# environment" architectural claim has been weakened — warn loudly.
check_identity_networks_internal() {
  local compose_file="$1" failed=0 missing=()
  # Networks that MUST be internal:true. Listed networks have no service on
  # them that needs outbound — confirmed via:
  #   grep -RIn -E "(http|requests|httpx|urllib|fetch|aiohttp)" \
  #     --include="*.py" --include="*.go" services/sandbox-a/ services/id-bridge/
  # which finds zero outbound HTTP clients in the air-tight services.
  local required_internal=(dsa-identity dsa-audit-identity dsa-certification)
  local net
  for net in "${required_internal[@]}"; do
    # Match a 2-space-indented network header `  <name>:` followed within
    # the next few lines (before the next 2-space-indented sibling key) by
    # an `internal: true` line. Use awk to scope per-network.
    if ! awk -v target="  $net:" '
      $0 == target { in_target = 1; next }
      in_target && /^  [a-z]/ { in_target = 0 }
      in_target && /^    internal: true/ { found = 1; exit }
      END { exit (found ? 0 : 1) }
    ' "$compose_file"; then
      missing+=("$net")
      failed=1
    fi
  done
  if [ "$failed" -eq 1 ]; then
    echo "identity networks: failed (${missing[*]} not internal:true)"
    echo "  Sandbox A holds the raw-PII-to-pseudonym mapping. Without"
    echo "  internal: true on these bridges the air-tight services have"
    echo "  outbound reach, contradicting the architectural claim that no"
    echo "  raw identity data leaves your environment. Restore"
    echo "  'internal: true' on the named networks or document the"
    echo "  operator-side firewall enforcement that compensates."
    return 1
  fi
  echo "identity networks: ok (${required_internal[*]} internal:true)"
  return 0
}

check_container_images() {
  local env_file="$1" failed=0 registry tag image
  registry="$(env_value "$env_file" LUCAIRN_IMAGE_REGISTRY)"
  tag="$(env_value "$env_file" LUCAIRN_IMAGE_TAG)"
  registry="${registry:-ghcr.io/declade}"
  tag="${tag:-0.5.0}"

  if ! have docker; then
    echo "container images: skipped (docker unavailable)"
    return 0
  fi

  for image in dsa-audit dsa-id-bridge dsa-sandbox-a dsa-sanitizer dsa-veil-witness dsa-gateway; do
    local ref="${registry}/${image}:${tag}"
    if ! docker manifest inspect "$ref" >/dev/null 2>&1; then
      echo "container images: failed ($ref not pullable; check registry credentials or image tag)"
      failed=1
    fi
  done

  # The dashboard ships under its own opt-in flag with an INDEPENDENT image
  # tag (LUCAIRN_DASHBOARD_IMAGE_TAG, defaults to the kit's pinned dashboard
  # version). Only verify when opted-in so non-dashboard operators do not see
  # a spurious failure for a registry path they never pull. dashboard_opted_in()
  # recognises all three opt-in channels (env-flag, DOCTOR_INCLUDE_DASHBOARD=1,
  # COMPOSE_PROFILES heuristic) so `--profile dashboard` alone no longer
  # bypasses the check.
  #
  # KCID-MED-3 fix-up r1: the fallback tag MUST stay in sync with the
  # dashboard image tag on every kit release. The locked surface list
  # (now 10 surfaces — was 9 through Slice 5 #41 / Slice 6) is documented
  # in customer.env.example § "dashboard.image.tag" and includes:
  #   1. customer.env.example LUCAIRN_DASHBOARD_IMAGE_TAG default
  #   2. customer.env.example inline comment (line ~207)
  #   3. charts/lucairn/values.yaml dashboard.image.tag
  #   4. charts/lucairn/values.yaml inline comment (line 5)
  #   5. charts/lucairn/charts/dashboard/values.yaml image.tag
  #   6. charts/lucairn/charts/dashboard/Chart.yaml appVersion
  #   7. docker-compose.customer.yml lucairn-dashboard image tag
  #   8. docker-compose.self-hosted.yml lucairn-dashboard image tag
  #   9. apps/dashboard/image-manifest.yaml dashboard tag
  #  10. bin/lucairn this fallback (LINE BELOW)
  local dash_tag dash_ref
  if dashboard_opted_in "$env_file"; then
    dash_tag="$(env_value "$env_file" LUCAIRN_DASHBOARD_IMAGE_TAG)"
    dash_tag="${dash_tag:-0.8.2}"
    dash_ref="${registry}/lucairn-dashboard:${dash_tag}"
    if ! docker manifest inspect "$dash_ref" >/dev/null 2>&1; then
      echo "container images: failed ($dash_ref not pullable; check registry credentials or image tag)"
      failed=1
    fi
  fi

  if [ "$failed" -eq 0 ]; then
    echo "container images: ok"
  fi
  [ "$failed" -eq 0 ]
}

# check_image_manifest — warn (do not fail) when the deployer's resolved
# image-tag / registry differs from the kit's pinned-known-good values in
# image-manifest.yaml. Sim 2 surfaced three coupling bugs (kit tag 1.0.0 vs
# real images 0.3.1; sanitizer config 0.4.x recognizers in 0.3.1 image;
# gateway BYOK adapter shape change between releases). The kit needs a
# single artifact that records which combination was actually tested.
check_image_manifest() {
  local env_file="$1" manifest_file="${ROOT}/image-manifest.yaml"

  if [ ! -f "$manifest_file" ]; then
    # Manifest is optional. Older kit versions may not ship one.
    return 0
  fi

  local manifest_kit_version manifest_tag manifest_registry
  manifest_kit_version="$(awk -F: '/^kit_version:/ { sub(/^[^:]+:[[:space:]]*/,""); gsub(/^"|"$/,""); print; exit }' "$manifest_file")"
  manifest_tag="$(awk -F: '/^default_lucairn_image_tag:/ { sub(/^[^:]+:[[:space:]]*/,""); gsub(/^"|"$/,""); print; exit }' "$manifest_file")"
  manifest_registry="$(awk -F: '/^default_lucairn_image_registry:/ { sub(/^[^:]+:[[:space:]]*/,""); gsub(/^"|"$/,""); print; exit }' "$manifest_file")"

  # Sanity: manifest kit_version should match VERSION file.
  if [ -n "$manifest_kit_version" ] && [ "$manifest_kit_version" != "$VERSION" ]; then
    warn "image-manifest.yaml kit_version ($manifest_kit_version) does not match repo VERSION ($VERSION); the kit may be in a half-updated state"
  fi

  # Env-resolved tag vs manifest pinned tag.
  local env_tag env_registry
  env_tag="$(env_value "$env_file" LUCAIRN_IMAGE_TAG)"
  env_tag="${env_tag:-0.5.0}"
  env_registry="$(env_value "$env_file" LUCAIRN_IMAGE_REGISTRY)"
  env_registry="${env_registry:-ghcr.io/declade}"

  if [ -n "$manifest_tag" ] && [ "$manifest_tag" != "$env_tag" ]; then
    warn "LUCAIRN_IMAGE_TAG=$env_tag in env, but image-manifest.yaml pins $manifest_tag for this kit release"
    warn "  bumping LUCAIRN_IMAGE_TAG without updating the kit's config tree can crash-loop services (see TROUBLESHOOTING.md § Image / Config Version Drift)"
  fi

  if [ -n "$manifest_registry" ] && [ "$manifest_registry" != "$env_registry" ]; then
    info "LUCAIRN_IMAGE_REGISTRY=$env_registry differs from manifest default $manifest_registry (expected if using a customer mirror)"
  fi

  echo "image manifest: read from image-manifest.yaml (kit_version=$manifest_kit_version, pinned_tag=$manifest_tag)"
  return 0
}

# -----------------------------------------------------------------------------
# Sim 3 doctor-coverage gaps G1–G10. Each fn below closes one gap surfaced by
# the 2026-05-15 audit; all are --offline-honest (no network required).
# -----------------------------------------------------------------------------

check_render_migrations_safe() {
  # G1: prep-migrations rejects empty / single-quote / backslash values.
  # Catch the same conditions at pre-flight time instead of letting the
  # render-migrations.sh service error halfway through compose-up.
  local env_file="$1" key val ok=0
  for key in AUDIT_APP_PASSWORD VEIL_APP_PASSWORD; do
    val="$(env_value "$env_file" "$key")"
    if [ -z "$val" ]; then
      echo "migration prep: $key is empty; render-migrations.sh will refuse"
      ok=1
    elif printf '%s' "$val" | grep -q "'"; then
      echo "migration prep: $key contains a single quote; render-migrations.sh refuses to substitute"
      ok=1
    elif printf '%s' "$val" | grep -q '\\'; then
      echo "migration prep: $key contains a backslash; render-migrations.sh refuses to substitute"
      ok=1
    fi
  done
  if [ ! -f "$ROOT/scripts/render-migrations.sh" ]; then
    echo "migration prep: scripts/render-migrations.sh missing — prep-migrations service will fail"
    ok=1
  fi
  return "$ok"
}

check_image_tag_set() {
  # G3: empty LUCAIRN_IMAGE_TAG silently falls back to the compose
  # default. Mixed defaults across env / compose / manifest are an
  # uncontrolled-change pattern; require the operator to pin explicitly.
  local env_file="$1" val
  val="$(env_value "$env_file" LUCAIRN_IMAGE_TAG)"
  if [ -z "$val" ]; then
    echo "image tag: LUCAIRN_IMAGE_TAG empty in env (falls back to compose default; pin explicitly to whatever your kit version pins)"
    return 1
  fi
}

check_byok_egress_open() {
  # G4: BYOK overlay is meaningless if dsa-egress is internal:true.
  # Only check when the operator has actually opted into the overlay
  # (LUCAIRN_LLM_EGRESS_ALLOWLIST non-empty).
  local env_file="$1" allowlist
  allowlist="$(env_value "$env_file" LUCAIRN_LLM_EGRESS_ALLOWLIST)"
  [ -z "$allowlist" ] && return 0
  local overlay="$ROOT/docker-compose.self-hosted-byok.yml"
  [ -f "$overlay" ] || return 0
  if awk '/^  dsa-egress:/,/^  [a-z]|^[^ ]/ { if (/^    internal:[[:space:]]+true/) print; }' "$overlay" | grep -q internal; then
    echo "byok overlay: dsa-egress is internal:true — sandbox-b cannot reach the upstream LLM"
    return 1
  fi
}

check_no_dev_default_keys() {
  # G6: three well-known dev-default literals are baked into the dual-
  # sandbox source as boot-time reject conditions when DSA_ENV=production
  # (services/id-bridge/cmd/server/main.go:71-73, sandbox-a:90-92,
  # gateway:538-540). Doctor's hex64 + placeholder gates don't catch
  # them. Reject explicitly when production mode.
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  local failed=0
  if [ "$(env_value "$env_file" BRIDGE_MASTER_KEY)" = "dev-master-key-minimum-32-characters!!" ]; then
    echo "dev defaults: BRIDGE_MASTER_KEY is the dual-sandbox dev literal — id-bridge will refuse to boot in production"
    failed=1
  fi
  if [ "$(env_value "$env_file" SANDBOX_A_ENCRYPTION_KEY)" = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef" ]; then
    echo "dev defaults: SANDBOX_A_ENCRYPTION_KEY is the dual-sandbox dev literal — sandbox-a will refuse to boot in production"
    failed=1
  fi
  if [ "$(env_value "$env_file" DSA_ADMIN_KEY)" = "dsa-admin-secret" ]; then
    echo "dev defaults: DSA_ADMIN_KEY is the dual-sandbox dev literal — gateway will refuse to boot in production"
    failed=1
  fi
  return "$failed"
}

check_local_sandbox_b_api_key() {
  # G7: self-hosted Sandbox-B + production must reject the well-known
  # `local-sandbox-b-key` fallback (compose default in the self-hosted
  # overlay). That value gives anyone with the host port unauthenticated
  # access to the local Sandbox-B.
  local env_file="$1" remote
  remote="$(env_value "$env_file" SANDBOX_B_REMOTE_ENDPOINT)"
  [ -n "$remote" ] && return 0   # split-deployment, not local SB
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  local k
  k="$(env_value "$env_file" LOCAL_SANDBOX_B_API_KEY)"
  if [ -z "$k" ]; then
    echo "local SB: LOCAL_SANDBOX_B_API_KEY unset in self-hosted production (falls back to weak default 'local-sandbox-b-key')"
    return 1
  fi
  if [ "$k" = "local-sandbox-b-key" ]; then
    echo "local SB: LOCAL_SANDBOX_B_API_KEY is the kit's well-known fallback — replace with a real secret"
    return 1
  fi
  if [ "${#k}" -lt 32 ]; then
    echo "local SB: LOCAL_SANDBOX_B_API_KEY too short (need ≥ 32 chars)"
    return 1
  fi
}

check_postgres_passwords() {
  # SEC-01 (hardening 2026-05-28): the four POSTGRES_*_PASSWORD vars plus the
  # two app-role passwords (AUDIT_APP_PASSWORD / VEIL_APP_PASSWORD) all carry a
  # weak `:-` shell fallback in docker-compose.customer.yml (`:-dsa` / `:-veil`
  # / `:-audit_app_password` / `:-veil_app_password`). Those fallbacks are
  # being removed in favour of `${VAR:?...}` fail-fast, but doctor must also
  # reject the weak literals (and blank / too-short values) up front so the
  # operator sees an actionable pre-flight error rather than a compose
  # variable-is-not-set crash at `up` time.
  #
  # Mirrors check_local_sandbox_b_api_key: non-empty AND non-weak-literal AND
  # min-length. Postgres binds NO host port in either compose file (the DBs sit
  # on segmented internal Docker networks), so this is lateral-movement /
  # defence-in-depth, not an externally-reachable bypass — hence enforced only
  # in production (DSA_ENV=production), matching the other prod-gated checks.
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  local failed=0 key val
  # Parallel arrays: password var name + its well-known weak compose fallback.
  local pw_keys=(
    POSTGRES_AUDIT_PASSWORD POSTGRES_BRIDGE_PASSWORD
    POSTGRES_SANDBOX_A_PASSWORD POSTGRES_VEIL_PASSWORD
    AUDIT_APP_PASSWORD VEIL_APP_PASSWORD
  )
  local pw_weak=(
    dsa dsa
    dsa veil
    audit_app_password veil_app_password
  )
  local i=0
  for key in "${pw_keys[@]}"; do
    val="$(env_value "$env_file" "$key")"
    local weak="${pw_weak[$i]}"
    i=$((i + 1))
    if [ -z "$val" ]; then
      echo "db password: $key unset in production (compose used to fall back to weak default '$weak'; set a real secret)"
      failed=1
      continue
    fi
    if [ "$val" = "$weak" ]; then
      echo "db password: $key is the kit's well-known weak fallback ('$weak') — replace with a real secret"
      failed=1
      continue
    fi
    if [ "${#val}" -lt 12 ]; then
      echo "db password: $key too short (need ≥ 12 chars)"
      failed=1
      continue
    fi
  done
  return "$failed"
}

check_gateway_base_url_https() {
  # G9: production GATEWAY_BASE_URL must be https — http URLs end up
  # in DSA-stamped cert URLs surfaced to customers' callers; external
  # verifiers reject http on the cert chain.
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  local url
  url="$(env_value "$env_file" GATEWAY_BASE_URL)"
  case "$url" in
    https://*) ;;
    *) echo "gateway base URL: GATEWAY_BASE_URL must use https:// in production (got: ${url:-empty})"; return 1 ;;
  esac
}

check_lucairn_resource_base_url_https() {
  # NEW-4: LUCAIRN_RESOURCE_BASE_URL is embedded in cert resource links the
  # gateway returns to callers + surfaced in /.well-known. If it leaks http
  # into production, external verifiers reject the cert chain and the
  # failure presents silently (compose-up healthy, /readyz green, /summary
  # 200 — only downstream SDK verification fails).
  #
  # Empty value is allowed: the gateway falls back to the hardcoded constant
  # `https://gateway.lucairn.eu` for `/.well-known/oauth-protected-resource`
  # and MCP OAuth discovery. If GATEWAY_BASE_URL points at a customer-owned
  # gateway host (not gateway.lucairn.eu), leaving LUCAIRN_RESOURCE_BASE_URL
  # empty means OAuth discovery advertises the wrong resource identifier and
  # MCP clients (Smithery, Claude Desktop) fail to complete the OAuth handshake.
  # Warn in that case.
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  local url gw
  url="$(env_value "$env_file" LUCAIRN_RESOURCE_BASE_URL)"
  if [ -z "$url" ]; then
    gw="$(env_value "$env_file" GATEWAY_BASE_URL)"
    case "$gw" in
      ""|*gateway.lucairn.eu*) ;;
      *) echo "warn: LUCAIRN_RESOURCE_BASE_URL empty while GATEWAY_BASE_URL=$gw — /.well-known/oauth-protected-resource will advertise the hardcoded https://gateway.lucairn.eu resource identifier (NOT $gw). Set LUCAIRN_RESOURCE_BASE_URL explicitly if MCP OAuth clients (Smithery, Claude Desktop) talk to this gateway." ;;
    esac
    return 0
  fi
  case "$url" in
    https://*) ;;
    *) echo "resource base URL: LUCAIRN_RESOURCE_BASE_URL must use https:// in production (got: $url)"; return 1 ;;
  esac
}

check_canary_hmac_key_length() {
  # G5 (length): CANARY_HMAC_KEY required-non-empty enforced via the
  # required + placeholder lists already. Add a length floor: sanitizer
  # canary signing wants ≥ 16 bytes (hex32+ or base64-22+).
  local env_file="$1" val
  val="$(env_value "$env_file" CANARY_HMAC_KEY)"
  [ -z "$val" ] && return 0   # required check fires elsewhere
  if [ "${#val}" -lt 32 ]; then
    echo "canary key: CANARY_HMAC_KEY too short (need ≥ 16 bytes; hex32+ or base64-22+)"
    return 1
  fi
}

validate_ed25519_pair() {
  # G10: derive the public key from a signing key seed and compare.
  # Catches the case where the operator pasted a public key from one
  # ceremony and a signing key from another — runtime would silently
  # produce certs that fail external verification.
  local env_file="$1" slot="$2" signing_key claimed_pub derived
  signing_key="$(env_value "$env_file" "VEIL_${slot}_SIGNING_KEY")"
  claimed_pub="$(env_value "$env_file" "VEIL_${slot}_PUBLIC_KEY")"
  [ -z "$signing_key" ] && return 0
  [ -z "$claimed_pub" ] && return 0
  # Skip placeholders so the dedicated placeholder check owns that error.
  case "$signing_key" in REPLACE_ME_*|REPLACE_WITH_*) return 0 ;; esac
  case "$claimed_pub"  in REPLACE_ME_*|REPLACE_WITH_*) return 0 ;; esac
  [ -x "$ROOT/scripts/derive-veil-pubkey.sh" ] || return 0
  derived="$("$ROOT/scripts/derive-veil-pubkey.sh" "$signing_key" 2>/dev/null)"
  if [ -z "$derived" ]; then
    return 0   # derive script unavailable / Python env wrong; non-fatal
  fi
  if [ "$derived" != "$claimed_pub" ]; then
    echo "veil keypair: VEIL_${slot}_PUBLIC_KEY does not match the derived public key of VEIL_${slot}_SIGNING_KEY"
    return 1
  fi
}

check_veil_keypairs() {
  # Wrap validate_ed25519_pair over all paired slots. Sandbox-B is
  # included because the operator generates the pair locally (per
  # INSTALL.md step 4a self-hosted instructions).
  local env_file="$1" slot failed=0
  if [ ! -x "$ROOT/scripts/derive-veil-pubkey.sh" ]; then
    warn "veil keypair: scripts/derive-veil-pubkey.sh missing or non-executable; pair coherence not verified"
    return 0
  fi
  for slot in AUDIT BRIDGE SANITIZER WITNESS GATEWAY SANDBOX_B; do
    validate_ed25519_pair "$env_file" "$slot" || failed=1
  done
  return "$failed"
}

# Sim 3 round-2 follow-up — close 4 remaining gaps surfaced by the doctor
# coverage auditor against the A++ branch (the on-main version of doctor
# left these open).

check_sanitizer_config_image_compat() {
  # G2-CLOSE: cross-check image-manifest.yaml's sanitizer_config_compat
  # against the operator's LUCAIRN_IMAGE_TAG. A customer who pins a tag
  # outside the compat window (e.g. 0.5.0 against compat 0.4.x) would
  # get a sanitizer crash-loop on `Unknown recognizer 'X'` at boot.
  local env_file="$1" manifest="$ROOT/image-manifest.yaml"
  [ -f "$manifest" ] || return 0
  local compat tag major_minor
  # Extract sanitizer_config_compat value: strip key+colon prefix, strip
  # inline-YAML-comment suffix (` # …`), strip surrounding whitespace, then
  # strip wrapping quotes. Comment-strip is load-bearing — the manifest
  # ships an inline comment after the value.
  compat="$(awk -F: '/^[[:space:]]*sanitizer_config_compat:/ {
                       sub(/^[^:]+:[[:space:]]*/,"");
                       sub(/[[:space:]]+#.*$/,"");
                       gsub(/^[[:space:]]+|[[:space:]]+$/,"");
                       gsub(/^"|"$/,"");
                       print; exit
                     }' "$manifest")"
  tag="$(env_value "$env_file" LUCAIRN_IMAGE_TAG)"
  [ -z "$compat" ] && return 0
  [ -z "$tag" ] && return 0
  major_minor="$(printf '%s' "$compat" | sed -E 's/\.[x*]$//')"
  case "$tag" in
    "${major_minor}."*) return 0 ;;
    *) echo "sanitizer drift: LUCAIRN_IMAGE_TAG=$tag is outside sanitizer_config_compat=$compat — sanitizer will crash on Unknown recognizer at boot"; return 1 ;;
  esac
}

check_insecure_dev_mode_off_in_prod() {
  # NEW-1: veil-witness loud-fails when INSECURE_DEV_MODE=true is set
  # alongside DSA_ENV=production. Catch at pre-flight time.
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  [ "$(env_value "$env_file" INSECURE_DEV_MODE)" = "true" ] \
    && { echo "dev mode: INSECURE_DEV_MODE=true is incompatible with DSA_ENV=production (veil-witness will refuse to start)"; return 1; }
  return 0
}

check_veil_rekor_url_in_prod() {
  # NEW-2: veil-witness loud-fails when DSA_ENV=production without
  # VEIL_REKOR_URL set (unless VEIL_DEV_MODE=true overrides).
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  [ "$(env_value "$env_file" VEIL_DEV_MODE)" = "true" ] && return 0
  [ -z "$(env_value "$env_file" VEIL_REKOR_URL)" ] \
    && { echo "veil rekor: VEIL_REKOR_URL required in production (set VEIL_DEV_MODE=true to bypass for non-production)"; return 1; }
  return 0
}

check_veil_tsa_url_in_prod() {
  # NEW-5: parallel to NEW-2. PR #105 in dual-sandbox added HTTPS startup
  # enforcement on VEIL_TSA_URL — witness exits at boot if empty/non-https
  # in production. customer.env.example default is empty, so an operator
  # following the example into production hits an immediate crashloop with
  # no doctor pre-flight.
  local env_file="$1"
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  [ "$(env_value "$env_file" VEIL_DEV_MODE)" = "true" ] && return 0
  local url
  url="$(env_value "$env_file" VEIL_TSA_URL)"
  if [ -z "$url" ]; then
    echo "veil TSA: VEIL_TSA_URL required in production (FreeTSA sub-processor: https://freetsa.org/tsr — set VEIL_DEV_MODE=true to bypass for non-production)"; return 1
  fi
  case "$url" in
    https://*) ;;
    *) echo "veil TSA: VEIL_TSA_URL must use https:// in production (got: $url)"; return 1 ;;
  esac
  return 0
}

check_sandbox_b_remote_coherent() {
  # NEW-3: if SANDBOX_B_REMOTE_ENDPOINT is set, scheme must be https,
  # and in production the mTLS cert triple must all be set together.
  local env_file="$1" ep cert key ca
  ep="$(env_value "$env_file" SANDBOX_B_REMOTE_ENDPOINT)"
  [ -z "$ep" ] && return 0
  case "$ep" in
    https://*) ;;
    *) echo "sandbox-b remote: SANDBOX_B_REMOTE_ENDPOINT must use https:// (got: $ep)"; return 1 ;;
  esac
  [ "$(env_value "$env_file" DSA_ENV)" = "production" ] || return 0
  cert="$(env_value "$env_file" SANDBOX_B_CLIENT_CERT)"
  key="$(env_value "$env_file"  SANDBOX_B_CLIENT_KEY)"
  ca="$(env_value "$env_file"   SANDBOX_B_CA_CERT)"
  if [ -z "$cert" ] || [ -z "$key" ] || [ -z "$ca" ]; then
    echo "sandbox-b remote: production requires SANDBOX_B_CLIENT_CERT + SANDBOX_B_CLIENT_KEY + SANDBOX_B_CA_CERT (one or more missing)"
    return 1
  fi
  return 0
}

# check_dashboard validates the Lucairn Enterprise Dashboard pre-flight.
#
# Triggered when:
#   - $LUCAIRN_DASHBOARD_ENABLED is truthy in the compose env (Compose path
#     opt-in convention), OR
#   - the compose env's COMPOSE_PROFILES (or live env) contains "dashboard"
#     AND the compose file declares the dashboard profile (operator opted in
#     via `--profile dashboard` without setting the dedicated env var), OR
#   - --include-dashboard was passed (Helm path opt-in; doctor's caller can
#     export DOCTOR_INCLUDE_DASHBOARD=1 to flip it for kubectl-based runs).
#
# What it checks:
#   - LUCAIRN_DASHBOARD_BOOTSTRAP_PASSWORD is present AND ≥12 chars (or a
#     Helm-managed secret named lucairn-dashboard-bootstrap-admin exists in
#     the cluster when kubectl is available + DOCTOR_INCLUDE_DASHBOARD=1).
#   - The dashboard container's /healthz returns 200 within 30s when the
#     compose profile is active (best-effort; non-fatal if container is
#     not running yet — doctor is supposed to run BEFORE compose up). The
#     port is read from LUCAIRN_DASHBOARD_LISTEN_ADDR (defaults 8443).
check_dashboard() {
  local env_file="$1"

  # dashboard_opted_in() unifies the three opt-in channels (env-flag,
  # DOCTOR_INCLUDE_DASHBOARD=1, COMPOSE_PROFILES heuristic) so this function
  # and check_container_images stay in lockstep. See helper docstring near
  # env_value() for the full channel list.
  if ! dashboard_opted_in "$env_file"; then
    echo "dashboard: skipped (set LUCAIRN_DASHBOARD_ENABLED=true, add dashboard to COMPOSE_PROFILES, or DOCTOR_INCLUDE_DASHBOARD=1)"
    return 0
  fi

  local include
  include="${DOCTOR_INCLUDE_DASHBOARD:-0}"

  local pw
  pw="$(env_value "$env_file" LUCAIRN_DASHBOARD_BOOTSTRAP_PASSWORD)"
  if [ -z "$pw" ]; then
    if have kubectl && [ "$include" = "1" ]; then
      if kubectl get secret lucairn-dashboard-bootstrap-admin -n "${LUCAIRN_DASHBOARD_NAMESPACE:-lucairn}" >/dev/null 2>&1; then
        echo "dashboard bootstrap secret: ok (kubectl: lucairn-dashboard-bootstrap-admin)"
      else
        echo "dashboard bootstrap secret: failed (neither LUCAIRN_DASHBOARD_BOOTSTRAP_PASSWORD set nor kubectl secret lucairn-dashboard-bootstrap-admin present)"
        return 1
      fi
    else
      echo "dashboard bootstrap secret: failed (LUCAIRN_DASHBOARD_BOOTSTRAP_PASSWORD missing — set in $env_file before \`--profile dashboard\`)"
      return 1
    fi
  else
    if [ "${#pw}" -lt 12 ]; then
      echo "dashboard bootstrap secret: failed (LUCAIRN_DASHBOARD_BOOTSTRAP_PASSWORD must be ≥12 chars; got ${#pw})"
      return 1
    fi
    echo "dashboard bootstrap secret: ok (env)"
  fi

  if have curl; then
    local dash_addr dash_port code
    dash_addr="$(env_value "$env_file" LUCAIRN_DASHBOARD_LISTEN_ADDR)"
    dash_port="${dash_addr##*:}"
    # Strip trailing whitespace; fall back if value did not contain a colon
    # or was empty.
    dash_port="${dash_port//[[:space:]]/}"
    case "$dash_port" in
      ''|*[!0-9]*) dash_port="8443" ;;
    esac
    code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 3 "http://127.0.0.1:${dash_port}/healthz" 2>/dev/null || true)"
    case "$code" in
      200) echo "dashboard healthz: ok (200 on :${dash_port})" ;;
      ""|000) echo "dashboard healthz: not started (no listener on :${dash_port} — expected when doctor runs pre-up)" ;;
      *) echo "dashboard healthz: failed ($code on :${dash_port})"; return 1 ;;
    esac
  else
    echo "dashboard healthz: skipped (curl unavailable)"
  fi

  check_dashboard_oidc "$env_file" || return 1

  check_dashboard_cert_browser "$env_file" || return 1

  check_dashboard_grafana "$env_file" || return 1

  check_dashboard_keys "$env_file" || return 1

  check_dashboard_audit_log "$env_file" || return 1

  check_dashboard_compliance "$env_file" || return 1

  check_dashboard_demo_mode_not_production "$env_file" || return 1

  check_dashboard_demo_toggle_not_production "$env_file" || return 1

  return 0
}

# Pre-flight: LUCAIRN_DASHBOARD_DEMO_MODE must NEVER coexist with
# DSA_ENV=production. demo mode swaps the real cert/audit/admin stores
# for in-memory fixtures at boot (apps/dashboard/main.go:380); an
# operator who silently runs in demo mode against a production install
# would ship the customer fixture-populated cert browsers + audit
# logs + compliance PDF cover pages. Caught here as FAIL, not WARN.
check_dashboard_demo_mode_not_production() {
  local env_file="$1"
  local demo dsa_env
  demo="$(env_value "$env_file" LUCAIRN_DASHBOARD_DEMO_MODE)"
  dsa_env="$(env_value "$env_file" DSA_ENV)"
  if [ "$(printf '%s' "${demo}" | tr '[:upper:]' '[:lower:]' | tr -d ' \t')" = "true" ] \
     && [ "$dsa_env" = "production" ]; then
    echo "dashboard demo mode: failed (LUCAIRN_DASHBOARD_DEMO_MODE=true with DSA_ENV=production; dashboard boots with in-memory fixture data — cert browser, audit log, compliance PDF would all serve fake numbers to the customer)"
    return 1
  fi
  return 0
}

# Pre-flight: LUCAIRN_DASHBOARD_DEMO_TOGGLE_ENABLED in production.
# Warn (not fail) — the toggle only affects the per-user home-page
# view; it does NOT swap the live stores. But it lets any signed-in
# admin flip the home page to fixture data with one POST, which can
# confuse a CISO reviewing the dashboard side-by-side with the
# compliance PDF (which always uses real data).
check_dashboard_demo_toggle_not_production() {
  local env_file="$1"
  local toggle dsa_env
  toggle="$(env_value "$env_file" LUCAIRN_DASHBOARD_DEMO_TOGGLE_ENABLED)"
  dsa_env="$(env_value "$env_file" DSA_ENV)"
  if [ "$(printf '%s' "${toggle}" | tr '[:upper:]' '[:lower:]' | tr -d ' \t')" = "true" ] \
     && [ "$dsa_env" = "production" ]; then
    warn "dashboard demo toggle: warn (LUCAIRN_DASHBOARD_DEMO_TOGGLE_ENABLED=true with DSA_ENV=production; any signed-in admin can flip the home page to demo data via POST /dashboard/toggle-demo — leave unset unless this install is intentionally a sandbox)"
    # Warn, not fail — toggle is non-destructive (cookie-scoped, per-user).
  fi
  return 0
}

# Pre-flight Slice 7 compliance PDF export configuration.
#
# The compliance surface is ADMIN-ONLY and always enabled when the
# dashboard is enabled — there is no opt-in env var. The two knobs
# (LUCAIRN_DASHBOARD_COMPLIANCE_MAX_WINDOW_DAYS +
# LUCAIRN_DASHBOARD_COMPLIANCE_DEFAULT_CUSTOMER_NAME) are optional
# overrides. The doctor checks the shape of each:
#
#   1. MAX_WINDOW_DAYS, when set, must be a positive integer
#      (otherwise the binary fails-closed at boot).
#   2. MAX_WINDOW_DAYS > 3650 → WARN (likely operator typo; the
#      compliance.HardMaxWindowDays cap kicks in inside the binary).
#   3. DEFAULT_CUSTOMER_NAME, when set, must NOT contain a banned
#      literal from the project mechanism-allowlist (the same set
#      compliance.banned_literals.go enforces at PDF render time).
#      The grep below mirrors the Go regex's word-boundary semantics
#      so doctor and Go converge — substring matching is too coarse
#      (`Smfa Holdings`, `Test mfa-protected.com`, `Big Red Team Inc`
#      all false-positive a substring check).
#   4. DEFAULT_CUSTOMER_NAME, when set, must NOT contain control
#      characters; the Go binary fails-closed at first export but
#      doctor catches the regression before customer drives the form.
#   5. Partial-data warning: when both DB pools are unset, the
#      generated PDF will contain zero counts in all categories.
#      Customers handing a zero-count PDF to a regulator without a
#      banner is the failure mode this probe pre-empts.
#
# Bash 3.2 compatible per Slice 2 lesson #7.
#
# Implementation note: the banned-literal pattern is a `grep -E` regex
# anchored on either end with `(^|[^A-Za-z0-9])` / `($|[^A-Za-z0-9])`
# boundaries to match the Go compliance/banned_literals.go regex.
# Pattern entries are kept in the same order as the Go file's
# `boundedEncoded` + `rawEncoded` arrays so future drift between
# doctor and Go is easier to spot.
check_dashboard_compliance() {
  local env_file="$1"
  local max_days default_customer cert_db audit_db
  max_days="$(env_value "$env_file" LUCAIRN_DASHBOARD_COMPLIANCE_MAX_WINDOW_DAYS)"
  default_customer="$(env_value "$env_file" LUCAIRN_DASHBOARD_COMPLIANCE_DEFAULT_CUSTOMER_NAME)"
  cert_db="$(env_value "$env_file" LUCAIRN_DASHBOARD_AUDIT_DB_URL)"
  audit_db="$(env_value "$env_file" LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL)"

  local fail=0

  # (1) + (2) max-window-days shape.
  if [ -n "$max_days" ]; then
    case "$max_days" in
      ''|*[!0-9]*)
        echo "dashboard compliance: failed (LUCAIRN_DASHBOARD_COMPLIANCE_MAX_WINDOW_DAYS must be a positive integer, got: $max_days)"
        fail=1
        ;;
      *)
        if [ "$max_days" -le 0 ]; then
          echo "dashboard compliance: failed (LUCAIRN_DASHBOARD_COMPLIANCE_MAX_WINDOW_DAYS must be > 0, got: $max_days)"
          fail=1
        elif [ "$max_days" -gt 3650 ]; then
          # BH-L2: the binary fails-closed at boot rather than silently
          # capping, so doctor escalates from warn to failed for honesty.
          echo "dashboard compliance: failed (LUCAIRN_DASHBOARD_COMPLIANCE_MAX_WINDOW_DAYS=$max_days exceeds the 3650-day hard cap; the dashboard binary will reject the value at boot — likely operator typo)"
          fail=1
        else
          echo "dashboard compliance: max window ok ($max_days days)"
        fi
        ;;
    esac
  fi

  # (3) default-customer-name banned-literal grep. Word-boundary regex
  # mirrors Go's compliance.bannedLiteralPattern (apps/dashboard/
  # internal/compliance/banned_literals.go). Substring matching is
  # specifically wrong: `Smfa Holdings`, `Test mfa-protected.com`, and
  # `Big Red Team Inc` all false-positive a substring check. BH-M2 +
  # KD-C1 fix-up r1.
  if [ -n "$default_customer" ]; then
    local banned_re_bounded banned_re_raw
    # Bounded set (mirror of Go boundedEncoded; case-insensitive via
    # grep -Ei). Order: longer phrases first.
    banned_re_bounded='(^|[^A-Za-z0-9])(SOC 2|ISO 27001|ISO 27701|ISO 42001|HIPAA|PCI-DSS|PCI DSS|encrypted at rest|penetration test|pen test|red team|MFA|multi-factor authentication|end-to-end encryption|E2E encryption|regular audits|Pro\+|pro_plus|Solo Free|Solo Pro|The Veil|theveil|dsaveil)($|[^A-Za-z0-9])'
    # Raw set (mirror of Go rawEncoded — no boundary wrap because they
    # carry their own anchors via character classes / non-word chars).
    banned_re_raw='TLS 1\.[23]|99\.9%|99\.99%'

    local banned_hit=""
    if printf '%s' "$default_customer" | LC_ALL=C grep -Eiq -- "$banned_re_bounded"; then
      banned_hit="$(printf '%s' "$default_customer" | LC_ALL=C grep -Eio -- "$banned_re_bounded" | head -n 1)"
    elif printf '%s' "$default_customer" | LC_ALL=C grep -Eiq -- "$banned_re_raw"; then
      banned_hit="$(printf '%s' "$default_customer" | LC_ALL=C grep -Eio -- "$banned_re_raw" | head -n 1)"
    fi

    if [ -n "$banned_hit" ]; then
      echo "dashboard compliance: failed (LUCAIRN_DASHBOARD_COMPLIANCE_DEFAULT_CUSTOMER_NAME contains a banned mechanism-allowlist literal (\"$banned_hit\"); the PDF cover render would fail-closed at first export)"
      fail=1
    else
      # Length cap mirrors compliance.SanitizeCustomerName (200 chars).
      if [ "${#default_customer}" -gt 200 ]; then
        echo "dashboard compliance: failed (LUCAIRN_DASHBOARD_COMPLIANCE_DEFAULT_CUSTOMER_NAME exceeds 200 chars; the binary will reject the value at boot)"
        fail=1
      # KD-C2 fix-up r1: control characters silently break the cover
      # render (binary returns 500 at first POST). Probe via `od -An -tx1`
      # for any byte in the 0x00-0x1F / 0x7F range — Bash 3.2 compatible.
      elif printf '%s' "$default_customer" | LC_ALL=C od -An -tx1 | tr -d ' \n' | LC_ALL=C grep -Eq '(0[0-9a-f]|1[0-9a-f]|7f)'; then
        echo "dashboard compliance: failed (LUCAIRN_DASHBOARD_COMPLIANCE_DEFAULT_CUSTOMER_NAME contains a control character; the binary will reject the value at boot)"
        fail=1
      else
        echo "dashboard compliance: default customer name ok"
      fi
    fi
  fi

  # (5) Partial-data warning. KD-C3 fix-up r1. Compliance is always-on;
  # if either DB pool is unset the PDF will silently contain zero counts
  # in the affected categories. Doctor surfaces the gap BEFORE the
  # customer drives a regulator-aimed export.
  #
  # 0.8.1 fix: skip the partial-data warn when LUCAIRN_DASHBOARD_DEMO_MODE
  # is true — the compliance aggregator inherits the demo cert + audit
  # stores via Compute(), so the PDF renders with fixture counts (NOT
  # zeros) even when both DB URLs are empty. The pre-existing warn was
  # operationally wrong about the PDF outcome in demo mode.
  local demo_mode
  demo_mode="$(env_value "$env_file" LUCAIRN_DASHBOARD_DEMO_MODE)"
  if [ "$(printf '%s' "${demo_mode}" | tr '[:upper:]' '[:lower:]' | tr -d ' \t')" = "true" ]; then
    echo "dashboard compliance: skipped in demo mode (fixture data provides counts; DB URLs are intentionally unset)"
  elif [ -z "$cert_db" ] && [ -z "$audit_db" ]; then
    echo "dashboard compliance: warn (LUCAIRN_DASHBOARD_AUDIT_DB_URL + LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL both unset — compliance PDF will contain zero counts in all three categories)"
  elif [ -z "$cert_db" ]; then
    echo "dashboard compliance: warn (LUCAIRN_DASHBOARD_AUDIT_DB_URL unset — Cat 2 + Cat 3 certificate counts will be zero in the generated PDF)"
  elif [ -z "$audit_db" ]; then
    echo "dashboard compliance: warn (LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL unset — Cat 1 + Cat 3 sanitizer + audit-event counts will be zero in the generated PDF)"
  fi

  if [ "$fail" -eq 0 ] && [ -z "$max_days" ] && [ -z "$default_customer" ]; then
    echo "dashboard compliance: skipped (no overrides set; binary uses defaults — 365-day max window, no default customer name)"
  fi

  return "$fail"
}

# Pre-flight Slice 5 API key management configuration. Skipped silently
# when LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL is unset (the /keys surface
# is off; the dashboard still renders cert browser + server health).
#
# Validates 6 failure modes:
#   1. URL set + token unset → FAIL
#   2. Token set + URL unset → FAIL (half-wired the other way)
#   3. Token matches a placeholder pattern (CHANGE_ME_*, etc.) → FAIL
#   4. URL unreachable (`curl -sf --max-time 5 "$url/healthz"` fails)
#      → FAIL (skipped when DOCTOR_OFFLINE=1)
#   5. URL + token set + endpoint returns 401 on /api/v1/admin/customers
#      → FAIL (skipped when DOCTOR_OFFLINE=1)
#   6. URL + token set + 200 + zero customers → WARN (/keys surface
#      will render the "no customers" empty state)
#
# kubectl path: when DOCTOR_INCLUDE_DASHBOARD=1 and kubectl is
# available, verify the Secret named LUCAIRN_DASHBOARD_GATEWAY_ADMIN_SECRET_NAME
# (default `lucairn-dashboard-gateway-admin`) exists AND carries a
# non-empty `admin-token` data key (Slice 4 C14 pattern — verify the
# VALUE not just the Secret existence).
#
# Bash 3.2 compatible per Slice 2 lesson #7 (no `${,,}`, no `declare -A`,
# no `mapfile`/`readarray`).
check_dashboard_keys() {
  local env_file="$1"
  local gw_url gw_token
  gw_url="$(env_value "$env_file" LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL)"
  gw_token="$(env_value "$env_file" LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN)"

  # OPT-IN — both unset = surface disabled cleanly.
  if [ -z "$gw_url" ] && [ -z "$gw_token" ]; then
    echo "dashboard keys: skipped (/keys surface disabled — set LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL + LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN to enable)"
    return 0
  fi

  local fail=0

  # Slice 5 fix-up r1 KD-1: whitespace-strip + length-compare BEFORE
  # any other checks. A leading or trailing space (a common copy-paste
  # footgun) silently breaks byte-for-byte comparison against the
  # gateway's DSA_ADMIN_KEY. We use `tr` rather than bash 4+ `${var//}`
  # so we stay Bash 3.2 compatible per Slice 2 lesson #7.
  local gw_url_stripped gw_token_stripped
  gw_url_stripped="$(printf '%s' "$gw_url" | tr -d ' \t\n\r')"
  gw_token_stripped="$(printf '%s' "$gw_token" | tr -d ' \t\n\r')"
  if [ "${#gw_url_stripped}" != "${#gw_url}" ]; then
    echo "dashboard keys: failed (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL has leading/trailing whitespace — strip it before retrying)"
    fail=1
  fi
  if [ "${#gw_token_stripped}" != "${#gw_token}" ]; then
    echo "dashboard keys: failed (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN has leading/trailing whitespace — strip it before retrying)"
    fail=1
  fi
  if [ "$fail" -eq 1 ]; then
    return "$fail"
  fi
  # All subsequent checks operate on the stripped values so that
  # downstream curl invocations see byte-identical input.
  gw_url="$gw_url_stripped"
  gw_token="$gw_token_stripped"

  # (1) + (2) Half-wired guards.
  if [ -n "$gw_url" ] && [ -z "$gw_token" ]; then
    echo "dashboard keys: failed (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL is set but LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN is empty — the dashboard would 401 on every /keys request)"
    fail=1
  fi
  if [ -n "$gw_token" ] && [ -z "$gw_url" ]; then
    echo "dashboard keys: failed (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN is set but LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL is empty — set both or neither)"
    fail=1
  fi

  if [ "$fail" -eq 1 ]; then
    return "$fail"
  fi

  # (3) Placeholder rejection. Mirrors the Slice 4 GAP-1 grafana
  # secret pattern + the gateway admin client's NewAdminClient
  # constructor (apps/dashboard/internal/gateway/admin_client.go::
  # isPlaceholderToken). Slice 5 fix-up r1 BH-M2: pre-lowercase via
  # `tr` so MixedCase placeholder values like
  # "Change_Me_to_real_gateway_admin_token" are rejected too. The Go
  # side already case-folds via strings.ToLower; this brings shell
  # parity.
  local gw_token_low
  gw_token_low="$(printf '%s' "$gw_token" | tr '[:upper:]' '[:lower:]')"
  case "$gw_token_low" in
    change_me*|changeme*|todo*|replace_me*|replace_with*|your-admin-token*|your_admin_token*|placeholder*)
      echo "dashboard keys: failed (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN still matches a placeholder (e.g. CHANGE_ME_*) — replace with the gateway's DSA_ADMIN_KEY value)"
      fail=1
      ;;
  esac

  # URL scheme check.
  case "$gw_url" in
    https://*)
      echo "dashboard keys: url scheme ok (https)"
      ;;
    http://*)
      echo "dashboard keys: warn (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL uses http://; expected on in-cluster service DNS, audit before exposing externally)"
      ;;
    *)
      echo "dashboard keys: failed (LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL must start with http:// or https://, got: $gw_url)"
      fail=1
      ;;
  esac

  if [ "$fail" -eq 1 ]; then
    return "$fail"
  fi

  # (4) + (5) Reachability + auth probe. Best-effort; --max-time keeps
  # doctor responsive even when the gateway is genuinely down.
  if [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have curl; then
    local probe_url probe_code probe_diag
    probe_url="${gw_url%/}/healthz"
    # Capture both stderr (for TLS / cert diagnostics) and stdout (the
    # HTTP code). Slice 5 fix-up r1 KD-2: when the probe collapses to
    # code 000 against an https:// URL, parse the curl error output to
    # distinguish "gateway is down" from "TLS handshake / cert chain
    # rejected" and surface the latter as a fail with an actionable
    # hint rather than the generic pre-up warn.
    probe_diag="$(mktemp 2>/dev/null || echo /tmp/lucairn-doctor-keys-diag.$$)"
    probe_code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 \
        "$probe_url" 2>"$probe_diag" || echo 000)"
    case "$probe_code" in
      200|204)
        echo "dashboard keys: gateway reachable ($probe_code on $probe_url)"
        ;;
      000)
        case "$gw_url" in
          https://*)
            if [ -s "$probe_diag" ] && grep -qiE 'SSL|certificate|x509|TLS|self.?signed|CA' "$probe_diag" 2>/dev/null; then
              local first_diag
              first_diag="$(head -1 "$probe_diag" 2>/dev/null | tr -d '\r')"
              echo "dashboard keys: failed (TLS error reaching gateway: $first_diag — for a self-signed or corporate-CA gateway, install the CA bundle inside the dashboard container, or use plain HTTP between dashboard and gateway over in-cluster DNS)"
              fail=1
            else
              echo "dashboard keys: warn (gateway unreachable at $probe_url — expected when doctor runs pre-up)"
            fi
            ;;
          *)
            echo "dashboard keys: warn (gateway unreachable at $probe_url — expected when doctor runs pre-up)"
            ;;
        esac
        ;;
      *)
        echo "dashboard keys: failed (gateway $probe_url returned $probe_code; verify LUCAIRN_DASHBOARD_GATEWAY_ADMIN_URL)"
        fail=1
        ;;
    esac
    rm -f "$probe_diag" 2>/dev/null || true

    if [ "$fail" -eq 0 ] && [ "$probe_code" = "200" -o "$probe_code" = "204" ]; then
      local admin_url admin_code admin_body
      admin_url="${gw_url%/}/api/v1/admin/customers"
      admin_body="$(mktemp 2>/dev/null || echo /tmp/lucairn-doctor-keys.$$)"
      admin_code="$(curl -sS -o "$admin_body" -w '%{http_code}' --max-time 5 \
          -H "X-Admin-Key: $gw_token" "$admin_url" 2>/dev/null || echo 000)"
      case "$admin_code" in
        200)
          echo "dashboard keys: admin auth ok ($admin_code on $admin_url)"
          # (6) Zero-customers warn.
          if [ -s "$admin_body" ]; then
            # Lightweight count of customer entries — match the
            # comma-separated "customer_id":"…" pattern. Bash 3.2
            # compatible, no jq dependency.
            local cust_count
            cust_count="$(grep -o '"customer_id"' "$admin_body" 2>/dev/null | wc -l | tr -d ' ')"
            if [ "${cust_count:-0}" -eq 0 ]; then
              echo "dashboard keys: warn (gateway has zero customers — /keys surface will render the \"no customers configured\" empty state)"
            else
              echo "dashboard keys: gateway reports $cust_count customer(s)"
            fi
          fi
          ;;
        401|403)
          # Slice 5 fix-up r1 KD-3: extend the 401 message with the
          # ingress-strip diagnostic. The most common non-obvious cause
          # of a 401 when the token is correct is a reverse-proxy /
          # ingress controller that strips the X-Admin-Key header
          # (Caddy + nginx default behavior; both need a snippet to
          # forward custom headers).
          echo "dashboard keys: failed (admin token rejected by gateway ($admin_code) — verify LUCAIRN_DASHBOARD_GATEWAY_ADMIN_TOKEN matches the gateway's DSA_ADMIN_KEY env var byte-for-byte; if the token is correct, verify your ingress/reverse-proxy does not strip the X-Admin-Key header (nginx: 'proxy_pass_request_headers on' or allowlist X-Admin-Key in a configuration-snippet; Caddy: 'request_header X-Admin-Key' propagation; cloud LB: confirm header forwarding policy))"
          fail=1
          ;;
        000)
          echo "dashboard keys: warn (admin endpoint unreachable; gateway /healthz returned 200 but $admin_url timed out)"
          ;;
        *)
          echo "dashboard keys: failed (admin endpoint $admin_url returned $admin_code)"
          fail=1
          ;;
      esac
      rm -f "$admin_body" 2>/dev/null || true
    fi
  fi

  # kubectl path — Secret existence + non-empty VALUE check.
  if [ "$fail" -eq 0 ] && [ "${DOCTOR_INCLUDE_DASHBOARD:-0}" = "1" ] && have kubectl; then
    local dash_ns secret_name secret_key val
    dash_ns="${LUCAIRN_DASHBOARD_NAMESPACE:-lucairn}"
    secret_name="${LUCAIRN_DASHBOARD_GATEWAY_ADMIN_SECRET_NAME:-lucairn-dashboard-gateway-admin}"
    secret_key="${LUCAIRN_DASHBOARD_GATEWAY_ADMIN_SECRET_KEY:-admin-token}"
    if ! kubectl get secret "$secret_name" -n "$dash_ns" >/dev/null 2>&1; then
      echo "dashboard keys: failed (Secret $secret_name missing in namespace $dash_ns — pre-create with: kubectl -n $dash_ns create secret generic $secret_name --from-literal=$secret_key=<gateway DSA_ADMIN_KEY value>)"
      fail=1
    else
      val=$(kubectl get secret "$secret_name" -n "$dash_ns" -o jsonpath="{.data.${secret_key}}" 2>/dev/null | base64 -d 2>/dev/null || true)
      if [ -z "$val" ]; then
        echo "dashboard keys: failed (Secret $secret_name in $dash_ns has missing/empty key '$secret_key' — verify the key name and value)"
        fail=1
      else
        echo "dashboard keys: kubectl Secret $secret_name present in $dash_ns (key '$secret_key' non-empty)"
      fi
    fi
  fi

  return "$fail"
}

# Pre-flight Slice 6 audit log browser configuration. Skipped silently
# when LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL is unset (the /audit surface
# is off; the rest of the dashboard keeps working).
#
# Validates 5 failure modes:
#   1. URL set + URL not parsable (doesn't start with postgres://) → FAIL
#   2. URL set + matches a placeholder pattern (CHANGE_ME_*, etc.) → FAIL
#   3. URL set + pg_isready / curl probe fails → WARN (audit log DB
#      unreachable; dashboard will fail-closed at boot — operator may
#      see expected pre-up state)
#   4. kubectl path: Secret missing OR data key empty (Slice 4 C14
#      pattern — verify VALUE not just existence)
#   5. psql path: connect + SELECT 1 FROM audit_events LIMIT 1 fails →
#      FAIL (role missing grants is the load-bearing case)
#
# Bash 3.2 compatible per Slice 2 lesson #7.
check_dashboard_audit_log() {
  local env_file="$1"
  local audit_url audit_url_low audit_url_stripped sf_url sf_stripped sf_low
  audit_url="$(env_value "$env_file" LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL)"

  # OPT-IN — empty = surface disabled cleanly.
  if [ -z "$audit_url" ]; then
    echo "dashboard audit-log: skipped (/audit surface disabled — set LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL to enable)"
    return 0
  fi

  local fail=0

  # Whitespace-strip pre-check (Slice 5 fix-up r1 KD-1 pattern).
  audit_url_stripped="$(printf '%s' "$audit_url" | tr -d ' \t\n\r')"
  if [ "${#audit_url_stripped}" != "${#audit_url}" ]; then
    echo "dashboard audit-log: failed (LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL has leading/trailing whitespace — strip it before retrying)"
    return 1
  fi
  audit_url="$audit_url_stripped"

  # (1) Scheme check.
  case "$audit_url" in
    postgres://*|postgresql://*)
      echo "dashboard audit-log: url scheme ok (postgres)"
      ;;
    *)
      echo "dashboard audit-log: failed (LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL must start with postgres:// or postgresql://, got: $audit_url)"
      return 1
      ;;
  esac

  # (2) Placeholder rejection. Case-fold via tr (Slice 5 fix-up r1
  # BH-M2 / Slice 5 pattern #40). Match the same indicators the Go
  # store's isPlaceholderURL recognises.
  audit_url_low="$(printf '%s' "$audit_url" | tr '[:upper:]' '[:lower:]')"
  case "$audit_url_low" in
    *change_me*|*changeme*|*your-*|*placeholder*|*replace_me*|*replaceme*|*todo:set*)
      echo "dashboard audit-log: failed (LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL still matches a placeholder pattern (e.g. CHANGE_ME) — replace with the real connection string)"
      return 1
      ;;
  esac

  # (3) Reachability probe via pg_isready when available, falling back
  # to a curl-shaped TCP probe via /dev/tcp when pg_isready is missing.
  if [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have pg_isready; then
    if pg_isready -d "$audit_url" -t 5 >/dev/null 2>&1; then
      echo "dashboard audit-log: db reachable (pg_isready)"
    else
      echo "dashboard audit-log: warn (audit log DB unreachable via pg_isready; the dashboard will fail-closed at boot — expected pre-up state)"
    fi
  fi

  # (5) Role grant probe via psql when available. Best-effort. Skips
  # silently when psql is not installed (operator's choice of tooling).
  #
  # KD-5: Slice 3's LUCAIRN_DASHBOARD_AUDIT_DB_URL points at the CERT
  # DB (postgres-bridge), Slice 6's LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL
  # points at the EVENT DB (postgres-audit). The two are independent
  # Postgres instances; pointing the audit-log URL at the cert DB is
  # a load-bearing misconfiguration that surfaces only at /audit
  # render time. Mention the distinction in the WARN so operators
  # don't have to re-read INSTALL.md to debug a no-events page.
  if [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have psql; then
    if psql "$audit_url" -X -q -t -c 'SELECT 1 FROM audit_events LIMIT 1' >/dev/null 2>&1; then
      echo "dashboard audit-log: role can SELECT audit_events"
    else
      echo "dashboard audit-log: warn (psql could not SELECT audit_events — verify the role's grants OR run pre-up when the audit DB is not yet reachable; confirm you are pointing at postgres-audit, NOT the cert DB; LUCAIRN_DASHBOARD_AUDIT_LOG_DB_URL targets the audit-event stream, LUCAIRN_DASHBOARD_AUDIT_DB_URL targets the cert browser)"
    fi
  fi

  # KD-1: dashboard_saved_filters table existence probe. Without the
  # migration applied, the /audit surface still works but the
  # saved-filter dropdown silently degrades (the handler swallows
  # ErrSavedFilterTableMissing into a banner). Surface the friendly
  # fix here so operators see the gap during pre-flight.
  if [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have psql; then
    if psql "$audit_url" -X -q -t -c 'SELECT 1 FROM dashboard_saved_filters LIMIT 1' >/dev/null 2>&1; then
      echo "dashboard audit-log: dashboard_saved_filters table ok"
    else
      echo "dashboard audit-log: warn (dashboard_saved_filters missing — apply apps/dashboard/migrations/000001_create_saved_filters.up.sql; saved filters will be silently absent at runtime)"
    fi
  fi

  # KD-2: INSERT grant probe. After Slice 6 fix-up r1 H3/DRIFT-006 the
  # dashboard's reveal-raw + csv_export_with_reveal paths INSERT into
  # audit_events; without the grant those flows fail-close with 500.
  # We probe via DO $$ ... $$ so the row is rolled back if it lands;
  # nothing persists on a successful probe.
  if [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have psql; then
    if psql "$audit_url" -X -q -t -c "
        DO \$\$ BEGIN
          INSERT INTO dashboard_saved_filters(user_email,name,filter_json)
            VALUES('__doctor__','__probe__','{}') ON CONFLICT DO NOTHING;
          DELETE FROM dashboard_saved_filters WHERE user_email='__doctor__' AND name='__probe__';
        END \$\$;" >/dev/null 2>&1; then
      echo "dashboard audit-log: role INSERT+DELETE on dashboard_saved_filters ok"
    else
      echo "dashboard audit-log: warn (role cannot INSERT on dashboard_saved_filters — GRANT INSERT,SELECT,UPDATE,DELETE ON dashboard_saved_filters TO audit_app; filter saves will silently fail)"
    fi
  fi

  # KD-4: saved-filters override URL — same scheme + placeholder gates
  # the main audit-log URL goes through. Operators who pass a
  # placeholder here would hit a fail-closed boot loop.
  sf_url="$(env_value "$env_file" LUCAIRN_DASHBOARD_AUDIT_LOG_SAVED_FILTERS_DB_URL)"
  if [ -n "$sf_url" ]; then
    sf_stripped="$(printf '%s' "$sf_url" | tr -d ' \t\n\r')"
    case "$sf_stripped" in
      postgres://*|postgresql://*) ;;
      *) echo "dashboard audit-log: failed (LUCAIRN_DASHBOARD_AUDIT_LOG_SAVED_FILTERS_DB_URL must start with postgres://)"; fail=1 ;;
    esac
    sf_low="$(printf '%s' "$sf_stripped" | tr '[:upper:]' '[:lower:]')"
    case "$sf_low" in
      *change_me*|*changeme*|*your-*|*placeholder*|*replace_me*|*replaceme*|*todo:set*)
        echo "dashboard audit-log: failed (LUCAIRN_DASHBOARD_AUDIT_LOG_SAVED_FILTERS_DB_URL still matches a placeholder)"; fail=1 ;;
    esac
  fi

  # (4) kubectl path — Secret existence + non-empty VALUE check.
  if [ "$fail" -eq 0 ] && [ "${DOCTOR_INCLUDE_DASHBOARD:-0}" = "1" ] && have kubectl; then
    local dash_ns secret_name secret_key val
    dash_ns="${LUCAIRN_DASHBOARD_NAMESPACE:-lucairn}"
    secret_name="${LUCAIRN_DASHBOARD_AUDIT_LOG_SECRET_NAME:-lucairn-dashboard-audit-log}"
    secret_key="${LUCAIRN_DASHBOARD_AUDIT_LOG_SECRET_KEY:-url}"
    if ! kubectl get secret "$secret_name" -n "$dash_ns" >/dev/null 2>&1; then
      echo "dashboard audit-log: failed (Secret $secret_name missing in namespace $dash_ns — pre-create with: kubectl -n $dash_ns create secret generic $secret_name --from-literal=$secret_key='postgres://audit_app:PASS@postgres-audit:5432/audit')"
      fail=1
    else
      val=$(kubectl get secret "$secret_name" -n "$dash_ns" -o jsonpath="{.data.${secret_key}}" 2>/dev/null | base64 -d 2>/dev/null || true)
      if [ -z "$val" ]; then
        echo "dashboard audit-log: failed (Secret $secret_name in $dash_ns has missing/empty key '$secret_key' — verify the key name and value)"
        fail=1
      else
        echo "dashboard audit-log: kubectl Secret $secret_name present in $dash_ns (key '$secret_key' non-empty)"
      fi
    fi
  fi

  return "$fail"
}

# Pre-flight Slice 4 server-health + Grafana embedding configuration.
#
# Skipped silently when LUCAIRN_DASHBOARD_GRAFANA_URL is unset (Grafana
# embedding is off; the /health surface still polls + renders status
# cards but the side drawer shows the "not configured" placeholder).
#
# Validates:
#   - GRAFANA_URL has http:// or https:// scheme
#   - GRAFANA_JWT_SECRET is set + ≥32 chars (HMAC floor)
#   - GRAFANA_URL is reachable when DOCTOR_OFFLINE != 1 (best-effort HEAD)
#   - HEALTH_POLL_INTERVAL_SECONDS, when set, is a positive integer ≤3600
#
# Bash 3.2 compatible per Slice 2 lesson #7.
check_dashboard_grafana() {
  local env_file="$1"
  local grafana_url grafana_secret poll_interval health_services u
  grafana_url="$(env_value "$env_file" LUCAIRN_DASHBOARD_GRAFANA_URL)"
  grafana_secret="$(env_value "$env_file" LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET)"
  poll_interval="$(env_value "$env_file" LUCAIRN_DASHBOARD_HEALTH_POLL_INTERVAL_SECONDS)"
  health_services="$(env_value "$env_file" LUCAIRN_DASHBOARD_HEALTH_SERVICES)"

  local fail=0

  # Poll interval shape check (always evaluated; the field is opt-in but
  # malformed values are caught here rather than at pod boot).
  # GAP-6 (Slice 4 fix-up r1): the unreachable empty-string case inside
  # this `case` block was removed — the outer `if [ -n "$poll_interval" ]`
  # already excludes empty values.
  if [ -n "$poll_interval" ]; then
    case "$poll_interval" in
      *[!0-9]*)
        echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_HEALTH_POLL_INTERVAL_SECONDS must be a positive integer, got: $poll_interval)"
        fail=1
        ;;
      *)
        if [ "$poll_interval" -le 0 ] || [ "$poll_interval" -gt 3600 ]; then
          echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_HEALTH_POLL_INTERVAL_SECONDS must be 1..3600, got: $poll_interval)"
          fail=1
        fi
        ;;
    esac
  fi

  # GAP-2 (Slice 4 fix-up r1): LUCAIRN_DASHBOARD_HEALTH_SERVICES is a
  # comma-separated `name=url` spec. The Go-side parser
  # (apps/dashboard/internal/health/services.go::ParseServicesSpec)
  # CRASHLOOPS on malformed entries (semicolon separator, missing `=`,
  # empty name, etc.). Catching the obvious shape errors here lets the
  # operator fix `customer.env` before the pod boots. The literal
  # "disabled" turns the poller off and is allowed verbatim.
  if [ -n "$health_services" ] && [ "$health_services" != "disabled" ]; then
    case "$health_services" in
      *\;*)
        echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_HEALTH_SERVICES separator must be ',' not ';', got: $health_services)"
        fail=1
        ;;
    esac
    if [ "$fail" -eq 0 ]; then
      local old_ifs entry
      old_ifs="$IFS"
      IFS=','
      # Bash 3.2: manually iterate over the comma-split list. set -- via
      # `read -a` would break with empty trailing tokens, and ${array[@]}
      # requires bash ≥4 syntax discipline that this script avoids.
      for entry in $health_services; do
        # Strip surrounding whitespace (BSD-compatible).
        entry="${entry# }"
        entry="${entry% }"
        if [ -z "$entry" ]; then continue; fi
        case "$entry" in
          *=*) ;;
          *)
            echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_HEALTH_SERVICES entry must be name=url, got: $entry)"
            fail=1
            ;;
        esac
      done
      IFS="$old_ifs"
    fi
    if [ "$fail" -eq 0 ]; then
      echo "dashboard grafana: health services spec ok"
    fi
  fi

  # Grafana embed is OPT-IN. Empty URL = embed off + we don't probe.
  if [ -z "$grafana_url" ]; then
    if [ -n "$grafana_secret" ]; then
      echo "dashboard grafana: warn (LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET set but LUCAIRN_DASHBOARD_GRAFANA_URL is empty — embed will stay OFF)"
    else
      echo "dashboard grafana: skipped (embed disabled — set LUCAIRN_DASHBOARD_GRAFANA_URL to enable)"
    fi
    return "$fail"
  fi

  # URL scheme check.
  u="$grafana_url"
  case "$u" in
    https://*)
      echo "dashboard grafana: url scheme ok (https)"
      ;;
    http://*)
      echo "dashboard grafana: warn (LUCAIRN_DASHBOARD_GRAFANA_URL uses http://, expected https://)"
      ;;
    *)
      echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_GRAFANA_URL must include scheme, got: $u)"
      fail=1
      ;;
  esac

  # Shared secret length floor (must match apps/dashboard/internal/grafana/jwt.go::MinSecretBytes).
  if [ -z "$grafana_secret" ]; then
    echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET is required when LUCAIRN_DASHBOARD_GRAFANA_URL is set)"
    fail=1
  else
    # GAP-1 (Slice 4 fix-up r1): reject obvious placeholder strings even
    # when they pass the length floor (CHANGE_ME_, TODO_, etc.). Catches
    # the customer who literally copy-pastes the example placeholder into
    # customer.env without rotating it.
    case "$grafana_secret" in
      CHANGE_ME*|CHANGEME*|changeme*|change_me*|TODO*|todo*|REPLACE*|replace*)
        echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET still set to a placeholder — replace with 32+ random chars, e.g. \`openssl rand -hex 24\`)"
        fail=1
        ;;
      *)
        if [ "${#grafana_secret}" -lt 32 ]; then
          echo "dashboard grafana: failed (LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET must be ≥32 chars, got ${#grafana_secret})"
          fail=1
        else
          echo "dashboard grafana: shared secret ok (${#grafana_secret} chars)"
        fi
        ;;
    esac
  fi

  # GAP-3 (Slice 4 fix-up r1): verify that the K8s Secret exists in BOTH
  # the dashboard namespace AND the observability namespace. The dashboard
  # sub-chart's secret-grafana-jwt.yaml auto-renders the mirror; this
  # check catches operators who supply their own secretName + forgot to
  # duplicate it across namespaces, or who use a different Helm chart
  # ordering that left the observability copy stale.
  if [ "$fail" -eq 0 ] && [ "${DOCTOR_INCLUDE_DASHBOARD:-0}" = "1" ] && have kubectl; then
    local dash_ns obs_ns secret_name
    dash_ns="${LUCAIRN_DASHBOARD_NAMESPACE:-lucairn}"
    obs_ns="${LUCAIRN_OBSERVABILITY_NAMESPACE:-dsa-observability}"
    secret_name="${LUCAIRN_DASHBOARD_GRAFANA_JWT_SECRET_NAME:-lucairn-dashboard-grafana-jwt}"
    local missing=""
    if ! kubectl get secret "$secret_name" -n "$dash_ns" >/dev/null 2>&1; then
      missing="$dash_ns"
    fi
    if ! kubectl get secret "$secret_name" -n "$obs_ns" >/dev/null 2>&1; then
      if [ -n "$missing" ]; then
        missing="$missing + $obs_ns"
      else
        missing="$obs_ns"
      fi
    fi
    if [ -n "$missing" ]; then
      echo "dashboard grafana: failed (Secret $secret_name missing in: $missing — Grafana pod will CrashLoopBackOff with CreateContainerConfigError. Either run \`helm upgrade\` to re-render the Secret mirror, or copy it across namespaces manually.)"
      fail=1
    else
      echo "dashboard grafana: jwt Secret present in both $dash_ns + $obs_ns"
    fi

    # C14 (Slice 4 fix-up r2): for each namespace where the Secret EXISTS,
    # verify the `shared-secret` data key carries a non-empty value. A
    # customer who pre-created the Secret with the wrong key name (or with
    # an empty string for the value) passes the existence check above but
    # the dashboard later fails to mint JWTs silently. Decode the base64
    # payload and reject empty.
    local _check_ns _val
    for _check_ns in "$dash_ns" "$obs_ns"; do
      if kubectl get secret "$secret_name" -n "$_check_ns" >/dev/null 2>&1; then
        _val=$(kubectl get secret "$secret_name" -n "$_check_ns" -o jsonpath='{.data.shared-secret}' 2>/dev/null | base64 -d 2>/dev/null || true)
        if [ -z "$_val" ]; then
          echo "dashboard grafana: failed (Secret $secret_name in namespace $_check_ns has missing/empty 'shared-secret' key — verify the key name is exactly 'shared-secret' and the value is the 48-char random secret)"
          fail=1
        fi
      fi
    done
  fi

  # Optional reachability probe. Best-effort; non-fatal if it fails so
  # operators can run doctor BEFORE the Grafana pod is up and still get
  # the rest of the gates.
  if [ "$fail" -eq 0 ] && [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have curl; then
    local probe_url health_code
    probe_url="${grafana_url%/}/api/health"
    health_code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 \
        "$probe_url" 2>/dev/null || echo 000)"
    # GAP-4 (Slice 4 fix-up r1): non-200 / non-000 codes from the
    # Grafana health endpoint indicate a misconfigured Grafana — fail
    # rather than warn. The 000 (unreachable) case stays as warn-only
    # so operators can run `doctor` BEFORE the Grafana pod is up.
    case "$health_code" in
      200) echo "dashboard grafana: grafana reachable (200 on $probe_url)" ;;
      000) echo "dashboard grafana: warn (grafana unreachable at $probe_url — expected when doctor runs pre-up)" ;;
      *)
        echo "dashboard grafana: failed (grafana $probe_url returned $health_code; verify URL + auth)"
        fail=1
        ;;
    esac

    # GAP-5 (Slice 4 fix-up r1): soft-warn probe of the datasource-proxy
    # path. A 404 here while /api/health is 200 strongly suggests the
    # Grafana side has NOT been configured with [auth.jwt] / our shared
    # secret, so the embed will silently fall back to the login screen.
    # Non-fatal so we surface it as a warn.
    if [ "$health_code" = "200" ]; then
      local probe_proxy proxy_code
      probe_proxy="${grafana_url%/}/api/datasources/proxy/health"
      proxy_code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 \
          "$probe_proxy" 2>/dev/null || echo 000)"
      case "$proxy_code" in
        200|401|403)
          # 200 means proxy reachable; 401/403 means Grafana is auth-gating
          # the path — both are evidence Grafana itself routes the URL.
          ;;
        404)
          echo "dashboard grafana: warn (datasource-proxy returned 404 at $probe_proxy — Grafana side may be missing [auth.jwt] config; embedded iframe will land on the login screen)"
          ;;
        *)
          # Non-fatal: best-effort signal only.
          ;;
      esac
    fi
  fi

  return "$fail"
}

# Pre-flight OIDC SSO configuration when LUCAIRN_DASHBOARD_OIDC_ENABLED=true.
# Catches issuer-unreachable, missing required vars, scheme-less URLs, and
# CALLBACK_URL/PUBLIC_URL absence before the dashboard pod crashloops on
# startup with a misleading config error. Skipped silently when OIDC is OFF.
check_dashboard_oidc() {
  local env_file="$1"
  local oidc_enabled
  oidc_enabled="$(env_value "$env_file" LUCAIRN_DASHBOARD_OIDC_ENABLED)"
  case "$oidc_enabled" in
    true|TRUE|True|1|yes|YES|Yes|on|ON|On) ;;
    *) return 0 ;;
  esac

  local fail=0 var val u
  for var in \
      LUCAIRN_DASHBOARD_OIDC_ISSUER_URL \
      LUCAIRN_DASHBOARD_OIDC_CLIENT_ID \
      LUCAIRN_DASHBOARD_OIDC_CLIENT_SECRET \
      LUCAIRN_DASHBOARD_OIDC_ADMIN_GROUP \
      LUCAIRN_DASHBOARD_OIDC_VIEWER_GROUP; do
    val="$(env_value "$env_file" "$var")"
    if [ -z "$val" ]; then
      echo "dashboard oidc: failed ($var must be set when OIDC_ENABLED=true)"
      fail=1
    fi
  done

  local cb pub
  cb="$(env_value "$env_file" LUCAIRN_DASHBOARD_OIDC_CALLBACK_URL)"
  pub="$(env_value "$env_file" LUCAIRN_DASHBOARD_OIDC_PUBLIC_URL)"
  if [ -z "$cb" ] && [ -z "$pub" ]; then
    echo "dashboard oidc: failed (LUCAIRN_DASHBOARD_OIDC_CALLBACK_URL or _PUBLIC_URL required)"
    fail=1
  fi

  for var in LUCAIRN_DASHBOARD_OIDC_ISSUER_URL LUCAIRN_DASHBOARD_OIDC_CALLBACK_URL LUCAIRN_DASHBOARD_OIDC_PUBLIC_URL; do
    u="$(env_value "$env_file" "$var")"
    if [ -n "$u" ]; then
      case "$u" in
        https://*) ;;
        http://*) echo "dashboard oidc: warn ($var uses http://, expected https://)" ;;
        *) echo "dashboard oidc: failed ($var must include scheme, got: $u)"; fail=1 ;;
      esac
    fi
  done

  if [ "$fail" -eq 0 ] && [ "${DOCTOR_OFFLINE:-0}" != "1" ] && have curl; then
    local issuer disc_code
    issuer="$(env_value "$env_file" LUCAIRN_DASHBOARD_OIDC_ISSUER_URL)"
    issuer="${issuer%/}"
    disc_code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 \
        "${issuer}/.well-known/openid-configuration" 2>/dev/null || echo 000)"
    case "$disc_code" in
      200) echo "dashboard oidc: issuer reachable (200 on ${issuer}/.well-known/openid-configuration)" ;;
      *) echo "dashboard oidc: failed (issuer discovery returned $disc_code at ${issuer}/.well-known/openid-configuration)"; fail=1 ;;
    esac
  fi

  return "$fail"
}

# Pre-flight Slice 3 cert browser configuration. Skipped silently when
# neither LUCAIRN_DASHBOARD_AUDIT_DB_URL nor LUCAIRN_DASHBOARD_WITNESS_ENDPOINT
# is set (cert pages render "not configured"; auth + shell still work).
# When EITHER is set, both are required (half-wired config is the
# Sim-class regression class the FX-17 lesson keeps catching).
#
# Validates:
#   - AUDIT_DB_URL scheme is postgres:// or postgresql://
#   - WITNESS_ENDPOINT has a colon (host:port shape)
#   - When running against Helm + DOCTOR_INCLUDE_DASHBOARD=1: the
#     auditDB Secret named in customer-values.yaml exists.
#
# Bash 3.2 compatible per the Slice 2 lesson (macOS default shell).
check_dashboard_cert_browser() {
  local env_file="$1"
  local db_url witness_ep tls_enabled
  db_url="$(env_value "$env_file" LUCAIRN_DASHBOARD_AUDIT_DB_URL)"
  witness_ep="$(env_value "$env_file" LUCAIRN_DASHBOARD_WITNESS_ENDPOINT)"
  tls_enabled="$(env_value "$env_file" LUCAIRN_DASHBOARD_WITNESS_TLS_ENABLED)"

  # The cert surface is OPT-IN. The driver is LUCAIRN_DASHBOARD_AUDIT_DB_URL:
  # empty AUDIT_DB_URL means cert surface OFF (the witness endpoint
  # default in docker-compose is a no-op in that case).
  if [ -z "$db_url" ]; then
    echo "dashboard certs: skipped (cert browser disabled — set LUCAIRN_DASHBOARD_AUDIT_DB_URL to enable)"
    return 0
  fi

  local fail=0
  case "$db_url" in
    postgres://*|postgresql://*)
      echo "dashboard certs: db url scheme ok"
      ;;
    *)
      echo "dashboard certs: failed (LUCAIRN_DASHBOARD_AUDIT_DB_URL must start with postgres:// or postgresql://, got: $db_url)"
      fail=1
      ;;
  esac

  if [ -z "$witness_ep" ]; then
    echo "dashboard certs: failed (LUCAIRN_DASHBOARD_WITNESS_ENDPOINT is required when LUCAIRN_DASHBOARD_AUDIT_DB_URL is set)"
    fail=1
  else
    case "$witness_ep" in
      *:*)
        echo "dashboard certs: witness endpoint shape ok ($witness_ep)"
        ;;
      *)
        echo "dashboard certs: failed (LUCAIRN_DASHBOARD_WITNESS_ENDPOINT must be host:port, got: $witness_ep)"
        fail=1
        ;;
    esac
  fi

  # TLS is reserved for the future mTLS slice; warn the operator who
  # sets it true today so the dead-config setting does not look ignored.
  case "$tls_enabled" in
    true|TRUE|True|1|yes|YES|Yes|on|ON|On)
      echo "dashboard certs: warn (LUCAIRN_DASHBOARD_WITNESS_TLS_ENABLED is a no-op in this image — mTLS lands in a future slice)"
      ;;
    *)
      ;;
  esac

  # Optional kubectl-side cross-check: when the Helm secret name is
  # known, verify it exists. Helm values surface this via
  # LUCAIRN_DASHBOARD_AUDIT_DB_SECRET_NAME (operator-set, optional).
  local include secret_name
  include="${DOCTOR_INCLUDE_DASHBOARD:-0}"
  secret_name="$(env_value "$env_file" LUCAIRN_DASHBOARD_AUDIT_DB_SECRET_NAME)"
  if [ "$include" = "1" ] && have kubectl && [ -n "$secret_name" ]; then
    if kubectl get secret "$secret_name" -n "${LUCAIRN_DASHBOARD_NAMESPACE:-lucairn}" >/dev/null 2>&1; then
      echo "dashboard certs: audit-db secret ok (kubectl: $secret_name)"
    else
      echo "dashboard certs: failed (audit-db Secret $secret_name not found in ${LUCAIRN_DASHBOARD_NAMESPACE:-lucairn})"
      fail=1
    fi
  fi

  return "$fail"
}

sha256_file() {
  local file="$1"
  if have sha256sum; then
    sha256sum "$file" | awk '{print $1}'
  else
    shasum -a 256 "$file" | awk '{print $1}'
  fi
}

manifest_value() {
  local manifest="$1" key="$2"
  awk -v key="$key" '
    /^[[:space:]]*model:[[:space:]]*$/ { in_model=1; next }
    in_model && /^[^[:space:]]/ { in_model=0 }
    in_model {
      pattern = "^[[:space:]]*" key ":[[:space:]]*"
      if ($0 ~ pattern) {
        sub(pattern, "")
        gsub(/^["'\''"]|["'\''"]$/, "")
        print
        exit
      }
    }
  ' "$manifest"
}

manifest_files_entries() {
  # Emits "path<TAB>sha256" lines, one per declared file.
  # Supports BOTH shapes:
  #   1) Legacy:  files: [ "foo.gguf", "bar.gguf" ]  (block form: "- foo.gguf")
  #      -> "foo.gguf\t"        (empty second column)
  #   2) New:     files:
  #                 - path: foo.gguf
  #                   sha256: <64-hex>
  #      -> "foo.gguf\tabc..."
  #
  # B4 hardening: the new-shape parser is keyed off the field NAME, not on
  # positional ordering. Authors may interleave sibling keys (size:, source:,
  # license:, notes:) between path: and sha256: — the parser ignores those
  # rather than dropping sha256 silently.
  local manifest="$1"
  awk -v OFS='\t' '
    function trim(s) { gsub(/^[[:space:]]+|[[:space:]]+$/, "", s); gsub(/^["'\''"]|["'\''"]$/, "", s); return s }
    function flush_cur() {
      if (cur_path != "") { print cur_path, cur_sha }
      cur_path=""; cur_sha=""
    }
    /^[[:space:]]*model:[[:space:]]*$/ { in_model=1; next }
    in_model && /^[^[:space:]]/ { in_model=0 }
    in_model && /^[[:space:]]*files:[[:space:]]*$/ {
      in_files=1
      # Capture the indentation depth of the "files:" key so we can detect a
      # sibling key (same or shallower indent that is NOT a list item) as the
      # end of the files block.
      match($0, /^[[:space:]]*/)
      files_indent = RLENGTH
      next
    }
    in_files {
      # End of files list: a sibling key at <= files_indent that is not a list
      # marker and not a deeper continuation. We compute the indent of $0 and
      # compare; deeper-indented continuation lines (size:, source:, etc.) stay
      # inside the current entry and are ignored by the allowlist below.
      match($0, /^[[:space:]]*/)
      cur_indent = RLENGTH
      if (cur_indent <= files_indent && $0 ~ /^[[:space:]]*[A-Za-z0-9_-]+:[[:space:]]*/ && $0 !~ /^[[:space:]]*-[[:space:]]/) {
        flush_cur()
        exit
      }
      # New shape: list item starting with "- path: <value>"
      if ($0 ~ /^[[:space:]]*-[[:space:]]+path:[[:space:]]*/) {
        flush_cur()
        line=$0
        sub(/^[[:space:]]*-[[:space:]]+path:[[:space:]]*/, "", line)
        cur_path=trim(line); cur_sha=""
        next
      }
      # New shape: any deeper-indented continuation line for the current entry.
      # We key off the field name ("sha256:"), so size:, source:, license:,
      # notes: are tolerated in any order between path: and sha256: without
      # dropping the sha256.
      if (cur_path != "" && $0 ~ /^[[:space:]]+sha256:[[:space:]]*/) {
        line=$0
        sub(/^[[:space:]]+sha256:[[:space:]]*/, "", line)
        cur_sha=trim(line)
        next
      }
      # Other allowlisted sibling keys inside an entry — explicitly ignored so
      # interleaving them between path: and sha256: cannot drop the sha256.
      if (cur_path != "" && $0 ~ /^[[:space:]]+(size|source|license|notes):[[:space:]]*/) {
        next
      }
      # Legacy shape: bare scalar item "- foo.gguf" (NOT a key:value pair)
      if ($0 ~ /^[[:space:]]*-[[:space:]]+[^[:space:]]/ && $0 !~ /^[[:space:]]*-[[:space:]]+[A-Za-z0-9_-]+:[[:space:]]/) {
        flush_cur()
        line=$0
        sub(/^[[:space:]]*-[[:space:]]+/, "", line)
        cur_path=trim(line); cur_sha=""
        next
      }
    }
    END { flush_cur() }
  ' "$manifest"
}

manifest_checksum_policy() {
  local manifest="$1" val
  val="$(manifest_value "$manifest" checksum_policy)"
  if [ -z "$val" ]; then
    printf 'sha256-required'
  else
    printf '%s' "$val"
  fi
}

validate_model_manifest() {
  # Args:
  #   $1 manifest path
  #   $2 models dir
  #   $3 (optional) "require-sha256" — when set, force checksum_policy to
  #      "sha256-required" regardless of what the manifest declares. Used by
  #      `bundle verify --require-sha256` (B2) to defend against a manifest
  #      that has been tampered to declare a weaker policy.
  local manifest="$1" models_dir="$2" force_mode="${3:-}"
  local name format runtime policy file sha actual missing=0
  require_file "$manifest" "model manifest"
  [ -d "$models_dir" ] || fail "models dir not found: $models_dir"

  name="$(manifest_value "$manifest" name)"
  format="$(manifest_value "$manifest" format)"
  runtime="$(manifest_value "$manifest" runtime)"
  policy="$(manifest_checksum_policy "$manifest")"

  [ -n "$name" ] || { echo "model manifest: missing model.name"; return 1; }
  [ -n "$format" ] || { echo "model manifest: missing model.format"; return 1; }
  [ -n "$runtime" ] || { echo "model manifest: missing model.runtime"; return 1; }

  case "$format" in
    gguf|safetensors|pytorch|onnx|tensorrt-llm|ollama|openai-compatible|custom) ;;
    *) echo "model manifest: unsupported format '$format'"; return 1 ;;
  esac

  case "$runtime" in
    llama-cpp|vllm|tgi|ollama|onnxruntime|triton|external-openai-compatible|custom) ;;
    *) echo "model manifest: unsupported runtime '$runtime'"; return 1 ;;
  esac

  case "$policy" in
    sha256-required|sha256-optional|none|external-runtime-no-model-file) ;;
    *) echo "model manifest: unsupported checksum_policy '$policy' (allowed: sha256-required, sha256-optional, none, external-runtime-no-model-file)"; return 1 ;;
  esac

  # B1: `external-runtime-no-model-file` is meaningful ONLY when the runtime
  # also delegates to an external endpoint. Without this guard, a tampered
  # manifest could pair `runtime: llama-cpp` with this policy and skip the
  # re-hash entirely (the loop terminal `;;` does nothing).
  if [ "$policy" = "external-runtime-no-model-file" ]; then
    case "$runtime" in
      external-openai-compatible) ;;
      *)
        echo "model manifest: checksum_policy=external-runtime-no-model-file requires runtime=external-openai-compatible (got '$runtime')"
        return 1
        ;;
    esac
  fi

  # B2: receiver-side override. If the caller demands strong verification, we
  # ignore a weaker declared policy. This DOES NOT relax existing rules — a
  # manifest declaring sha256-required already enforces sha256-required.
  if [ "$force_mode" = "require-sha256" ]; then
    policy="sha256-required"
  fi

  if [ "$runtime" = "external-openai-compatible" ] || [ "$format" = "openai-compatible" ]; then
    return 0
  fi

  if ! manifest_files_entries "$manifest" | grep -q .; then
    echo "model manifest: model.files is required for local runtimes"
    return 1
  fi

  while IFS=$'\t' read -r file sha; do
    [ -z "$file" ] && continue
    if [ ! -f "$models_dir/$file" ]; then
      echo "model manifest: missing model file $file"
      missing=1
      continue
    fi
    case "$policy" in
      sha256-required)
        if [ -z "$sha" ]; then
          echo "model manifest: checksum_policy=sha256-required but no sha256 declared for $file"
          missing=1
          continue
        fi
        if ! printf '%s' "$sha" | grep -Eq '^[0-9a-fA-F]{64}$'; then
          echo "model manifest: invalid sha256 for $file (must be 64 hex chars)"
          missing=1
          continue
        fi
        actual="$(sha256_file "$models_dir/$file")"
        if [ "$actual" != "$sha" ]; then
          echo "model manifest: sha256 mismatch for $file"
          echo "  declared: $sha"
          echo "  actual:   $actual"
          missing=1
        fi
        ;;
      sha256-optional)
        if [ -n "$sha" ]; then
          if ! printf '%s' "$sha" | grep -Eq '^[0-9a-fA-F]{64}$'; then
            echo "model manifest: invalid sha256 for $file (must be 64 hex chars)"
            missing=1
            continue
          fi
          actual="$(sha256_file "$models_dir/$file")"
          if [ "$actual" != "$sha" ]; then
            echo "model manifest: sha256 mismatch for $file"
            echo "  declared: $sha"
            echo "  actual:   $actual"
            missing=1
          fi
        fi
        ;;
      none|external-runtime-no-model-file)
        ;;
    esac
  done < <(manifest_files_entries "$manifest")

  [ "$missing" -eq 0 ]
}

write_bundle_install_note() {
  local file="$1" slug="$2"
  cat > "$file" <<EOF
# Lucairn Customer Install: $slug

This bundle is prepared for one customer environment. Do not reuse it across customers.

## Offline Install

\`\`\`bash
docker load -i images/lucairn-images.tar
bin/lucairn bundle verify --bundle .
bin/lucairn doctor --env install/customer.env --compose install/docker-compose.customer.yml --skip-image-check
docker compose \\
  -f install/docker-compose.customer.yml \\
  -f install/docker-compose.self-hosted.yml \\
  --env-file install/customer.env \\
  --profile "\${MODEL_RUNTIME_PROFILE:-custom-runtime}" \\
  up -d
\`\`\`

## Model Runtime

The selected runtime is declared in \`models/model-manifest.yaml\`. Supported profiles are:

- \`llama-cpp\` for GGUF.
- \`vllm\` for Hugging Face safetensors / PyTorch model directories.
- \`tgi\` for Hugging Face Text Generation Inference.
- \`ollama\` for Ollama model stores or Modelfile-based packaging.
- \`onnxruntime\` for ONNX-serving containers.
- \`triton\` for TensorRT-LLM / Triton deployments.
- \`custom-runtime\` for any runtime image that exposes an OpenAI-compatible HTTP API inside the compose network.

## Support

If install fails, run:

\`\`\`bash
bin/lucairn support-bundle --env install/customer.env --compose install/docker-compose.customer.yml
\`\`\`

Review the generated archive before sending it to Lucairn support.
EOF
}

write_checksums() {
  local dir="$1"
  mkdir -p "$dir/checksums"
  : > "$dir/checksums/SHA256SUMS"
  (
    cd "$dir"
    find . -type f ! -path './checksums/SHA256SUMS' | sort | while IFS= read -r file; do
      printf '%s  %s\n' "$(sha256_file "$file")" "${file#./}"
    done > checksums/SHA256SUMS
  )
}

verify_checksums() {
  local dir="$1" sums expected path actual failed=0
  sums="$dir/checksums/SHA256SUMS"
  require_file "$sums" "checksum file"
  while read -r expected path; do
    [ -z "${expected:-}" ] && continue
    if [ ! -f "$dir/$path" ]; then
      echo "checksum verification failed: missing $path"
      failed=1
      continue
    fi
    actual="$(sha256_file "$dir/$path")"
    if [ "$actual" != "$expected" ]; then
      echo "checksum verification failed: $path"
      failed=1
    fi
  done < "$sums"
  [ "$failed" -eq 0 ]
}

bundle_create() {
  local slug="" models_dir="" manifest="" env_file="" output_dir="$ROOT/dist/customer-bundles"
  local image_tar="" images_dir="" data_dir="" base_compose="$ROOT/docker-compose.customer.yml" self_compose="$ROOT/docker-compose.self-hosted.yml"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --customer-slug) slug="$2"; shift 2 ;;
      --models-dir) models_dir="$2"; shift 2 ;;
      --model-manifest) manifest="$2"; shift 2 ;;
      --env) env_file="$2"; shift 2 ;;
      --output) output_dir="$2"; shift 2 ;;
      --image-tar) image_tar="$2"; shift 2 ;;
      --images-dir) images_dir="$2"; shift 2 ;;
      --customer-data-dir|--demo-data-dir|--data-dir) data_dir="$2"; shift 2 ;;
      --base-compose) base_compose="$2"; shift 2 ;;
      --self-hosted-compose|--compose) self_compose="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown bundle create argument: $1" ;;
    esac
  done

  [ -n "$slug" ] || fail "--customer-slug is required"
  printf '%s' "$slug" | grep -Eq '^[a-z0-9][a-z0-9-]{1,62}$' || fail "--customer-slug must be lowercase letters, numbers, and hyphens"
  [ -n "$models_dir" ] || fail "--models-dir is required"
  [ -n "$manifest" ] || fail "--model-manifest is required"
  [ -n "$env_file" ] || fail "--env is required"
  validate_model_manifest "$manifest" "$models_dir"
  require_file "$env_file" "env file"
  require_file "$base_compose" "base compose"
  require_file "$self_compose" "self-hosted compose"
  [ -z "$image_tar" ] || require_file "$image_tar" "image tar"
  [ -z "$images_dir" ] || [ -d "$images_dir" ] || fail "images dir not found: $images_dir"
  [ -z "$data_dir" ] || [ -d "$data_dir" ] || fail "customer data dir not found: $data_dir"

  local ts bundle_name staging archive
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  bundle_name="lucairn-customer-bundle-${slug}-${ts}"
  mkdir -p "$output_dir"
  staging="$output_dir/$bundle_name"
  archive="$output_dir/$bundle_name.tar.gz"
  rm -rf "$staging" "$archive"
  mkdir -p "$staging"/{bin,install,models,images,customer-data,checksums,docs,config,migrations,starter-templates}

  cp "$ROOT/bin/lucairn" "$staging/bin/lucairn"
  cp "$base_compose" "$staging/install/docker-compose.customer.yml"
  cp "$self_compose" "$staging/install/docker-compose.self-hosted.yml"
  cp "$env_file" "$staging/install/customer.env"
  cp "$manifest" "$staging/models/model-manifest.yaml"
  cp -R "$models_dir"/. "$staging/models/"
  cp "$manifest" "$staging/models/model-manifest.yaml"
  cp -R "$ROOT/config"/. "$staging/config/"
  cp -R "$ROOT/migrations"/. "$staging/migrations/"
  cp -R "$ROOT/starter-templates"/. "$staging/starter-templates/"
  cp "$ROOT/OPS.md" "$ROOT/TROUBLESHOOTING.md" "$ROOT/README.md" "$staging/docs/"
  [ -f "$ROOT/docs/CUSTOMER_BUNDLE.md" ] && cp "$ROOT/docs/CUSTOMER_BUNDLE.md" "$staging/docs/"
  write_bundle_install_note "$staging/INSTALL-CUSTOMER.md" "$slug"

  if [ -n "$image_tar" ]; then
    cp "$image_tar" "$staging/images/lucairn-images.tar"
  elif [ -n "$images_dir" ]; then
    cp -R "$images_dir"/. "$staging/images/"
  else
    echo "No image archive included. Customer install must use registry access." > "$staging/images/README.txt"
  fi

  if [ -n "$data_dir" ]; then
    cp -R "$data_dir"/. "$staging/customer-data/"
  else
    echo "No customer demo data included." > "$staging/customer-data/README.txt"
  fi

  {
    echo "customer_slug=$slug"
    echo "created_utc=$ts"
    echo "kit_version=$VERSION"
    echo "model_name=$(manifest_value "$manifest" name)"
    echo "model_format=$(manifest_value "$manifest" format)"
    echo "model_runtime=$(manifest_value "$manifest" runtime)"
    if [ -n "$data_dir" ]; then
      echo "customer_data=present"
    else
      echo "customer_data=absent"
    fi
  } > "$staging/bundle-manifest.txt"

  write_checksums "$staging"
  tar -czf "$archive" -C "$output_dir" "$bundle_name"
  echo "bundle: $archive"
}

bundle_root_from_path() {
  local bundle="$1" tmp="$2"
  if [ -d "$bundle" ]; then
    printf '%s' "$bundle"
    return 0
  fi
  require_file "$bundle" "bundle"
  mkdir -p "$tmp"
  tar -xzf "$bundle" -C "$tmp"
  find "$tmp" -maxdepth 1 -type d -name 'lucairn-customer-bundle-*' -print -quit
}

bundle_verify() {
  local bundle="" expect_slug="" max_age_days="" require_sha256=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bundle) bundle="$2"; shift 2 ;;
      --customer-slug) expect_slug="$2"; shift 2 ;;
      --max-age-days) max_age_days="$2"; shift 2 ;;
      --require-sha256) require_sha256=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown bundle verify argument: $1" ;;
    esac
  done
  [ -n "$bundle" ] || fail "--bundle is required"
  if [ -n "$max_age_days" ]; then
    printf '%s' "$max_age_days" | grep -Eq '^[0-9]+$' \
      || fail "--max-age-days must be a non-negative integer"
  fi
  if [ -n "$expect_slug" ]; then
    # B7: apply the same slug regex bundle_create uses when minting bundles, so
    # an attacker cannot smuggle a bogus expected-slug string past this gate.
    printf '%s' "$expect_slug" | grep -Eq '^[a-z0-9][a-z0-9-]{1,62}$' \
      || fail "--customer-slug must be lowercase letters, numbers, and hyphens"
  fi

  local tmp root
  tmp="$(mktemp -d)"
  root="$(bundle_root_from_path "$bundle" "$tmp")"
  if [ -z "$root" ]; then
    rm -rf "$tmp"
    fail "bundle root not found"
  fi

  require_file "$root/install/docker-compose.customer.yml" "bundle base compose"
  require_file "$root/install/docker-compose.self-hosted.yml" "bundle self-hosted compose"
  require_file "$root/install/customer.env" "bundle customer env"
  require_file "$root/models/model-manifest.yaml" "bundle model manifest"
  require_file "$root/bin/lucairn" "bundle CLI"
  if [ "$require_sha256" -eq 1 ]; then
    validate_model_manifest "$root/models/model-manifest.yaml" "$root/models" "require-sha256"
  else
    validate_model_manifest "$root/models/model-manifest.yaml" "$root/models"
  fi
  verify_checksums "$root"

  if [ -n "$expect_slug" ] || [ -n "$max_age_days" ]; then
    require_file "$root/bundle-manifest.txt" "bundle manifest"
  fi

  # B3: replay-guard hardening. The manifest must declare exactly one
  # customer_slug= and one created_utc= line. Without this, an attacker could
  # append a duplicated line targeting a different victim and re-hash
  # SHA256SUMS — `tail -1` then silently selects the doctored line and the
  # cross-customer replay check passes.
  if [ -n "$expect_slug" ]; then
    local slug_count
    slug_count="$(grep -cE '^customer_slug=' "$root/bundle-manifest.txt" || true)"
    if [ "$slug_count" != "1" ]; then
      rm -rf "$tmp"
      fail "bundle-manifest.txt has $slug_count customer_slug= lines (expected exactly 1)"
    fi
    local actual_slug
    actual_slug="$(grep -E '^customer_slug=' "$root/bundle-manifest.txt" | cut -d= -f2-)"
    if [ "$actual_slug" != "$expect_slug" ]; then
      rm -rf "$tmp"
      fail "bundle customer_slug mismatch: expected '$expect_slug', got '$actual_slug'"
    fi
  fi

  if [ -n "$max_age_days" ]; then
    local ts_count created_utc created_epoch now_epoch age_seconds max_age_seconds
    ts_count="$(grep -cE '^created_utc=' "$root/bundle-manifest.txt" || true)"
    if [ "$ts_count" != "1" ]; then
      rm -rf "$tmp"
      fail "bundle-manifest.txt has $ts_count created_utc= lines (expected exactly 1)"
    fi
    created_utc="$(grep -E '^created_utc=' "$root/bundle-manifest.txt" | cut -d= -f2-)"
    [ -n "$created_utc" ] || { rm -rf "$tmp"; fail "bundle-manifest.txt missing created_utc"; }
    # B5: strip whitespace + pre-check the format with a regex so ambiguous or
    # space-padded values fail with a clear error rather than tripping
    # strptime's "is not a recognised timestamp" later.
    created_epoch="$(python3 - "$created_utc" <<'PY' 2>/dev/null || true
import sys, datetime, re
ts = sys.argv[1].strip()
if not re.fullmatch(r"\d{8}T\d{6}Z", ts):
    sys.exit(0)
try:
    dt = datetime.datetime.strptime(ts, "%Y%m%dT%H%M%SZ").replace(tzinfo=datetime.timezone.utc)
    print(int(dt.timestamp()))
except Exception:
    pass
PY
)"
    [ -n "$created_epoch" ] || { rm -rf "$tmp"; fail "bundle created_utc '$created_utc' is not a recognised timestamp"; }
    now_epoch="$(date -u +%s)"
    age_seconds=$(( now_epoch - created_epoch ))
    # B8: a future-dated bundle is either clock skew or tamper. Either way it
    # is not a state the gate should silently allow under `--max-age-days`.
    if [ "$age_seconds" -lt 0 ]; then
      rm -rf "$tmp"
      fail "bundle created_utc '$created_utc' is in the future ($(( -age_seconds )) seconds): clock skew or tamper"
    fi
    max_age_seconds=$(( max_age_days * 86400 ))
    if [ "$age_seconds" -gt "$max_age_seconds" ]; then
      rm -rf "$tmp"
      fail "bundle is $((age_seconds / 86400)) days old (max allowed: $max_age_days)"
    fi
  fi

  rm -rf "$tmp"
  echo "bundle verify: ok"
}

write_bundle_prepare_report() {
  local report="$1" slug="$2" staging_dir="$3" archive="$4" manifest="$5" env_file="$6"
  local image_delivery="$7" base_compose="$8" self_compose="$9"
  local customer_data="${10}"
  local ts
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  {
    echo "agent_contract=lucairn-customer-package-v1"
    echo "customer_slug=$slug"
    echo "prepared_utc=$ts"
    echo "kit_version=$VERSION"
    echo "bundle_path=$archive"
    echo "bundle_sha256=$(sha256_file "$archive")"
    echo "bundle_verify=ok"
    echo "customer_env=present"
    echo "model_name=$(manifest_value "$manifest" name)"
    echo "model_format=$(manifest_value "$manifest" format)"
    echo "model_runtime=$(manifest_value "$manifest" runtime)"
    echo "image_delivery=$image_delivery"
    echo "customer_data=$customer_data"
    echo "base_compose=$base_compose"
    echo "self_hosted_compose=$self_compose"
    echo "staging_dir=$staging_dir"
    echo "human_review_required=true"
    echo "customer_files_committed_to_git=false"
  } > "$report"
}

bundle_prepare() {
  local slug="" staging_dir="" output_dir="$ROOT/dist/customer-bundles" report_file=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --customer-slug) slug="$2"; shift 2 ;;
      --staging-dir) staging_dir="$2"; shift 2 ;;
      --output) output_dir="$2"; shift 2 ;;
      --report) report_file="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown bundle prepare argument: $1" ;;
    esac
  done

  [ -n "$slug" ] || fail "--customer-slug is required"
  [ -n "$staging_dir" ] || fail "--staging-dir is required"
  [ -d "$staging_dir" ] || fail "staging dir not found: $staging_dir"

  local env_file models_dir manifest image_tar images_dir data_dir image_delivery customer_data base_compose self_compose
  env_file="$staging_dir/customer.env"
  models_dir="$staging_dir/models"
  manifest="$models_dir/model-manifest.yaml"
  image_tar=""
  images_dir=""
  data_dir=""
  image_delivery="registry"
  customer_data="absent"
  base_compose="$ROOT/docker-compose.customer.yml"
  self_compose="$ROOT/docker-compose.self-hosted.yml"

  [ -f "$staging_dir/install/docker-compose.customer.yml" ] && base_compose="$staging_dir/install/docker-compose.customer.yml"
  [ -f "$staging_dir/install/docker-compose.self-hosted.yml" ] && self_compose="$staging_dir/install/docker-compose.self-hosted.yml"

  if [ -f "$staging_dir/images/lucairn-images.tar" ]; then
    image_tar="$staging_dir/images/lucairn-images.tar"
    image_delivery="archive"
  elif dir_has_payload_files "$staging_dir/images"; then
    images_dir="$staging_dir/images"
    image_delivery="directory"
  fi

  # B6: "non-empty" means "contains at least one real candidate file" —
  # exclude the product sentinel `README.txt` (bundle_create writes this when
  # no data dir was supplied) and any hidden dotfile (.gitkeep, .DS_Store, …).
  # Otherwise extracting a previous bundle next to a separately-staged
  # demo-data/ produces a false-positive "ambiguous" failure.
  local data_candidates=() data_real_files=() candidate file
  for candidate in customer-data demo-data data; do
    if [ ! -d "$staging_dir/$candidate" ]; then
      continue
    fi
    # Collect non-sentinel non-dotfile entries. Dotfiles match files whose
    # basename starts with a dot at any depth (find's -name acts on basename).
    local found_files
    found_files="$(find "$staging_dir/$candidate" -mindepth 1 -type f \
        ! -name 'README.txt' ! -name '.*' \
        -print 2>/dev/null || true)"
    if [ -n "$found_files" ]; then
      data_candidates+=("$staging_dir/$candidate")
      data_real_files+=("$found_files")
    fi
  done
  if [ "${#data_candidates[@]}" -gt 1 ]; then
    echo "bundle prepare: ambiguous data staging — multiple non-empty data dirs found:" >&2
    local i=0
    for candidate in "${data_candidates[@]}"; do
      echo "  - $candidate" >&2
      # List ONLY real candidate files (sentinel + dotfiles already filtered).
      while IFS= read -r file; do
        [ -z "$file" ] && continue
        echo "      $file" >&2
      done <<< "${data_real_files[$i]}"
      i=$(( i + 1 ))
    done
    fail "remove the unwanted directories so only one of customer-data/, demo-data/, or data/ contains real files"
  fi
  if [ "${#data_candidates[@]}" -eq 1 ]; then
    data_dir="${data_candidates[0]}"
    customer_data="present"
    echo "selected staging dir: $data_dir"
  fi

  require_file "$env_file" "staged customer env"
  require_file "$manifest" "staged model manifest"
  validate_model_manifest "$manifest" "$models_dir"

  mkdir -p "$output_dir"
  report_file="${report_file:-$output_dir/lucairn-customer-bundle-${slug}-report.txt}"

  local create_args create_output archive verify_output
  create_args=(
    --customer-slug "$slug"
    --models-dir "$models_dir"
    --model-manifest "$manifest"
    --env "$env_file"
    --output "$output_dir"
    --base-compose "$base_compose"
    --self-hosted-compose "$self_compose"
  )
  if [ -n "$data_dir" ]; then
    create_args+=(--customer-data-dir "$data_dir")
  fi
  if [ -n "$image_tar" ]; then
    create_args+=(--image-tar "$image_tar")
  elif [ -n "$images_dir" ]; then
    create_args+=(--images-dir "$images_dir")
  fi

  create_output="$(bundle_create "${create_args[@]}")"
  echo "$create_output"
  archive="$(printf '%s\n' "$create_output" | awk '/^bundle: / {print $2; exit}')"
  [ -n "$archive" ] || fail "bundle prepare could not resolve archive path"

  # B2: prepare's internal verify defaults to the strongest mode so the
  # operator gate matches the receiver gate (CUSTOMER_HANDOFF_GATES.md).
  if ! verify_output="$(bundle_verify --bundle "$archive" --require-sha256 2>&1)"; then
    echo "$verify_output" >&2
    fail "bundle prepare verification failed"
  fi
  echo "$verify_output"

  write_bundle_prepare_report "$report_file" "$slug" "$staging_dir" "$archive" "$manifest" "$env_file" "$image_delivery" "$base_compose" "$self_compose" "$customer_data"
  echo "agent report: $report_file"
}

bundle_command() {
  local subcmd="${1:-}"
  case "$subcmd" in
    create) shift; bundle_create "$@" ;;
    prepare) shift; bundle_prepare "$@" ;;
    verify) shift; bundle_verify "$@" ;;
    -h|--help|"") usage ;;
    *) fail "unknown bundle subcommand: $subcmd" ;;
  esac
}

doctor() {
  local env_file="" compose_file="" offline=0 postgres_url="" kube_namespace="dsa-system" check_images=1 strict_runtime=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --env) env_file="$2"; shift 2 ;;
      --compose) compose_file="$2"; shift 2 ;;
      --offline) offline=1; check_images=0; shift ;;
      --check-images) check_images=1; shift ;;
      --skip-image-check) check_images=0; shift ;;
      --postgres-url) postgres_url="$2"; shift 2 ;;
      --kube-namespace) kube_namespace="$2"; shift 2 ;;
      --strict-runtime) strict_runtime=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown doctor argument: $1" ;;
    esac
  done

  env_file="${env_file:-$ROOT/customer.env}"
  compose_file="${compose_file:-$ROOT/docker-compose.customer.yml}"

  require_file "$env_file" "env file"
  require_file "$compose_file" "compose file"

  echo "lucairn doctor $VERSION"
  echo "env file: ok ($env_file)"
  echo "compose file: ok ($compose_file)"

  if require_env_values "$env_file"; then
    echo "required secrets: ok"
  else
    return 1
  fi

  # Reject any required secret still set to a placeholder. Runs before the
  # hex/base64 format checks so the operator sees the actionable
  # "still set to a placeholder" error instead of the misleading
  # "must be 64 hex chars" error.
  #
  # Self-hosted-mode carve-out: when SANDBOX_B_REMOTE_ENDPOINT is empty, the
  # operator is on the local-sandbox-b overlay (per INSTALL.md "Choose A
  # Deployment Mode" table). In that mode the SANDBOX_B_* + VEIL_SANDBOX_B_*
  # slots are unused (the local container generates its own keypair at
  # startup); leaving them as REPLACE_WITH_* / REPLACE_ME_* is the
  # documented default for self-hosted installs. Mirrors the certification-
  # profile carve-out below.
  local remote_endpoint
  remote_endpoint="$(env_value "$env_file" SANDBOX_B_REMOTE_ENDPOINT)"
  local placeholder_failed=0
  local placeholder_keys=(
    DSA_SERVICE_TOKEN DSA_BRIDGE_ENCRYPTION_KEY SANDBOX_A_ENCRYPTION_KEY
    BRIDGE_MASTER_KEY DSA_ADMIN_KEY GATEWAY_KEYSTORE_KEY
    GATEWAY_BASE_URL
    VEIL_AUDIT_SIGNING_KEY VEIL_BRIDGE_SIGNING_KEY VEIL_SANITIZER_SIGNING_KEY
    VEIL_WITNESS_SIGNING_KEY VEIL_GATEWAY_SIGNING_KEY VEIL_MANIFEST_SIGNING_KEY
    VEIL_WITNESS_PUBLIC_KEY VEIL_BRIDGE_PUBLIC_KEY VEIL_SANITIZER_PUBLIC_KEY
    VEIL_AUDIT_PUBLIC_KEY VEIL_GATEWAY_PUBLIC_KEY
    POSTGRES_AUDIT_PASSWORD POSTGRES_BRIDGE_PASSWORD
    POSTGRES_SANDBOX_A_PASSWORD POSTGRES_VEIL_PASSWORD
    AUDIT_APP_PASSWORD VEIL_APP_PASSWORD
    CANARY_HMAC_KEY
  )
  # License keys: only check placeholder when the operator left them set
  # (both must be non-empty in production; both empty = dev mode handled in
  # require_env_values above).
  local lic_key_val
  lic_key_val="$(env_value "$env_file" DSA_LICENSE_KEY)"
  if [ -n "$lic_key_val" ]; then
    placeholder_keys+=(DSA_LICENSE_KEY DSA_LICENSE_SIGNING_KEY)
  fi
  # Sandbox B keypair placement (mode-dependent):
  #
  # - Split deployment (SANDBOX_B_REMOTE_ENDPOINT set):
  #   * SANDBOX_B_API_KEY:           Lucairn-provided
  #   * VEIL_SANDBOX_B_PUBLIC_KEY:   Lucairn-provided (matches Lucairn-hosted SB signing key)
  #   * VEIL_SANDBOX_B_SIGNING_KEY:  not used on customer side (lives on Lucairn SB fleet)
  #
  # - Self-hosted (SANDBOX_B_REMOTE_ENDPOINT empty):
  #   * SANDBOX_B_API_KEY:           not used; sandbox-b reads LOCAL_SANDBOX_B_API_KEY
  #                                  from the self-hosted overlay (which has its own
  #                                  default), so the example placeholder is harmless.
  #   * VEIL_SANDBOX_B_PUBLIC_KEY:   operator-generated (witness reads this; MUST be
  #                                  the derived public key for the SIGNING key below)
  #   * VEIL_SANDBOX_B_SIGNING_KEY:  operator-generated (sandbox-b uses this to sign
  #                                  CLAIM_TYPE_INFERENCE_GENERATED; required at boot
  #                                  via :? enforcement in docker-compose.self-hosted.yml)
  #
  # Therefore SANDBOX_B_API_KEY may stay at its example placeholder in self-hosted
  # mode (and is only validated when split-deployment makes it load-bearing), but
  # the SB keypair MUST be operator-generated and pass placeholder + hex64 checks
  # in BOTH modes.
  if [ -n "$remote_endpoint" ]; then
    placeholder_keys+=(SANDBOX_B_API_KEY)
  fi
  placeholder_keys+=(
    VEIL_SANDBOX_B_PUBLIC_KEY
    VEIL_SANDBOX_B_SIGNING_KEY
  )
  for key in "${placeholder_keys[@]}"; do
    validate_no_placeholder "$env_file" "$key" || placeholder_failed=1
  done
  # Certification-profile placeholders (BUILD_AUTH_TOKEN, CUSTOMER_KEY_ID,
  # PORTAL_API_KEY) are NOT checked here because the certification profile
  # is opt-in (`--profile certification`); leaving them as REPLACE_WITH_*
  # is the documented default for non-certification installs.
  [ "$placeholder_failed" -eq 0 ] || return 1
  echo "placeholder values: ok"

  local format_failed=0
  local hex64_keys=(
    DSA_SERVICE_TOKEN DSA_BRIDGE_ENCRYPTION_KEY SANDBOX_A_ENCRYPTION_KEY
    BRIDGE_MASTER_KEY DSA_ADMIN_KEY VEIL_AUDIT_SIGNING_KEY
    VEIL_BRIDGE_SIGNING_KEY VEIL_SANITIZER_SIGNING_KEY VEIL_WITNESS_SIGNING_KEY
    VEIL_GATEWAY_SIGNING_KEY VEIL_MANIFEST_SIGNING_KEY VEIL_WITNESS_PUBLIC_KEY
    VEIL_BRIDGE_PUBLIC_KEY VEIL_SANITIZER_PUBLIC_KEY VEIL_AUDIT_PUBLIC_KEY
  )
  # VEIL_SANDBOX_B_PUBLIC_KEY: hex64 in BOTH modes. Split deployment gets
  # the value from Lucairn; self-hosted gets it from the operator's
  # `scripts/derive-veil-pubkey.sh "$VEIL_SANDBOX_B_SIGNING_KEY"` output
  # (per the corrected step 4a table in INSTALL.md).
  # VEIL_SANDBOX_B_SIGNING_KEY: sandbox-b parses it as hex at boot — a
  # non-hex 64-char value (e.g. base64 from `openssl rand -base64 48`)
  # crashloops sandbox-b with `encoding/hex decode failed`. Wave-5: add it
  # to the hex64 set so doctor catches it pre-flight.
  hex64_keys+=(VEIL_SANDBOX_B_PUBLIC_KEY VEIL_SANDBOX_B_SIGNING_KEY)
  for key in "${hex64_keys[@]}"; do
    validate_hex64 "$env_file" "$key" || format_failed=1
  done
  validate_keystore_key "$env_file" || format_failed=1
  check_canary_hmac_key_length "$env_file" || format_failed=1
  [ "$format_failed" -eq 0 ] || return 1
  echo "secret formats: ok"

  # Sim 3 G10: ed25519 pair coherence. Operators who paste a pubkey
  # from one ceremony + a signing key from another get a doctor-PASS
  # install with broken cert verification; runs the derive script.
  local pair_failed=0
  check_veil_keypairs "$env_file" || pair_failed=1
  if [ "$pair_failed" -eq 0 ]; then
    echo "veil keypairs: ok (derived pubkeys match claimed)"
  else
    return 1
  fi

  # Sim 3 G6: reject known dual-sandbox dev-default literals in prod.
  local dev_default_failed=0
  check_no_dev_default_keys "$env_file" || dev_default_failed=1
  [ "$dev_default_failed" -eq 0 ] || return 1

  # Sim 3 G1: pre-flight render-migrations.sh input contract.
  local migration_failed=0
  check_render_migrations_safe "$env_file" || migration_failed=1
  [ "$migration_failed" -eq 0 ] || return 1

  # Sim 3 G3: LUCAIRN_IMAGE_TAG must be set explicitly.
  local tag_failed=0
  check_image_tag_set "$env_file" || tag_failed=1
  [ "$tag_failed" -eq 0 ] || return 1

  # Sim 3 G7: self-hosted SB API key not the well-known fallback.
  local sb_key_failed=0
  check_local_sandbox_b_api_key "$env_file" || sb_key_failed=1
  [ "$sb_key_failed" -eq 0 ] || return 1

  # SEC-01 (hardening 2026-05-28): Postgres + app-role passwords must be
  # non-empty, non-weak-literal, and ≥ 12 chars in production (the weak
  # `:-dsa`/`:-veil`/`:-*_app_password` compose fallbacks are being removed in
  # favour of `${VAR:?...}` fail-fast).
  local pg_pw_failed=0
  check_postgres_passwords "$env_file" || pg_pw_failed=1
  [ "$pg_pw_failed" -eq 0 ] || return 1

  # Sim 3 G9: production GATEWAY_BASE_URL must be https.
  local url_failed=0
  check_gateway_base_url_https "$env_file" || url_failed=1
  [ "$url_failed" -eq 0 ] || return 1

  # Wave-5 NEW-4: production LUCAIRN_RESOURCE_BASE_URL must be https
  # (silent gap — passes doctor today, breaks downstream verifiers).
  local resource_url_failed=0
  check_lucairn_resource_base_url_https "$env_file" || resource_url_failed=1
  [ "$resource_url_failed" -eq 0 ] || return 1

  # Sim 3 G4: BYOK overlay's dsa-egress network must not be internal:true.
  local egress_failed=0
  check_byok_egress_open "$env_file" || egress_failed=1
  [ "$egress_failed" -eq 0 ] || return 1

  # Sim 3 round-2 G2-CLOSE: image-tag vs sanitizer_config_compat.
  local compat_failed=0
  check_sanitizer_config_image_compat "$env_file" || compat_failed=1
  [ "$compat_failed" -eq 0 ] || return 1

  # Sim 3 round-2 NEW-1: INSECURE_DEV_MODE incompatible with prod.
  local insecure_failed=0
  check_insecure_dev_mode_off_in_prod "$env_file" || insecure_failed=1
  [ "$insecure_failed" -eq 0 ] || return 1

  # Sim 3 round-2 NEW-2: VEIL_REKOR_URL required in prod (unless dev-mode).
  local rekor_failed=0
  check_veil_rekor_url_in_prod "$env_file" || rekor_failed=1
  [ "$rekor_failed" -eq 0 ] || return 1

  # Wave-5 NEW-5: VEIL_TSA_URL required in prod (parallel to NEW-2; PR #105
  # dual-sandbox enforcement). Crashloop gap — witness fail-fasts at boot.
  local tsa_failed=0
  check_veil_tsa_url_in_prod "$env_file" || tsa_failed=1
  [ "$tsa_failed" -eq 0 ] || return 1

  # Sim 3 round-2 NEW-3: Sandbox-B remote scheme + cert-triple coherence.
  local sb_remote_failed=0
  check_sandbox_b_remote_coherent "$env_file" || sb_remote_failed=1
  [ "$sb_remote_failed" -eq 0 ] || return 1

  check_certs "$env_file"

  # Dev-mode-env consistency check. Catches the "production-defaults
  # vs dev install" foot-gun Sim 3 final-smoothing hit three times:
  # `customer.env.example` ships DSA_ENV=production + GRPC_TLS_ENABLED=true
  # so production installs are safe by default, but local-laptop / sandbox
  # installs that leave those defaults intact without provisioning real
  # mTLS material crash sandbox-b at boot (`CRITICAL ... refusing insecure
  # port`) or surface as gateway sandbox_b health-check TLS-handshake
  # errors. This check warns operators of the inconsistency before
  # compose-up so they hit the actionable troubleshooting entry rather
  # than the cryptic runtime log.
  check_dev_mode_consistency "$env_file"

  # BYOK overlay check (self-hosted + managed-LLM mode). Informational +
  # enforces that at least one provider key is present when the allowlist
  # is set. Skipped silently when the operator is not using the overlay.
  check_byok_overlay "$env_file" || return 1

  # Identity-plane network lockdown check. Sandbox A holds the raw-PII-to-
  # pseudonym mapping; the identity-plane bridges (dsa-identity,
  # dsa-audit-identity, dsa-certification) MUST be internal:true so the
  # network layer enforces "no raw identity data leaves your environment"
  # as defence-in-depth on top of code-level air-tightness.
  check_identity_networks_internal "$compose_file" || return 1

  # Image-manifest drift warning. Runs in --offline mode as well so customers
  # without network egress still get the warning.
  check_image_manifest "$env_file"

  if [ "$check_images" -eq 1 ]; then
    check_container_images "$env_file" || return 1
  fi

  # Slice 1: dashboard pre-flight. Runs in BOTH --offline and live paths
  # so the doctor surfaces dashboard misconfiguration even when network
  # checks are skipped. Non-fatal when the dashboard is not opted-in;
  # fatal when the bootstrap secret is missing/short and the operator
  # has explicitly opted in.
  check_dashboard "$env_file" || return 1

  if [ "$offline" -eq 1 ]; then
    echo "network checks: skipped (--offline)"
    echo "docker compose: skipped (--offline)"
    echo "postgres: skipped (--offline)"
    echo "network policies: skipped (--offline)"
    echo "doctor: ok"
    return 0
  fi

  local gateway_url host port
  gateway_url="$(env_value "$env_file" GATEWAY_BASE_URL)"
  host="$(url_host "$gateway_url")"
  port="$(url_port "$gateway_url")"
  if check_dns "$host"; then
    echo "dns: ok ($host)"
  else
    echo "dns: failed ($host)"
    return 1
  fi

  local gateway_port
  gateway_port="$(env_value "$env_file" GATEWAY_PORT)"
  gateway_port="${gateway_port:-8080}"
  if check_local_port_available "$gateway_port"; then
    echo "ports: ok (host port $gateway_port available)"
  else
    echo "ports: failed (host port $gateway_port already has a listener)"
    return 1
  fi

  local compose
  compose="$(compose_cmd)"
  if [ -n "$compose" ]; then
    if $compose -f "$compose_file" --env-file "$env_file" config --quiet; then
      echo "docker compose: ok"
    else
      echo "docker compose: config failed"
      return 1
    fi
  else
    warn "docker compose not available; skipping compose config validation"
  fi

  postgres_url="${postgres_url:-$(env_value "$env_file" POSTGRES_URL)}"
  if [ -n "$postgres_url" ] && have pg_isready; then
    if pg_isready -d "$postgres_url" >/dev/null 2>&1; then
      echo "postgres: ok"
    else
      echo "postgres: failed"
      return 1
    fi
  else
    echo "postgres: skipped (no --postgres-url or pg_isready unavailable)"
  fi

  if have kubectl; then
    if kubectl get networkpolicy -n "$kube_namespace" >/dev/null 2>&1; then
      echo "network policies: ok ($kube_namespace)"
    else
      echo "network policies: not found or cluster unavailable ($kube_namespace)"
    fi

    # SEC-08 (hardening 2026-05-28): k8s-native Secrets are base64-ENCODED,
    # not encrypted. They are readable by anyone with `get secret` RBAC and,
    # unless the cluster operator has enabled etcd encryption-at-rest (the
    # operator's responsibility, which this kit cannot verify), they sit in
    # etcd in cleartext. For production, recommend the chart's External
    # Secrets Operator (ESO) backend so the signing seeds / keystore key / DB
    # passwords live in a real secrets manager (HashiCorp Vault, AWS Secrets
    # Manager, or Azure Key Vault) and are only materialised into the
    # namespace at runtime. This is INFO-level (advisory) — it never fails
    # the doctor — because the default k8s-native path is a supported
    # configuration when etcd encryption + tight RBAC are in place.
    info "secrets backend (k8s): INFO — Helm default is secrets.backend=k8s-native (base64 Secrets, NOT encryption)."
    info "  For production, set secrets.backend=vault|aws|azure (External Secrets Operator) so secrets live"
    info "  in a real secrets manager, OR ensure etcd encryption-at-rest + strict 'get secret' RBAC are enabled."
    info "  See INSTALL.md § 'Production secrets: External Secrets Operator (ESO)'."
  else
    echo "network policies: skipped (kubectl unavailable)"
  fi

  # Post-deploy liveness + readiness probe. Sim 2 M4 surfaced that a doctor PASS
  # is not sufficient evidence the gateway can actually serve traffic: the gateway
  # can be `(healthy)` per its Docker healthcheck (curl /healthz returns 200) while
  # /readyz returns 503 because an upstream service-link breaker is open. Operators
  # who relied on `doctor` + `docker compose ps` reported the stack as "deployed"
  # and only discovered the missing inference path at first real request.
  #
  # This block is non-fatal by default: if the gateway is not running yet (which
  # is the normal state during initial install — doctor is supposed to run BEFORE
  # `docker compose up -d`), the probes time out and we report `not started`
  # without failing the doctor exit. Use --strict-runtime to fail-closed.
  local gateway_health_port gateway_health_base runtime_failed=0
  gateway_health_port="$(env_value "$env_file" GATEWAY_HEALTH_PORT)"
  gateway_health_port="${gateway_health_port:-8085}"
  gateway_health_base="http://127.0.0.1:${gateway_health_port}"

  if have curl; then
    local healthz_code readyz_code curl_args
    curl_args="-sS -o /dev/null -w %{http_code} --max-time 3"
    healthz_code="$(curl $curl_args "${gateway_health_base}/healthz" 2>/dev/null || true)"
    readyz_code="$(curl $curl_args "${gateway_health_base}/readyz" 2>/dev/null || true)"

    if [ -z "$healthz_code" ] || [ "$healthz_code" = "000" ]; then
      echo "gateway healthz: not started (no listener on :${gateway_health_port})"
      echo "gateway readyz: not started (no listener on :${gateway_health_port})"
      [ "$strict_runtime" -eq 1 ] && runtime_failed=1
    else
      if [ "$healthz_code" = "200" ]; then
        echo "gateway healthz: ok (200)"
      else
        echo "gateway healthz: failed ($healthz_code)"
        runtime_failed=1
      fi

      if [ "$readyz_code" = "200" ]; then
        echo "gateway readyz: ok (200)"
      elif [ "$readyz_code" = "503" ]; then
        # 503 from /readyz typically means at least one service-link circuit
        # breaker is open. Inference is the common culprit on a fresh deploy
        # because SANDBOX_B_REMOTE_ENDPOINT defaults to a placeholder and split
        # deployments require a Lucairn-provisioned remote endpoint. Surface
        # this distinctly so the operator does not mistake a 503 readyz for a
        # generic doctor failure.
        echo "gateway readyz: failed (503 — at least one service-link unavailable; inference path commonly missing on a fresh deploy)"
        echo "  Run: $compose -f $compose_file --env-file $env_file logs --tail 50 gateway"
        echo "  Then: curl -fsS ${gateway_health_base}/healthz to inspect circuit_breakers map"
        runtime_failed=1
      else
        echo "gateway readyz: failed ($readyz_code)"
        runtime_failed=1
      fi
    fi
  else
    echo "gateway runtime probes: skipped (curl unavailable)"
  fi

  if [ "$strict_runtime" -eq 1 ] && [ "$runtime_failed" -eq 1 ]; then
    fail "runtime probes failed and --strict-runtime is set"
  fi

  echo "doctor: ok"
}

write_cert_report() {
  local env_file="$1" out="$2" key path
  : > "$out"
  for key in SANDBOX_B_CLIENT_CERT SANDBOX_B_CA_CERT GRPC_TLS_CERT_FILE WITNESS_MTLS_CA_BUNDLE_PATH WITNESS_MTLS_GATEWAY_CLIENT_CERT_PATH; do
    path="$(env_value "$env_file" "$key")"
    [ -z "$path" ] && continue
    if [ -f "$path" ]; then
      {
        echo "$key=$path"
        openssl x509 -noout -subject -issuer -dates -in "$path" 2>/dev/null || true
        echo
      } >> "$out"
    else
      echo "$key=$path (missing)" >> "$out"
    fi
  done
  if [ ! -s "$out" ]; then
    echo "No external certificate paths were configured in the env file." > "$out"
  fi
}

support_bundle() {
  local env_file="" compose_file="" output_dir="" offline=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --env) env_file="$2"; shift 2 ;;
      --compose) compose_file="$2"; shift 2 ;;
      --output) output_dir="$2"; shift 2 ;;
      --offline) offline=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) fail "unknown support-bundle argument: $1" ;;
    esac
  done

  env_file="${env_file:-$ROOT/customer.env}"
  compose_file="${compose_file:-$ROOT/docker-compose.customer.yml}"
  output_dir="${output_dir:-$ROOT/support-bundles}"

  require_file "$env_file" "env file"
  require_file "$compose_file" "compose file"
  mkdir -p "$output_dir"

  local ts bundle_dir archive compose
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  bundle_dir="$output_dir/lucairn-support-bundle-$ts"
  archive="$bundle_dir.tar.gz"
  mkdir -p "$bundle_dir"/{redacted,docker,logs,certs,postgres}

  {
    echo "Lucairn support bundle"
    echo "Generated: $ts"
    echo "Kit version: $VERSION"
    echo "Host: $(hostname 2>/dev/null || echo unknown)"
    echo "Kernel: $(uname -a 2>/dev/null || echo unknown)"
    echo
    echo "Customer review required before sending this bundle to Lucairn support."
  } > "$bundle_dir/README.txt"

  {
    echo "version=$VERSION"
    echo "generated_utc=$ts"
  } > "$bundle_dir/version.txt"

  redact_stream < "$env_file" > "$bundle_dir/redacted/customer.env"
  redact_stream < "$compose_file" > "$bundle_dir/redacted/docker-compose.customer.yml"
  write_cert_report "$env_file" "$bundle_dir/certs/cert-validity.txt"

  if [ "$offline" -eq 1 ]; then
    echo "offline mode: docker status not collected" > "$bundle_dir/docker/status.txt"
    echo "offline mode: logs not collected" > "$bundle_dir/logs/compose.log"
    echo "offline mode: postgres schema version not collected" > "$bundle_dir/postgres/schema-version.txt"
  else
    compose="$(compose_cmd)"
    if [ -n "$compose" ]; then
      ($compose -f "$compose_file" --env-file "$env_file" ps 2>&1 || true) | redact_stream > "$bundle_dir/docker/compose-ps.txt"
      (docker ps --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}' 2>&1 || true) | redact_stream > "$bundle_dir/docker/status.txt"
      ($compose -f "$compose_file" --env-file "$env_file" logs --tail 300 --no-color 2>&1 || true) | redact_stream > "$bundle_dir/logs/compose.log"
      ($compose -f "$compose_file" --env-file "$env_file" config 2>&1 || true) | redact_stream > "$bundle_dir/redacted/compose-resolved.yml"
    else
      echo "docker compose unavailable" > "$bundle_dir/docker/status.txt"
      echo "docker compose unavailable" > "$bundle_dir/logs/compose.log"
    fi
    echo "Collect schema version manually if Postgres is external: SELECT version FROM schema_migrations ORDER BY version;" > "$bundle_dir/postgres/schema-version.txt"
  fi

  tar -czf "$archive" -C "$output_dir" "$(basename "$bundle_dir")"
  rm -rf "$bundle_dir"
  echo "support bundle: $archive"
}

# ---------------------------------------------------------------------------
# Compose-path compliance-DB backup / restore (WS-2 / HA-01).
# ---------------------------------------------------------------------------
#
# The Helm path ships CronJobs (charts/lucairn/templates/backup-cronjobs.yaml).
# The Compose path gets `lucairn backup` / `lucairn restore` wrappers that run
# the SAME pipeline: pg_dump -Fc -> client-side encrypt with age -> upload to
# the configured S3-compatible bucket (backup), and download -> decrypt ->
# pg_restore into a fresh DB (restore). `lucairn backup --verify` does a
# restore-into-throwaway smoke against a scratch Postgres container.
#
# Config is read from the customer.env file (--env):
#   LUCAIRN_BACKUP_S3_BUCKET      (required) destination bucket
#   LUCAIRN_BACKUP_S3_ENDPOINT    (optional) S3 endpoint for Hetzner/MinIO
#   LUCAIRN_BACKUP_S3_REGION      (optional, default eu-central-1)
#   LUCAIRN_BACKUP_S3_PREFIX      (optional) key prefix inside the bucket
#   LUCAIRN_BACKUP_AGE_RECIPIENT  (required for backup) age public key (age1...)
#   LUCAIRN_BACKUP_AGE_IDENTITY_FILE (required for restore/--verify) path to
#                                 the age private identity, held OUTSIDE the host
#   LUCAIRN_BACKUP_RETENTION_DAYS (optional, default 30)
# S3 credentials use the standard AWS resolution (env AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY, ~/.aws/credentials, or instance role) — never read
# from customer.env so they never land in the support bundle.
#
# The three compliance DBs (compose service:db:user):
#   postgres-audit:audit:dsa   postgres-bridge:bridge:dsa   postgres-veil:veil:veil
LUCAIRN_BACKUP_DBS="postgres-audit:audit:dsa postgres-bridge:bridge:dsa postgres-veil:veil:veil"

backup_require_tools() {
  have age || fail "age not found — install age (https://github.com/FiloSottile/age) for client-side backup encryption"
  have aws || fail "aws CLI not found — install awscli for S3 upload/download"
}

backup_aws_args() {
  # Emit the --endpoint-url flag (if any) on stdout for the caller to expand.
  local endpoint="$1"
  [ -n "$endpoint" ] && printf -- '--endpoint-url %s' "$endpoint" || true
}

# lucairn backup --env customer.env [--compose FILE] [--verify]
backup() {
  local env_file="" compose_file="$ROOT/docker-compose.customer.yml" do_verify=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --env) env_file="$2"; shift 2 ;;
      --compose) compose_file="$2"; shift 2 ;;
      --verify) do_verify=1; shift ;;
      -h|--help) usage; return 0 ;;
      *) fail "backup: unknown option: $1" ;;
    esac
  done
  [ -n "$env_file" ] || fail "backup: --env customer.env is required"
  require_file "$env_file" "env file"
  backup_require_tools

  local dc; dc="$(compose_cmd)"
  [ -n "$dc" ] || fail "docker compose not available"

  local bucket endpoint region prefix recipient retention
  bucket="$(env_value "$env_file" LUCAIRN_BACKUP_S3_BUCKET)"
  endpoint="$(env_value "$env_file" LUCAIRN_BACKUP_S3_ENDPOINT)"
  region="$(env_value "$env_file" LUCAIRN_BACKUP_S3_REGION)"; [ -n "$region" ] || region="eu-central-1"
  prefix="$(env_value "$env_file" LUCAIRN_BACKUP_S3_PREFIX)"
  recipient="$(env_value "$env_file" LUCAIRN_BACKUP_AGE_RECIPIENT)"
  retention="$(env_value "$env_file" LUCAIRN_BACKUP_RETENTION_DAYS)"; [ -n "$retention" ] || retention="30"

  [ -n "$bucket" ] || fail "backup: LUCAIRN_BACKUP_S3_BUCKET is empty in $env_file — set a destination bucket"
  [ -n "$recipient" ] || fail "backup: LUCAIRN_BACKUP_AGE_RECIPIENT is empty in $env_file — dumps would be uploaded UNENCRYPTED; set an age recipient (public key, age1...)"

  local stamp work aws_extra
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  work="$(mktemp -d)"
  # FIX-D (full-stack-test-results-2026-05-29): bake the workdir path into the
  # RETURN trap at registration time (double-quote, not single-quote) so the
  # cleanup never re-expands "$work" when the trap fires — that late expansion
  # tripped `set -u` ("work: unbound variable") once a nested function return
  # ran this trap out of the local's scope.
  # shellcheck disable=SC2064
  trap "rm -rf '$work'" RETURN
  aws_extra="$(backup_aws_args "$endpoint")"

  local row svc db usr dump enc key
  for row in $LUCAIRN_BACKUP_DBS; do
    svc="${row%%:*}"; db="${row#*:}"; usr="${db##*:}"; db="${db%%:*}"
    dump="$work/${db}-${stamp}.dump"
    enc="${dump}.age"
    key="${prefix}lucairn/${svc}/${db}-${stamp}.dump.age"

    info "backup($db): pg_dump -Fc via $svc ..."
    # shellcheck disable=SC2086
    $dc -f "$compose_file" --env-file "$env_file" exec -T "$svc" \
      pg_dump -U "$usr" -d "$db" -Fc > "$dump"
    [ -s "$dump" ] || fail "backup($db): EMPTY DUMP from $svc"

    info "backup($db): encrypting with age (client-side) ..."
    age -r "$recipient" -o "$enc" "$dump"
    rm -f "$dump"
    # Defensive: the uploaded object must be age-encrypted, never a raw
    # pg_dump. age v1 files begin with the literal "age-encryption.org/v1"
    # (21 bytes); a custom-format pg_dump begins with "PGDMP". Read >= the
    # full magic before grepping — a 16-byte slice TRUNCATES the 18-char
    # needle and can NEVER match, which would abort every valid backup.
    head -c 64 "$enc" | grep -q "age-encryption.org" \
      || fail "backup($db): encryption check FAILED — refusing to upload plaintext"

    info "backup($db): uploading s3://${bucket}/${key} ..."
    # shellcheck disable=SC2086
    aws s3 cp "$enc" "s3://${bucket}/${key}" --region "$region" $aws_extra

    if [ "$do_verify" -eq 1 ]; then
      backup_verify_roundtrip "$enc" "$env_file" "$db" "$usr"
    fi
    rm -f "$enc"
    info "backup($db): OK ${key}"
  done

  backup_prune "$bucket" "$region" "$prefix" "$retention" "$aws_extra"
  info "backup: ok ($stamp)"
}

# Prune S3 objects older than retention days under each compliance-DB prefix.
backup_prune() {
  local bucket="$1" region="$2" prefix="$3" retention="$4" aws_extra="$5"
  local cutoff
  cutoff="$(date -u -d "-${retention} days" +%Y-%m-%d 2>/dev/null \
    || date -u -v-"${retention}"d +%Y-%m-%d)"
  info "backup: pruning objects older than ${retention} days (< ${cutoff}) ..."
  local row svc p oldkey
  for row in $LUCAIRN_BACKUP_DBS; do
    svc="${row%%:*}"
    p="${prefix}lucairn/${svc}/"
    # shellcheck disable=SC2086
    aws s3api list-objects-v2 --bucket "$bucket" --prefix "$p" --region "$region" $aws_extra \
      --query "Contents[?LastModified<='${cutoff}'].Key" --output text 2>/dev/null \
      | tr '\t' '\n' | while read -r oldkey; do
          [ -n "$oldkey" ] && [ "$oldkey" != "None" ] || continue
          info "backup: pruning s3://${bucket}/${oldkey}"
          # shellcheck disable=SC2086
          aws s3 rm "s3://${bucket}/${oldkey}" --region "$region" $aws_extra || true
        done
  done
}

# Decrypt an encrypted dump into a throwaway Postgres container and assert it
# pg_restores cleanly + has non-zero rows. Used by `backup --verify`.
backup_verify_roundtrip() {
  local enc="$1" env_file="$2" db="$3" usr="$4"
  local identity scratch
  identity="$(env_value "$env_file" LUCAIRN_BACKUP_AGE_IDENTITY_FILE)"
  [ -n "$identity" ] || fail "backup --verify: LUCAIRN_BACKUP_AGE_IDENTITY_FILE is empty — need the age private identity to decrypt"
  require_file "$identity" "age identity file"

  local work2 plain
  work2="$(mktemp -d)"
  plain="$work2/${db}.dump"
  info "verify($db): decrypting + restoring into a throwaway postgres:16-alpine ..."
  age -d -i "$identity" -o "$plain" "$enc"
  [ -s "$plain" ] || { rm -rf "$work2"; fail "verify($db): decrypt produced empty output"; }

  scratch="lucairn-bk-verify-${db}-$$"
  docker run -d --rm --name "$scratch" \
    -e POSTGRES_PASSWORD=verify -e POSTGRES_DB="$db" -e POSTGRES_USER="$usr" \
    postgres:16-alpine >/dev/null
  # `fail` does `exit 1`, which fires the EXIT trap (not the RETURN trap), so
  # register the scratch-container teardown on BOTH so a hard failure mid-verify
  # never leaks a running throwaway Postgres. EXIT runs once at script end.
  # shellcheck disable=SC2064
  trap "docker rm -f '$scratch' >/dev/null 2>&1 || true; rm -rf '$work2'" RETURN EXIT
  local i ready=0
  for i in $(seq 1 30); do
    if docker exec "$scratch" pg_isready -U "$usr" -d "$db" >/dev/null 2>&1; then ready=1; break; fi
    sleep 1
  done
  [ "$ready" -eq 1 ] || fail "verify($db): scratch postgres never became ready"
  # FIX-D (full-stack-test-results-2026-05-29): --no-acl. The dump carries
  # GRANT/REVOKE statements for the live app role (e.g. audit_app), which does
  # NOT exist in this throwaway postgres:16-alpine. Without --no-acl pg_restore
  # errors on the ACL statements and the verify aborts even though the DATA
  # round-trips fine. The verify only proves the dump restores + has tables;
  # ACL restoration is not part of that contract.
  docker exec -i "$scratch" pg_restore -U "$usr" -d "$db" --no-owner --no-acl --clean --if-exists < "$plain" \
    || fail "verify($db): pg_restore failed"
  local tables
  tables="$(docker exec "$scratch" psql -U "$usr" -d "$db" -tAc \
    "SELECT count(*) FROM information_schema.tables WHERE table_schema='public';" 2>/dev/null || echo 0)"
  [ "${tables:-0}" -gt 0 ] || fail "verify($db): restored DB has zero public tables"
  info "verify($db): OK — restored ${tables} public tables into throwaway DB"
  # Clear the EXIT trap on success so a later DB's verify can register its own
  # without this one's teardown firing for an already-removed container. The
  # RETURN trap still fires now to clean THIS DB's scratch + workdir.
  trap - EXIT
}

# lucairn restore --env customer.env --stamp STAMP [--compose FILE] [--db NAME]
# Downloads + decrypts + pg_restores the chosen STAMP's dumps into the LIVE
# compose compliance DBs. Restore into clean DBs only (the dump does not
# truncate existing rows; --clean --if-exists drops+recreates objects).
restore() {
  local env_file="" compose_file="$ROOT/docker-compose.customer.yml" stamp="" only_db=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --env) env_file="$2"; shift 2 ;;
      --compose) compose_file="$2"; shift 2 ;;
      --stamp) stamp="$2"; shift 2 ;;
      --db) only_db="$2"; shift 2 ;;
      -h|--help) usage; return 0 ;;
      *) fail "restore: unknown option: $1" ;;
    esac
  done
  [ -n "$env_file" ] || fail "restore: --env customer.env is required"
  [ -n "$stamp" ] || fail "restore: --stamp YYYYMMDDTHHMMSSZ is required (the backup timestamp to restore)"
  require_file "$env_file" "env file"
  backup_require_tools

  local dc; dc="$(compose_cmd)"
  [ -n "$dc" ] || fail "docker compose not available"

  local bucket endpoint region prefix identity aws_extra
  bucket="$(env_value "$env_file" LUCAIRN_BACKUP_S3_BUCKET)"
  endpoint="$(env_value "$env_file" LUCAIRN_BACKUP_S3_ENDPOINT)"
  region="$(env_value "$env_file" LUCAIRN_BACKUP_S3_REGION)"; [ -n "$region" ] || region="eu-central-1"
  prefix="$(env_value "$env_file" LUCAIRN_BACKUP_S3_PREFIX)"
  identity="$(env_value "$env_file" LUCAIRN_BACKUP_AGE_IDENTITY_FILE)"
  [ -n "$bucket" ] || fail "restore: LUCAIRN_BACKUP_S3_BUCKET is empty in $env_file"
  [ -n "$identity" ] || fail "restore: LUCAIRN_BACKUP_AGE_IDENTITY_FILE is empty in $env_file — need the age private identity to decrypt"
  require_file "$identity" "age identity file"
  aws_extra="$(backup_aws_args "$endpoint")"

  # FIX-D (full-stack-test-results-2026-05-29): bake the workdir into the RETURN
  # trap at registration time so the cleanup never re-expands "$work" under
  # `set -u` when the trap fires out of this local's scope.
  # shellcheck disable=SC2064
  local work; work="$(mktemp -d)"; trap "rm -rf '$work'" RETURN
  local row svc db usr key enc plain
  for row in $LUCAIRN_BACKUP_DBS; do
    svc="${row%%:*}"; db="${row#*:}"; usr="${db##*:}"; db="${db%%:*}"
    if [ -n "$only_db" ] && [ "$db" != "$only_db" ]; then continue; fi
    key="${prefix}lucairn/${svc}/${db}-${stamp}.dump.age"
    enc="$work/${db}.dump.age"; plain="$work/${db}.dump"

    info "restore($db): downloading s3://${bucket}/${key} ..."
    # shellcheck disable=SC2086
    aws s3 cp "s3://${bucket}/${key}" "$enc" --region "$region" $aws_extra \
      || fail "restore($db): download failed — check the --stamp and bucket"
    info "restore($db): decrypting ..."
    age -d -i "$identity" -o "$plain" "$enc"
    [ -s "$plain" ] || fail "restore($db): decrypt produced empty output"

    info "restore($db): pg_restore --clean --if-exists into LIVE $svc ..."
    # shellcheck disable=SC2086
    $dc -f "$compose_file" --env-file "$env_file" exec -T "$svc" \
      pg_restore -U "$usr" -d "$db" --no-owner --clean --if-exists < "$plain" \
      || fail "restore($db): pg_restore failed"
    info "restore($db): OK"
  done
  info "restore: ok ($stamp)"
}

# ---------------------------------------------------------------------------
# verify-images — cryptographically verify the published Lucairn images against
# the bundled cosign public key + the Sigstore Rekor public transparency log.
#
# Lucairn cosign-signs every customer-pulled container image at release time
# with a single Lucairn-held Image Signing Key (custody documented in the DSA
# repo: docs/operations/key-ceremony-runbook.md § Key Inventory). The matching
# PUBLIC key ships in this kit at keys/lucairn-cosign.pub, so a customer can
# independently verify that each image they pull was signed by Lucairn and that
# the signature is recorded in a public transparency log — answering an
# enterprise supply-chain questionnaire without trusting the registry alone.
#
# This is supply-chain image provenance. It is ORTHOGONAL to the Veil
# certificate chain (which signs per-request claims with the Witness/claim keys
# at runtime). Image signing proves "this binary is the one Lucairn published";
# the cert chain proves "this request was sanitized + isolated + attested".
#
# Image set + digests: the AUTHORITATIVE verify set is keys/image-digests-<tag>.txt
# — one `<repo>:<tag> <sha256:digest>` line per signed artifact, recorded at sign
# time by scripts/sign-images.sh (DSA repo) and committed to this kit. That file
# is the single source of WHAT was signed (it also covers artifacts not listed in
# image-manifest.yaml, e.g. admin/demo/ingest). verify-images binds verification
# to the exact signed BYTES (digest), not the mutable tag, so a re-pointed tag is
# caught as a downgrade/substitution rather than silently re-verified.
#
# Slice 3 will fold these digests into image-manifest.yaml + `doctor --strict`;
# keys/image-digests-*.txt is the Slice-1 interim record.
# ---------------------------------------------------------------------------

verify_images_usage() {
  cat <<'USAGE'
Usage:
  lucairn verify-images [--tag TAG] [--registry REG] [--key PATH]

Verifies every published Lucairn image's cosign signature BY DIGEST against the
bundled public key (keys/lucairn-cosign.pub) and the Sigstore Rekor public
transparency log.

For each image recorded in keys/image-digests-<tag>.txt it:
  1. resolves the tag's CURRENT registry digest and asserts it EQUALS the
     recorded (signed) digest — a mismatch means the tag was re-pointed to
     other bytes (downgrade/substitution) and is a hard FAIL;
  2. runs `cosign verify --key <pubkey> <repo>@<recorded-digest>` and requires
     a transparency-log (Rekor) entry in the output before printing PASS.

Exits non-zero if any image's digest drifted, signature is missing/invalid, or
no transparency-log entry is present.

Requires `cosign` (>= v2.0) on PATH (https://github.com/sigstore/cosign) and a
tool to resolve tag->digest (`docker buildx imagetools`, `crane`, or `skopeo`).

Options:
  --tag TAG       Release tag to verify (default: the single release covered by
                  the present keys/image-digests-*.txt — currently 0.5.0).
                  Errors if no keys/image-digests-<tag>.txt exists.
  --registry REG  Override the registry host for ALL images (default: the
                  registry recorded in the digests file, e.g. ghcr.io/declade).
  --key PATH      cosign public key (default: keys/lucairn-cosign.pub).
USAGE
}

# image_manifest_value KEY — extract a top-level scalar from
# image-manifest.yaml, stripping the key prefix, any inline comment, surrounding
# whitespace, and wrapping quotes. Mirrors the awk extraction used by
# check_image_manifest.
#
# NOTE: named image_manifest_value (not manifest_value) to avoid colliding with
# the model-manifest helper manifest_value() defined earlier in this file, which
# takes (manifest, key) and scans the `model:` block. Bash is last-def-wins, so
# a same-named def here would silently break validate_model_manifest /
# manifest_checksum_policy (bundle create/verify/prepare) → "missing model.name".
image_manifest_value() {
  local key="$1" manifest="${ROOT}/image-manifest.yaml"
  [ -f "$manifest" ] || return 0
  awk -v k="$key" -F: '
    $0 ~ "^[[:space:]]*" k ":" {
      sub(/^[^:]+:[[:space:]]*/, "");
      sub(/[[:space:]]+#.*$/, "");
      gsub(/^[[:space:]]+|[[:space:]]+$/, "");
      gsub(/^"|"$/, "");
      print; exit
    }' "$manifest"
}

# verify_images_default_tag — derive the default --tag from the SINGLE
# keys/image-digests-*.txt present (FIX-5: do not fall back to the manifest's
# lagging tag). Errors if zero or more than one digests file exists.
verify_images_default_tag() {
  local f matches=() base
  for f in "$ROOT"/keys/image-digests-*.txt; do
    [ -e "$f" ] || continue
    matches+=("$f")
  done
  if [ "${#matches[@]}" -eq 0 ]; then
    fail "verify-images: no keys/image-digests-*.txt found — cannot determine which release to verify. Pass --tag TAG once a keys/image-digests-<tag>.txt exists."
  fi
  if [ "${#matches[@]}" -gt 1 ]; then
    fail "verify-images: multiple keys/image-digests-*.txt present — pass --tag TAG to pick a release."
  fi
  base="$(basename "${matches[0]}")"
  base="${base#image-digests-}"
  printf '%s' "${base%.txt}"
}

# sanitize_digest STR — trim SURROUNDING whitespace from STR and echo it back
# ONLY if it is a bare, canonical image digest (sha256:<64 lowercase hex>).
# Anything else (empty, multi-line text dump, partial output, INTERNAL
# whitespace) echoes empty.
# This is the load-bearing gate that stops a resolver's human-readable
# inspect output from ever being mistaken for a digest. Surfaced by the A1
# Vast fresh-install verify: `docker buildx imagetools inspect --format
# '{{.Manifest.Digest}}'` on buildx v0.23.0 returns the full text dump (not
# the bare digest) for a multi-arch image INDEX — non-empty, so the old code
# accepted it and never fell through to crane/skopeo, then false-reported
# "TAG RE-POINTED" because the text dump != the recorded digest.
#
# FIX-2 (security): trim ONLY leading/trailing whitespace — NEVER strip
# internal whitespace. The previous `tr -d '[:space:]'` deleted ALL
# whitespace, so "sha256:<32hex>\n<32hex>" collapsed into a valid-looking
# "sha256:<64hex>" and passed the gate. For a signature-verification gate
# that must REJECT, so a stray newline inside a malformed/spliced digest can
# never be sanitized into a fake-valid one. The anchored ^...$ regex below
# then naturally rejects any remaining internal whitespace.
sanitize_digest() {
  local d="$1"
  # Trim ONLY leading/trailing whitespace (incl. surrounding newlines a text
  # dump would carry). Do NOT touch internal whitespace — see FIX-2 above.
  d="${d#"${d%%[![:space:]]*}"}"   # strip leading whitespace
  d="${d%"${d##*[![:space:]]}"}"   # strip trailing whitespace
  case "$d" in
    sha256:*)
      # Exactly "sha256:" + 64 lowercase hex chars, nothing else (the anchored
      # ^...$ rejects any internal whitespace/newline that survived the trim).
      if printf '%s' "$d" | grep -Eq '^sha256:[0-9a-f]{64}$'; then
        printf '%s' "$d"
      fi
      ;;
  esac
}

# image_current_digest REF — resolve a tag ref to its CURRENT registry digest
# using whichever resolver is on PATH. Echoes "sha256:..." (validated bare
# digest) or empty on failure. Each resolver's output is validated through
# sanitize_digest; an invalid/non-digest result is treated as "no result" and
# falls through to the next resolver, so a text-dump can never leak through.
#
# FIX-1 (security, HIGH): the resolver MUST always yield the manifest-list /
# INDEX (top-level) digest — the same digest cosign signs
# (scripts/sign-images.sh: "cosign signs the manifest-list digest") and the
# one recorded in keys/image-digests-<tag>.txt. For a multi-arch image,
# `{{json .Manifest}}` is an OCI index whose JSON carries a top-level
# "digest" (the INDEX) AND a nested "manifests":[{...,"digest":<CHILD>},...]
# array of per-architecture CHILD digests. A greedy/last-match extraction
# grabs a CHILD digest → child != recorded INDEX → false "TAG RE-POINTED".
# We therefore extract ONLY the top-level/index digest:
#   - with jq:    `.digest` (jq returns the top-level field, never a child);
#   - without jq: truncate the JSON at the first "manifests" occurrence so a
#                 nested child digest is structurally unreachable, then take
#                 the FIRST "digest" match.
image_current_digest() {
  local ref="$1" d="" raw="" head=""
  if have docker; then
    # Primary: parse the OCI index/manifest JSON and take the TOP-LEVEL digest.
    raw="$(docker buildx imagetools inspect "$ref" --format '{{json .Manifest}}' 2>/dev/null)" || raw=""
    if [ -n "$raw" ]; then
      if have jq; then
        # jq returns the top-level ".digest" = the index/manifest-list digest,
        # never a nested per-arch child. // empty => empty string on absence.
        d="$(sanitize_digest "$(printf '%s' "$raw" | jq -r '.digest // empty' 2>/dev/null)")"
      else
        # No jq: drop everything from the FIRST "manifests" key onward so the
        # nested per-arch child digests are unreachable, THEN take the first
        # "digest" — which is now guaranteed to be the top-level index digest.
        head="$(printf '%s' "$raw" | sed 's/"manifests".*//')"
        d="$(sanitize_digest "$(printf '%s' "$head" | sed -n 's/.*"digest"[[:space:]]*:[[:space:]]*"\(sha256:[0-9a-f]\{64\}\).*/\1/p' | head -n1)")"
      fi
    fi
    # Fallback: the Docker-documented template returns the manifest-list/index
    # digest directly. (On buildx v0.23 this may text-dump for a multi-arch
    # INDEX, in which case sanitize_digest rejects it and we fall through.)
    if [ -z "$d" ]; then
      raw="$(docker buildx imagetools inspect "$ref" --format '{{.Manifest.Digest}}' 2>/dev/null)" || raw=""
      d="$(sanitize_digest "$raw")"
    fi
  fi
  # crane digest returns the index digest for a multi-arch ref by default.
  if [ -z "$d" ] && have crane; then
    raw="$(crane digest "$ref" 2>/dev/null)" || raw=""
    d="$(sanitize_digest "$raw")"
  fi
  # skopeo inspect (no --raw) reports the manifest-list/index digest.
  if [ -z "$d" ] && have skopeo; then
    raw="$(skopeo inspect --format '{{.Digest}}' "docker://$ref" 2>/dev/null)" || raw=""
    d="$(sanitize_digest "$raw")"
  fi
  printf '%s' "$d"
}

verify_images() {
  local registry="" tag="" key=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --registry) [ $# -ge 2 ] || fail "verify-images: --registry needs a value (see: lucairn verify-images --help)"; registry="$2"; shift 2 ;;
      --tag)      [ $# -ge 2 ] || fail "verify-images: --tag needs a value (see: lucairn verify-images --help)"; tag="$2"; shift 2 ;;
      --key)      [ $# -ge 2 ] || fail "verify-images: --key needs a value (see: lucairn verify-images --help)"; key="$2"; shift 2 ;;
      -h|--help) verify_images_usage; return 0 ;;
      *) fail "verify-images: unknown argument: $1 (see: lucairn verify-images --help)" ;;
    esac
  done

  # cosign presence + version floor (FIX-4: require >= v2.x; this also underpins
  # the tlog-by-default assumption the Rekor-entry check below relies on).
  if ! have cosign; then
    fail "verify-images: 'cosign' not found on PATH. Install it from https://github.com/sigstore/cosign/releases (verify its published checksum — see OPS.md), then re-run."
  fi
  local cosign_major
  cosign_major="$(cosign version 2>/dev/null | awk -F'[v.]' '/GitVersion/{print $2; exit}')"
  case "$cosign_major" in
    ''|*[!0-9]*) warn "verify-images: could not parse cosign version (expected >= v2.0); proceeding, but a Rekor tlog entry is still required for PASS." ;;
    *) [ "$cosign_major" -ge 2 ] || fail "verify-images: cosign >= v2.0 is required (found v${cosign_major}.x). Upgrade from https://github.com/sigstore/cosign/releases." ;;
  esac

  # A tag->digest resolver is required to bind verification to the signed bytes.
  if ! have docker && ! have crane && ! have skopeo; then
    fail "verify-images: need a registry digest resolver on PATH — install one of: 'docker' (buildx imagetools), 'crane', or 'skopeo'."
  fi

  # Public key: explicit --key wins, else the kit-bundled key.
  key="${key:-$ROOT/keys/lucairn-cosign.pub}"
  [ -f "$key" ] || fail "verify-images: public key not found at '$key' (the kit ships keys/lucairn-cosign.pub)"

  # Registry override: ONLY when explicitly requested (CLI flag or env). The
  # registry recorded in each digests-file line is authoritative by default;
  # an override is for air-gapped mirrors that re-host the SAME signed bytes.
  # image_manifest_value provides a last-resort default for an operator who has
  # set the manifest registry but expects verify-images to honor it.
  registry="${registry:-${LUCAIRN_IMAGE_REGISTRY:-}}"
  if [ -z "$registry" ]; then
    local mreg; mreg="$(image_manifest_value default_lucairn_image_registry)"
    # Only treat the manifest registry as an override if it DIFFERS from the
    # recorded host (a mirror); otherwise leave empty (use recorded refs as-is).
    case "$mreg" in
      ''|ghcr.io/declade) registry="" ;;
      *) registry="$mreg" ;;
    esac
  fi

  # Tag: CLI flag wins; otherwise default to the single committed digests file
  # (NOT the manifest's possibly-lagging default_lucairn_image_tag — FIX-5).
  tag="${tag:-$(verify_images_default_tag)}"
  local digests_file="$ROOT/keys/image-digests-${tag}.txt"
  [ -f "$digests_file" ] || fail "verify-images: no signed-digest record for tag '$tag' (expected $digests_file). This release was not signed, or the tag is wrong."

  # ---- FIX-A: canonical EXPECTED artifact set (membership + cardinality) ----
  # The digests file is the verify SOURCE, but it must contain EXACTLY the
  # artifacts Lucairn publishes for a release — no more, no fewer, no dups. A
  # truncated/trimmed file (e.g. one entry) must NOT pass as "all verified".
  #
  # SINGLE SOURCE OF TRUTH for the release image set. If a future release
  # legitimately adds/removes an image, update THIS list (and the dashboard
  # pin below) — it is the one place verify-images keys off.
  #
  # The 12 dsa-* services ride the release --tag (default 0.5.0); the dashboard
  # ships on its OWN independent cadence and is pinned here (currently 0.8.2),
  # mirroring optional_services.lucairn-dashboard.image_tag in image-manifest.yaml
  # and the 10 dashboard-tag surfaces documented in customer.env.example.
  local dsa_images=(
    dsa-gateway dsa-sanitizer dsa-audit dsa-id-bridge dsa-sandbox-a dsa-sandbox-b
    dsa-veil-witness dsa-reid-guard dsa-admin dsa-demo dsa-ingest dsa-llm-auditor
  )
  local dashboard_image="lucairn-dashboard"
  local dashboard_tag="0.8.2"   # FIX-A: dashboard's own pinned tag (NOT --tag)
  local canonical_host="ghcr.io/declade"

  # Build the expected recorded-ref set (as the digests file records them, i.e.
  # BEFORE any --registry mirror override; the file is canonical-host-pinned).
  # Bash 3.2 compatible (Slice 2 lesson #7): indexed arrays only, no `local -A`.
  local -a expected_refs=()
  local _img
  for _img in "${dsa_images[@]}"; do
    expected_refs+=("${canonical_host}/${_img}:${tag}")
  done
  expected_refs+=("${canonical_host}/${dashboard_image}:${dashboard_tag}")

  local failed=0 checked=0 line ref recorded current out rc repo repo_tag
  info "verify-images: verifying cosign signatures BY DIGEST against $key"
  info "verify-images: tag=$tag  record=$digests_file  (+ Rekor transparency log)"
  info "verify-images: expecting EXACTLY ${#expected_refs[@]} artifacts (${#dsa_images[@]} dsa-* @ $tag + $dashboard_image @ $dashboard_tag)"
  [ -n "$registry" ] && info "verify-images: registry override: $registry"
  echo

  # ---- Pass 1: load the digests file into PARALLEL indexed arrays (ref[i] ->
  # digest[i]) and detect malformed lines + DUPLICATE refs. No associative
  # arrays — bash 3.2 has none — so membership is a linear scan (the set is ~13).
  local -a file_refs=() file_digests=()
  local i seen
  while IFS= read -r line || [ -n "$line" ]; do
    # Strip comments + blank lines.
    line="${line%%#*}"
    ref="${line%% *}"
    recorded="${line##* }"
    # Trim surrounding whitespace from the ref field.
    ref="${ref#"${ref%%[![:space:]]*}"}"
    ref="${ref%"${ref##*[![:space:]]}"}"
    [ -n "$ref" ] || continue
    # A well-formed entry is "<repo>:<tag> <sha256:...>"; the digest must parse.
    case "$recorded" in
      sha256:*) ;;
      *) fail "verify-images: malformed digest record for '$ref' in $digests_file — expected '<repo>:<tag> sha256:...', got: '$line'" ;;
    esac
    # DUPLICATE detection: ref already recorded -> hard FAIL.
    seen=0
    for i in "${file_refs[@]:+${file_refs[@]}}"; do
      [ "$i" = "$ref" ] && { seen=1; break; }
    done
    [ "$seen" -eq 0 ] || fail "verify-images: DUPLICATE entry for '$ref' in $digests_file — each artifact must appear exactly once."
    file_refs+=("$ref")
    file_digests+=("$recorded")
  done < "$digests_file"

  # ---- FIX-A: assert EXACT membership of the expected set against the file.
  # MISSING: an expected artifact is not recorded -> hard FAIL (truncation).
  local -a missing=() unexpected=()
  local want have found
  for want in "${expected_refs[@]}"; do
    found=0
    for have in "${file_refs[@]:+${file_refs[@]}}"; do
      [ "$have" = "$want" ] && { found=1; break; }
    done
    [ "$found" -eq 1 ] || missing+=("$want")
  done
  # UNEXPECTED: a recorded artifact is not in the canonical set -> hard FAIL.
  for have in "${file_refs[@]:+${file_refs[@]}}"; do
    found=0
    for want in "${expected_refs[@]}"; do
      [ "$want" = "$have" ] && { found=1; break; }
    done
    [ "$found" -eq 1 ] || unexpected+=("$have")
  done
  if [ "${#missing[@]}" -gt 0 ] || [ "${#unexpected[@]}" -gt 0 ]; then
    echo "verify-images: FAILED — $digests_file does not match the expected artifact set." >&2
    [ "${#missing[@]}" -gt 0 ]    && echo "  MISSING (expected but not recorded):    ${missing[*]}" >&2
    [ "${#unexpected[@]}" -gt 0 ] && echo "  UNEXPECTED (recorded but not expected):  ${unexpected[*]}" >&2
    echo "  Expected exactly ${#expected_refs[@]} artifacts; the canonical set lives in verify_images() (dsa_images + dashboard pin)." >&2
    return 1
  fi

  # ---- Pass 2: per-image digest verify, in canonical order. set -e-safe so
  # one cosign failure does NOT abort the loop (FIX-B) — every image is checked
  # and accounted, and the summary reports ALL failures.
  for ref in "${expected_refs[@]}"; do
    # Look up the recorded digest for this expected ref (linear scan; verified
    # present by the membership check above).
    recorded=""
    for i in $(seq 0 $(( ${#file_refs[@]} - 1 ))); do
      if [ "${file_refs[$i]}" = "$ref" ]; then recorded="${file_digests[$i]}"; break; fi
    done

    # Apply optional mirror override: swap the registry+org host prefix, keep
    # the trailing <repo>:<tag>. Recorded ref is <host>/<org>/<repo>:<tag>.
    if [ -n "$registry" ]; then
      repo_tag="${ref#*/}"      # drop host segment (e.g. ghcr.io)
      repo_tag="${repo_tag#*/}" # drop org segment (e.g. declade) -> repo:tag
      ref="${registry%/}/${repo_tag}"
    fi

    checked=$((checked + 1))
    repo="${ref%:*}"

    # 1. Resolve current tag digest and assert it matches the recorded digest.
    current="$(image_current_digest "$ref")"
    if [ -z "$current" ]; then
      echo "FAIL  $ref (could not resolve a valid registry digest — image missing, registry unreachable/unauthenticated, or no working resolver. Install 'crane' or 'skopeo', or upgrade Docker buildx, then re-run; ensure 'docker login' to the registry succeeded.)" >&2
      failed=$((failed + 1))
      continue
    fi
    if [ "$current" != "$recorded" ]; then
      echo "FAIL  $ref (TAG RE-POINTED: current digest $current != signed digest $recorded — downgrade/substitution; refusing to verify)" >&2
      failed=$((failed + 1))
      continue
    fi

    # 2. cosign verify against the recorded digest; capture output; require a
    #    transparency-log entry before PASS (FIX-3). FIX-B: the `if` guard keeps
    #    a nonzero cosign exit from tripping `set -e` so the loop continues.
    if out="$(cosign verify --key "$key" --output json "${repo}@${recorded}" 2>&1)"; then
      rc=0
    else
      rc=$?
    fi
    if [ "$rc" -ne 0 ]; then
      echo "FAIL  ${repo}@${recorded} (cosign verify failed: $(printf '%s' "$out" | tail -n1))" >&2
      failed=$((failed + 1))
      continue
    fi
    if ! printf '%s' "$out" | grep -qiE 'logindex|tlogentries|"bundle"|rekor'; then
      echo "FAIL  ${repo}@${recorded} (signature valid but NO transparency-log (Rekor) entry found — refusing to PASS)" >&2
      failed=$((failed + 1))
      continue
    fi
    info "PASS  ${repo}@${recorded}  (signature valid + Rekor entry present)"
  done

  echo
  if [ "$checked" -eq 0 ]; then
    fail "verify-images: digests file $digests_file contained no image entries."
  fi
  if [ "$failed" -eq 0 ]; then
    info "verify-images: OK — all $checked images verified by digest (cosign signature valid + Rekor entry present)"
    return 0
  fi
  echo "verify-images: FAILED — $failed of $checked images did not verify" >&2
  return 1
}

# ---------------------------------------------------------------------------
# license — issue / verify / gen-key for self-hosted DEPLOYMENT entitlement
# licenses (Ed25519-signed, offline-verifiable). OPERATOR/Lucairn-side only.
#
# The actual signing lives in the DSA gateway tool `license-sign` (so the
# canonical signed bytes are byte-identical to what the gateway verifier
# reconstructs — a cross-repo contract). This wrapper locates that tool and
# shells out. Discovery order:
#   1. $LUCAIRN_LICENSE_SIGN_BIN  — explicit path to a prebuilt binary.
#   2. `license-sign` on $PATH.
#   3. `go run ./services/gateway/cmd/license-sign` from $DSA_REPO (the
#      dual-sandbox-architecture clone) — Lucairn-internal build path.
#
# This is the deployment FEATURE license — distinct from the platform tier
# license issued by the gateway's HMAC `license-gen`. The private signing
# seed (LICENSE_SIGNING_KEY_SEED_HEX) lives ONLY in the Lucairn vault and is
# NEVER shipped to a customer. See docs/operations on the License Signing
# Key (DSA repo: docs/operations/key-ceremony-runbook.md).
# ---------------------------------------------------------------------------

license_usage() {
  cat <<'USAGE'
Usage:
  lucairn license issue   --license-id ID --customer-id ID --customer-name NAME \
                          --valid-until YYYY-MM-DD [--features csv] \
                          --signing-key-hex HEX | --signing-key-file PATH
  lucairn license verify  --license TOKEN | --license-file PATH \
                          --public-key-hex HEX | --public-key-file PATH
  lucairn license gen-key

Notes:
  - issue/gen-key are OPERATOR-only (Lucairn). The signing seed never ships to customers.
  - Customers receive the signed token + the public key only.
  - Set LUCAIRN_LICENSE_SIGN_BIN, put `license-sign` on PATH, or set DSA_REPO
    to the dual-sandbox-architecture clone so this wrapper can run the signer.
USAGE
}

# license_sign_runner echoes the command prefix used to invoke the DSA
# license-sign tool, or fails with guidance if none is available.
license_sign_runner() {
  if [ -n "${LUCAIRN_LICENSE_SIGN_BIN:-}" ]; then
    [ -x "$LUCAIRN_LICENSE_SIGN_BIN" ] || fail "LUCAIRN_LICENSE_SIGN_BIN=$LUCAIRN_LICENSE_SIGN_BIN is not executable"
    printf '%s' "$LUCAIRN_LICENSE_SIGN_BIN"
    return 0
  fi
  if have license-sign; then
    printf 'license-sign'
    return 0
  fi
  if [ -n "${DSA_REPO:-}" ] && [ -d "$DSA_REPO/services/gateway/cmd/license-sign" ]; then
    have go || fail "DSA_REPO is set but 'go' is not on PATH (needed to run license-sign from source)"
    printf 'go -C %q run ./services/gateway/cmd/license-sign' "$DSA_REPO"
    return 0
  fi
  fail "license-sign tool not found. Set LUCAIRN_LICENSE_SIGN_BIN to a prebuilt binary, put 'license-sign' on PATH, or set DSA_REPO to the dual-sandbox-architecture clone."
}

license_command() {
  local subcmd="${1:-}"
  case "$subcmd" in
    issue|verify|gen-key)
      shift
      # shellcheck disable=SC2046  # word-split runner prefix intentionally
      exec $(license_sign_runner) "$subcmd" "$@"
      ;;
    -h|--help|"")
      license_usage
      ;;
    *)
      fail "unknown license subcommand: $subcmd (want: issue | verify | gen-key)"
      ;;
  esac
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    doctor) shift; doctor "$@" ;;
    support-bundle) shift; support_bundle "$@" ;;
    bundle) shift; bundle_command "$@" ;;
    backup) shift; backup "$@" ;;
    restore) shift; restore "$@" ;;
    license) shift; license_command "$@" ;;
    verify-images) shift; verify_images "$@" ;;
    -h|--help|"") usage ;;
    *) fail "unknown command: $cmd" ;;
  esac
}

main "$@"
